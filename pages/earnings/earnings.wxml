<view class="page-shell earnings-page {{appearancePageClass}}">
  <view wx:if="{{isLoading}}" class="rise-in">
    <loading-panel rows="2" appearance-page-class="{{appearancePageClass}}" />
  </view>

  <block wx:else>
    <view class="hero rise-in earnings-hero">
      <view class="eyebrow-row earnings-hero-top">
        <view class="eyebrow">收益统计</view>
        <view class="source-badge">{{dataSource}}</view>
      </view>
      <view class="hero-metrics earnings-hero-metrics">
        <view class="metric-card earnings-metric-card" wx:for="{{earnings.summary}}" wx:key="label">
          <view class="metric-label">{{item.label}}</view>
          <view class="metric-value">{{item.value}}</view>
        </view>
      </view>
    </view>

    <view class="section rise-in stagger-2">
      <view class="section-header earnings-section-header">
        <view class="section-title">成交明细</view>
        <view class="chip earnings-month-chip">本月</view>
      </view>
      <view class="deal-card earnings-deal-card" wx:for="{{earnings.deals}}" wx:key="id" data-project-id="{{item.projectId}}" bindtap="openDealProject">
        <view class="project-top earnings-deal-top">
          <view class="earnings-deal-main">
            <view class="project-name">{{item.name}}</view>
            <view class="project-meta">{{item.date}}</view>
          </view>
          <view class="status-badge {{item.status === '全部回款' ? 'is-success' : item.status === '未回款' ? 'is-danger' : ''}}">{{item.status}}</view>
        </view>

        <view class="compact-inline-metrics earnings-inline-metrics">
          <view class="compact-inline-item earnings-inline-item">成交金额 {{item.amount}}</view>
          <view class="compact-inline-item earnings-inline-item">预期提成 {{item.commission}}</view>
        </view>

        <view wx:if="{{item.note}}" class="project-summary-compact earnings-note-card">
          <view class="project-summary-row">
            <view class="project-summary-label">备注</view>
            <view class="project-summary-text">{{item.note}}</view>
          </view>
        </view>
      </view>

      <empty-state
        wx:if="{{!earnings.deals.length}}"
        appearance-page-class="{{appearancePageClass}}"
        title="本月暂无成交记录"
        desc="登记成交后会自动汇总到这里。"
        image="/assets/illustrations/empty-projects.svg"
        actionText="查看我的项目"
        bind:action="openPage"
        data-url="/pages/projects/projects"
      />
    </view>
  </block>
</view>
