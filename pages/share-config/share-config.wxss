.share-config-page .share-purpose-note {
  margin-top: 12rpx;
}

.share-config-page .preview-card {
  padding: 30rpx;
}

.share-config-page .preview-block + .preview-block,
.share-config-page .preview-contacts {
  margin-top: 18rpx;
}

.share-config-page .preview-block-title {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--theme-text-soft);
}

.share-config-page .preview-block-text {
  margin-top: 8rpx;
  font-size: 25rpx;
  line-height: 1.72;
  color: var(--theme-title);
}

.share-config-page .share-config-metrics {
  margin-top: 16rpx;
  gap: 10rpx;
}

.share-config-page .share-config-metrics .compact-inline-item {
  background: var(--theme-inline-bg);
  color: var(--theme-inline-text);
}

.share-config-page .footer-bar {
  grid-template-columns: 1fr;
}

.footer-bar.appearance-font-large .btn-primary {
  font-size: 30rpx;
}

.footer-bar.appearance-font-readable .btn-primary {
  font-size: 38rpx;
}
