<view class="page-shell phone-bind-page {{appearancePageClass}}">
  <view class="hero rise-in phone-bind-hero">
    <view class="eyebrow-row">
      <view class="eyebrow">绑定手机号</view>
      <view class="source-badge">{{account.phoneVerified ? '已绑定' : '待绑定'}}</view>
    </view>
    <view class="hero-title">先把账户身份补齐</view>
    <view class="hero-subtitle">{{helperText}}</view>
  </view>

  <view class="form-card section rise-in stagger-1 phone-bind-return-card">
    <view class="section-title">绑定完成后的回流</view>
    <view class="card-subtitle">{{returnHint}}</view>
  </view>

  <view class="form-card section rise-in stagger-1">
    <view class="field-group">
      <view class="field-label">当前状态</view>
      <view class="card-subtitle">{{account.phoneVerified ? account.phoneMasked : '尚未绑定手机号'}}</view>
    </view>
    <view class="field-group">
      <view class="field-label">手机号</view>
      <input
        class="input-sim input-native"
        type="number"
        maxlength="11"
        value="{{phoneNumber}}"
        bindinput="onPhoneInput"
        placeholder="请输入 11 位手机号"
        placeholder-class="input-placeholder"
      />
    </view>
    <view class="field-group phone-bind-check-group">
      <view class="field-label">绑定说明</view>
      <checkbox-group bindchange="onConsentChange">
        <label class="phone-bind-check-item">
          <checkbox value="agree" checked="{{consentChecked}}" color="#355d76" />
          <view class="card-subtitle phone-bind-check-copy">我确认该手机号仅用于账号识别、后续付费与权益操作，不会在分享卡中自动对外展示。</view>
        </label>
      </checkbox-group>
    </view>
  </view>

  <view class="form-card section rise-in stagger-2">
    <view class="section-title">绑定后会发生什么</view>
    <view class="phone-bind-timeline">
      <view class="phone-bind-timeline-item">1. 当前账户会标记为已绑定手机号。</view>
      <view class="phone-bind-timeline-item">2. 正式保存项目、跟进、任务时，不再被“需先绑定手机号”拦截。</view>
      <view class="phone-bind-timeline-item">3. 后续订阅与流量包购买会直接归属到当前账户。</view>
    </view>
  </view>

  <view class="footer-bar {{appearancePageClass}}">
    <view class="btn-primary" bindtap="handleBind">{{isSaving ? '绑定中...' : '确认绑定'}}</view>
  </view>
</view>
