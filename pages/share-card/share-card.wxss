}

.share-card-page .hero.hero-sender .brand-lockup-title-share {
  font-size: 34rpx;
  letter-spacing: 1rpx;
}

.share-card-page .brand-lockup-subtitle-share {
  margin-top: 8rpx;
  font-size: 21rpx;
  letter-spacing: 3rpx;
  color: var(--theme-preview-muted);
}

.share-card-page .hero.hero-sender .brand-lockup-subtitle-share {
  margin-top: 4rpx;
  font-size: 19rpx;
  letter-spacing: 2rpx;
}

.share-card-page .hero-title {
  font-size: 42rpx;
}

.share-card-page .hero.hero-sender .eyebrow-row {
  gap: 12rpx;
}

.share-card-page .hero.hero-sender .eyebrow,
.share-card-page .hero.hero-sender .source-badge {
  padding-top: 6rpx;
  padding-bottom: 6rpx;
  font-size: 19rpx;
}

.share-card-page .hero.hero-sender .hero-title {
  margin-top: 14rpx;
  font-size: 38rpx;
}

.share-card-page .hero-subtitle {
  max-width: 92%;
}

.share-card-page .hero.hero-sender .hero-subtitle {
  margin-top: 8rpx;
  max-width: 88%;
  font-size: 22rpx;
  line-height: 1.52;
}

.share-card-page .hero.hero-sender + .section {
  margin-top: 20rpx;
}

.share-card-page .state-card {
  padding: 26rpx;
}

.share-card-page .share-state-head {
  align-items: flex-start;
}

.share-card-page .share-state-summary {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.68;
  color: var(--theme-text-main);
}

.share-card-page .share-state-meta {
  margin-top: 14rpx;
}

.share-card-page .share-state-steps {
  margin-top: 16rpx;
  padding: 18rpx 20rpx 20rpx;
  border-radius: 22rpx;
  background: var(--theme-summary-bg);
  box-shadow: var(--theme-summary-shadow);
}

.share-card-page .share-state-step {
  position: relative;
  padding-left: 18rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: var(--theme-text-secondary);
}

.share-card-page .share-state-step + .share-state-step {
  margin-top: 10rpx;
}

.share-card-page .share-state-step::before {
  content: '';
  position: absolute;
  left: 0;
  top: 14rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--theme-accent);
}

.share-card-page .state-card .inline-actions {
  margin-top: 18rpx;
}

.share-card-page .share-preview-card {
  padding: 26rpx;
  background: var(--theme-project-card-bg);
  box-shadow: var(--theme-project-card-shadow);
}

.share-card-page .share-config-shell {
  padding: 20rpx 22rpx 20rpx;
}

.share-card-page .share-config-overview {
  padding: 16rpx 18rpx 18rpx;
  border-radius: 22rpx;
  background: var(--theme-soft-block-bg);
}

.share-card-page .share-config-topline {
  align-items: flex-start;
  gap: 16rpx;
}

.share-card-page .share-config-project-name {
  flex: 1 1 auto;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.32;
  color: var(--theme-title);
}

.share-card-page .share-config-meta-pills {
  margin-top: 10rpx;
  gap: 6rpx;
}

.share-card-page .share-config-fields {
  margin-top: 10rpx;
  padding: 14rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.44);
  box-shadow: inset 0 0 0 1rpx var(--theme-divider);
}

.share-card-page .share-config-fields-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.share-card-page .share-config-fields-title {
  font-size: 21rpx;
  font-weight: 600;
  color: var(--theme-text-muted);
}

.share-card-page .share-config-fields-count {
  flex: 0 0 auto;
  font-size: 20rpx;
  color: var(--theme-text-soft);
}

.share-card-page .share-config-fields-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.66;
  color: var(--theme-text-main);
}

.share-card-page .shared-detail-value-strong {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--theme-title);
}

.share-card-page .share-preview-head {
  align-items: flex-start;
}

.share-card-page .share-preview-head-main {
  flex: 1 1 auto;
  min-width: 0;
}

.share-card-page .preview-meta-pills {
  margin-top: 10rpx;
}

.share-card-page .share-preview-mode {
  flex: 0 0 auto;
  margin-top: 2rpx;
}

.share-card-page .share-preview-section {
  margin-top: 16rpx;
  padding: 18rpx 20rpx 20rpx;
  border-radius: 22rpx;
  background: var(--theme-summary-bg);
  box-shadow: var(--theme-summary-shadow);
}

.share-card-page .share-preview-section .card-subtitle {
  margin-top: 8rpx;
  color: var(--theme-text-secondary);
  line-height: 1.72;
}

.share-card-page .share-preview-summary {
  margin-top: 16rpx;
  padding: 18rpx 20rpx 20rpx;
}

.share-card-page .history-scope-card {
  padding: 18rpx 20rpx 20rpx;
  background: var(--theme-soft-block-bg);
  box-shadow: none;
}

.share-card-page .share-brief-card {
  padding: 18rpx 20rpx 20rpx;
}

.share-card-page .share-brief-head {
  align-items: center;
  margin-bottom: 0;
  gap: 12rpx;
}

.share-card-page .share-brief-meta {
  margin-top: 10rpx;
}

.share-card-page .share-brief-source {
  font-size: 20rpx;
  line-height: 1.6;
  color: var(--theme-text-soft);
}

.share-card-page .share-brief-result-panel {
  margin-top: 8rpx;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.44);
  box-shadow:
    inset 0 0 0 1rpx var(--theme-divider),
    0 10rpx 22rpx rgba(27, 54, 93, 0.04);
}

.share-card-page .share-brief-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-width: 176rpx;
  height: 64rpx;
  padding: 0 14rpx;
  border-radius: 18rpx;
  background: var(--theme-button-primary-bg);
  box-shadow: var(--theme-button-shadow);
}

.share-card-page .share-brief-btn-text {
  flex: 0 0 auto;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--theme-button-primary-text);
  text-align: center;
}

.share-card-page .share-brief-text {
  font-size: 23rpx;
  line-height: 1.68;
  color: var(--theme-text-main);
}

.share-card-page .share-summary-config {
  margin-top: 10rpx;
}

.share-card-page .summary-mode-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.share-card-page .summary-mode-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-height: 54rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: var(--theme-chip-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.share-card-page .summary-mode-chip.is-active {
  background: var(--theme-summary-bg);
  box-shadow:
    inset 0 0 0 2rpx var(--theme-divider),
    var(--theme-project-card-shadow);
}

.share-card-page .summary-mode-chip.is-disabled {
  opacity: 0.45;
}

.share-card-page .summary-mode-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--theme-text-muted);
}

.share-card-page .summary-mode-chip.is-active .summary-mode-dot {
  background: var(--theme-accent-strong);
}

.share-card-page .summary-mode-label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--theme-text-main);
}

.share-card-page .share-summary-draft-block {
  margin-top: 12rpx;
  padding: 14rpx 16rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.44);
  box-shadow: inset 0 0 0 1rpx var(--theme-divider);
}

.share-card-page .share-final-summary-title {
  margin-top: 0;
}

.share-card-page .share-summary-textarea {
  margin-top: 8rpx;
  min-height: 126rpx;
  line-height: 1.62;
}

.share-card-page .share-preview-sheet {
  padding: 20rpx 20rpx calc(22rpx + env(safe-area-inset-bottom));
}

.share-card-page .share-preview-sheet-head {
  display: flex;
  align-items: center;
  flex: 1 1 auto;
  gap: 12rpx;
}

.share-card-page .share-preview-sheet-head-main {
  min-width: 0;
  flex: 1 1 auto;
}

.share-card-page .share-preview-sheet-caption {
  margin-top: 4rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: var(--theme-text-soft);
}

.share-card-page .share-preview-sheet-mode {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: var(--theme-chip-bg);
  box-shadow: inset 0 0 0 1rpx var(--theme-divider);
  font-size: 19rpx;
  font-weight: 600;
  color: var(--theme-text-secondary);
}

.share-card-page .share-preview-scroll {
  max-height: 72vh;
}

.share-card-page .share-preview-sheet-banner {
  margin-top: 0;
}

.share-card-page .share-preview-sheet-card {
  margin-top: 14rpx;
}

.share-card-page .preview-bottom-space {
  height: 10rpx;
}

.share-card-page .share-preview-sheet .sheet-header {
  margin-bottom: 12rpx;
}

.share-card-page .share-preview-sheet .sheet-close {
  padding: 6rpx 0 6rpx 12rpx;
}

.share-card-page .share-preview-sheet .sheet-title {
  font-size: 28rpx;
}

.share-card-page .share-preview-sheet .share-preview-card {
  padding: 20rpx 22rpx 22rpx;
}

.share-card-page .share-preview-overview {
  padding: 14rpx 16rpx 16rpx;
  border-radius: 20rpx;
  background: var(--theme-soft-block-bg);
}

.share-card-page .share-preview-sheet .preview-meta-pills {
  margin-top: 8rpx;
  gap: 6rpx;
}

.share-card-page .share-bottom-space {
  height: 114rpx;
}

.share-card-page .history-scope-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 0;
}

.share-card-page .history-scope-head,
.share-card-page .share-timeline-head {
  align-items: flex-start;
}

.share-card-page .history-scope-head {
  margin-bottom: 10rpx;
}

.share-card-page .history-scope-badge {
  background: rgba(255, 255, 255, 0.58);
  color: var(--theme-text-secondary);
  box-shadow: inset 0 0 0 1rpx var(--theme-divider);
}

.share-card-page .history-scope-selector {
  padding: 8rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.42);
  box-shadow: inset 0 0 0 1rpx var(--theme-divider);
}

.share-card-page .share-timeline-link {
  margin-top: 12rpx;
  display: inline-flex;
}

.share-card-page .history-scope-radio {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-height: 50rpx;
  padding: 0 12rpx;
  border-radius: 16rpx;
  background: transparent;
  box-shadow: inset 0 0 0 1rpx transparent;
}

.share-card-page .history-scope-radio.is-active {
  background: var(--theme-summary-bg);
  box-shadow:
    inset 0 0 0 1rpx var(--theme-divider),
    var(--theme-summary-shadow);
}

.share-card-page .history-scope-radio-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--theme-text-muted);
}

.share-card-page .history-scope-radio.is-active .history-scope-radio-dot {
  background: var(--theme-accent-strong);
}

.share-card-page .history-scope-radio-label {
  font-size: 21rpx;
  font-weight: 600;
  color: var(--theme-text-main);
  text-align: center;
}

.share-card-page .share-timeline-entry {
  padding: 22rpx 24rpx;
}

.share-card-page .share-history-note {
  padding: 22rpx 24rpx;
}

.share-card-page .share-brief-card.section {
  margin-top: 22rpx;
}

.share-card-page .history-scope-card.section,
.share-card-page .share-timeline-entry.section,
.share-card-page .share-history-note.section {
  margin-top: 18rpx;
}

.share-card-page .history-scope-card.section:last-of-type {
  margin-bottom: 2rpx;
}

.share-card-page .share-conversion-card {
  padding: 22rpx 24rpx 24rpx;
  background: var(--theme-state-card-bg);
  box-shadow: var(--theme-state-card-shadow);
}

.share-card-page .share-conversion-copy {
  min-width: 0;
}

.share-card-page .share-conversion-action {
  display: flex;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  margin-top: 18rpx;
  border-radius: 22rpx;
  box-shadow: var(--theme-button-shadow);
  text-align: center;
}

.share-card-page .share-conversion-card.section {
  margin-top: 18rpx;
}

.share-card-page .share-footer {
  grid-template-columns: 176rpx minmax(0, 1fr);
  gap: 12rpx;
  padding: 12rpx;
  border-radius: 28rpx;
  background: var(--theme-bottom-nav-bg);
  box-shadow: var(--theme-bottom-nav-shadow);
}

.share-card-page .share-preview-trigger,
.share-card-page .share-action {
  width: 100%;
  margin: 0;
}

.share-card-page .share-preview-trigger {
  border-radius: 24rpx;
  background: transparent;
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
  color: var(--theme-text-secondary);
  font-weight: 600;
}

.share-card-page .share-action {
  border: 0;
  line-height: 88rpx;
  border-radius: 22rpx;
  box-shadow: var(--theme-button-shadow);
}

.share-card-page .share-action::after {
  border: 0;
}

.share-footer.appearance-font-large .btn-primary,
.share-footer.appearance-font-large .btn-ghost,
.share-preview-sheet.appearance-font-large .sheet-title,
.share-preview-sheet.appearance-font-large .sheet-close {
  font-size: 30rpx;
}

.share-preview-sheet.appearance-font-large .share-preview-sheet-mode {
  font-size: 22rpx;
}

.share-preview-sheet.appearance-font-large .project-name,
.share-preview-sheet.appearance-font-large .card-title,
.share-preview-sheet.appearance-font-large .form-card-title {
  font-size: 28rpx;
}

.share-preview-sheet.appearance-font-large .project-meta,
.share-preview-sheet.appearance-font-large .card-subtitle,
.share-preview-sheet.appearance-font-large .form-card-desc,
.share-preview-sheet.appearance-font-large .section-link {
  font-size: 26rpx;
}

.share-footer.appearance-font-readable .btn-primary,
.share-footer.appearance-font-readable .btn-ghost,
.share-preview-sheet.appearance-font-readable .sheet-title,
.share-preview-sheet.appearance-font-readable .sheet-close {
  font-size: 38rpx;
}

.share-preview-sheet.appearance-font-readable .share-preview-sheet-mode {
  font-size: 28rpx;
}

.share-preview-sheet.appearance-font-readable .project-name,
.share-preview-sheet.appearance-font-readable .card-title,
.share-preview-sheet.appearance-font-readable .form-card-title {
  font-size: 34rpx;
}

.share-preview-sheet.appearance-font-readable .project-meta,
.share-preview-sheet.appearance-font-readable .card-subtitle,
.share-preview-sheet.appearance-font-readable .form-card-desc,
.share-preview-sheet.appearance-font-readable .section-link {
  font-size: 34rpx;
}
