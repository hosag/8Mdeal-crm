@keyframes shareBriefSpin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.share-card-page .hero {
  padding: 32rpx;
}

.share-card-page .brand-lockup-share {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 16rpx;
}

.share-card-page .brand-lockup-image-share {
  flex: 0 0 auto;
  width: 104rpx;
  height: 84rpx;
  display: block;
}

.share-card-page .brand-lockup-copy-share {
  min-width: 0;
}

.share-card-page .brand-lockup-title-share {
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.08;
  letter-spacing: 2rpx;
  color: var(--theme-preview-text);
  text-shadow: 0 4rpx 14rpx rgba(14, 25, 36, 0.14);
}

.share-card-page .brand-lockup-subtitle-share {
  margin-top: 8rpx;
  font-size: 21rpx;
  letter-spacing: 3rpx;
  color: var(--theme-preview-muted);
}

.share-card-page .hero-title {
  font-size: 42rpx;
}

.share-card-page .hero-subtitle {
  max-width: 92%;
}

.share-card-page .state-card {
  padding: 26rpx;
}

.share-card-page .state-card .inline-actions {
  margin-top: 18rpx;
}

.share-card-page .share-preview-card {
  padding: 26rpx;
  background: var(--theme-project-card-bg);
  box-shadow: var(--theme-project-card-shadow);
}

.share-card-page .share-config-shell {
  padding: 24rpx 26rpx;
}

.share-card-page .share-config-head {
  align-items: flex-start;
  gap: 16rpx;
}

.share-card-page .share-config-head-main {
  flex: 1 1 auto;
  min-width: 0;
}

.share-card-page .share-config-project-name {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.32;
  color: var(--theme-title);
}

.share-card-page .share-config-project-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--theme-text-soft);
}

.share-card-page .share-config-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.share-card-page .share-config-fields {
  margin-top: 14rpx;
  padding: 18rpx 20rpx 20rpx;
  border-radius: 24rpx;
  background: var(--theme-soft-block-bg);
}

.share-card-page .share-config-fields-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.share-card-page .share-config-fields-title {
  font-size: 22rpx;
  color: var(--theme-text-muted);
}

.share-card-page .share-config-fields-count {
  flex: 0 0 auto;
  font-size: 21rpx;
  color: var(--theme-text-soft);
}

.share-card-page .share-config-fields-wall {
  margin-top: 12rpx;
}

.share-card-page .shared-detail-value-strong {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--theme-title);
}

.share-card-page .share-preview-head {
  align-items: flex-start;
}

.share-card-page .share-preview-head-main {
  flex: 1 1 auto;
  min-width: 0;
}

.share-card-page .share-preview-mode {
  flex: 0 0 auto;
  margin-top: 2rpx;
}

.share-card-page .share-preview-pills {
  margin-top: 14rpx;
  gap: 10rpx;
}

.share-card-page .share-preview-section {
  margin-top: 16rpx;
  padding: 18rpx 20rpx 20rpx;
  border-radius: 22rpx;
  background: var(--theme-summary-bg);
  box-shadow: var(--theme-summary-shadow);
}

.share-card-page .share-preview-section .card-subtitle {
  margin-top: 8rpx;
  color: var(--theme-text-secondary);
  line-height: 1.72;
}

.share-card-page .share-preview-summary {
  margin-top: 18rpx;
  padding: 20rpx 22rpx 22rpx;
}

.share-card-page .visible-fields-card {
  padding: 24rpx 26rpx;
}

.share-card-page .history-scope-card {
  padding: 24rpx 26rpx;
}

.share-card-page .share-brief-card {
  padding: 24rpx 26rpx;
}

.share-card-page .share-brief-head {
  align-items: center;
  gap: 16rpx;
}

.share-card-page .share-brief-meta {
  margin-top: 18rpx;
}

.share-card-page .share-brief-source {
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--theme-text-soft);
}

.share-card-page .share-brief-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-width: 196rpx;
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 20rpx;
  background: var(--theme-button-primary-bg);
  box-shadow: var(--theme-button-shadow);
}

.share-card-page .share-brief-btn-spinner {
  flex: 0 0 auto;
  width: 28rpx;
  height: 28rpx;
  border-radius: 999rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.28);
  border-top-color: var(--theme-button-primary-text);
  box-sizing: border-box;
  animation: shareBriefSpin 760ms linear infinite;
}

.share-card-page .share-brief-btn-text {
  flex: 0 0 auto;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--theme-button-primary-text);
  text-align: center;
}

.share-card-page .share-brief-btn-spinner-ghost {
  opacity: 0;
}

.share-card-page .share-brief-result {
  margin-top: 14rpx;
  padding: 20rpx 22rpx 22rpx;
}

.share-card-page .share-brief-text {
  font-size: 24rpx;
  line-height: 1.72;
  color: var(--theme-text-main);
}

.share-card-page .share-summary-config {
  margin-top: 18rpx;
}

.share-card-page .summary-mode-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.share-card-page .summary-mode-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  min-height: 62rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: var(--theme-chip-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.share-card-page .summary-mode-chip.is-active {
  background: var(--theme-summary-bg);
  box-shadow:
    inset 0 0 0 2rpx var(--theme-divider),
    var(--theme-project-card-shadow);
}

.share-card-page .summary-mode-chip.is-disabled {
  opacity: 0.45;
}

.share-card-page .summary-mode-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--theme-text-muted);
}

.share-card-page .summary-mode-chip.is-active .summary-mode-dot {
  background: var(--theme-accent-strong);
}

.share-card-page .summary-mode-label {
  font-size: 23rpx;
  font-weight: 600;
  color: var(--theme-text-main);
}

.share-card-page .share-final-summary-title {
  margin-top: 16rpx;
}

.share-card-page .share-summary-textarea {
  margin-top: 12rpx;
  min-height: 170rpx;
  line-height: 1.68;
}

.share-card-page .share-preview-sheet {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.share-card-page .share-preview-scroll {
  max-height: 74vh;
}

.share-card-page .share-preview-sheet-banner {
  margin-top: 0;
}

.share-card-page .share-preview-sheet-card {
  margin-top: 18rpx;
}

.share-card-page .preview-bottom-space {
  height: 18rpx;
}

.share-card-page .history-scope-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.share-card-page .history-scope-radio {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  min-height: 58rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: var(--theme-chip-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.share-card-page .history-scope-radio.is-active {
  background: var(--theme-summary-bg);
  box-shadow:
    inset 0 0 0 2rpx var(--theme-divider),
    var(--theme-project-card-shadow);
}

.share-card-page .history-scope-radio-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--theme-text-muted);
}

.share-card-page .history-scope-radio.is-active .history-scope-radio-dot {
  background: var(--theme-accent-strong);
}

.share-card-page .history-scope-radio-label {
  font-size: 23rpx;
  font-weight: 600;
  color: var(--theme-text-main);
}

.share-card-page .share-timeline-entry {
  padding: 24rpx 26rpx;
}

.share-card-page .share-timeline-pills {
  margin-top: 14rpx;
  gap: 10rpx;
}

.share-card-page .share-timeline-entry .field-pill {
  background: var(--theme-field-pill-bg);
  color: var(--theme-field-pill-text);
}

.share-card-page .share-history-note {
  padding: 24rpx 26rpx;
}

.share-card-page .visible-fields-wall {
  gap: 10rpx;
}

.share-card-page .visible-fields-card .field-pill {
  background: var(--theme-field-pill-bg);
  color: var(--theme-field-pill-text);
}

.share-card-page .share-footer {
  grid-template-columns: 1fr 1fr;
  background: var(--theme-bottom-nav-bg);
  box-shadow: var(--theme-bottom-nav-shadow);
}

.share-card-page .share-preview-trigger,
.share-card-page .share-action {
  width: 100%;
  margin: 0;
}

.share-card-page .share-preview-trigger {
  border-radius: 24rpx;
}

.share-card-page .share-action {
  border: 0;
  line-height: 88rpx;
  border-radius: 24rpx;
  box-shadow: var(--theme-button-shadow);
}

.share-card-page .share-action::after {
  border: 0;
}

.share-footer.appearance-font-large .btn-primary,
.share-footer.appearance-font-large .btn-ghost,
.share-preview-sheet.appearance-font-large .sheet-title,
.share-preview-sheet.appearance-font-large .sheet-close {
  font-size: 30rpx;
}

.share-preview-sheet.appearance-font-large .project-name,
.share-preview-sheet.appearance-font-large .card-title,
.share-preview-sheet.appearance-font-large .form-card-title {
  font-size: 28rpx;
}

.share-preview-sheet.appearance-font-large .project-meta,
.share-preview-sheet.appearance-font-large .card-subtitle,
.share-preview-sheet.appearance-font-large .form-card-desc,
.share-preview-sheet.appearance-font-large .section-link {
  font-size: 26rpx;
}

.share-footer.appearance-font-readable .btn-primary,
.share-footer.appearance-font-readable .btn-ghost,
.share-preview-sheet.appearance-font-readable .sheet-title,
.share-preview-sheet.appearance-font-readable .sheet-close {
  font-size: 38rpx;
}

.share-preview-sheet.appearance-font-readable .project-name,
.share-preview-sheet.appearance-font-readable .card-title,
.share-preview-sheet.appearance-font-readable .form-card-title {
  font-size: 34rpx;
}

.share-preview-sheet.appearance-font-readable .project-meta,
.share-preview-sheet.appearance-font-readable .card-subtitle,
.share-preview-sheet.appearance-font-readable .form-card-desc,
.share-preview-sheet.appearance-font-readable .section-link {
  font-size: 34rpx;
}
