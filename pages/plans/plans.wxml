<view class="page-shell plans-page {{appearancePageClass}}">
  <view wx:if="{{isLoading}}" class="rise-in">
    <loading-panel rows="3" appearance-page-class="{{appearancePageClass}}" />
  </view>

  <block wx:else>
    <view class="hero rise-in plans-hero">
      <view class="eyebrow-row">
        <view class="eyebrow">套餐中心</view>
      </view>
      <view class="hero-title">选择适合当前阶段的开通方式</view>
      <view class="hero-subtitle">{{heroCaption}}</view>
      <view class="hero-actions plans-hero-actions">
        <view class="btn-secondary" bindtap="handlePrimaryAction">{{planActionMeta.actionText}}</view>
        <view class="btn-ghost" bindtap="openEntitlementsPage">查看权益详情</view>
      </view>
      <view class="plans-hero-grid">
        <view class="plans-hero-metric" wx:for="{{heroMetrics}}" wx:key="key">
          <view class="plans-hero-metric-label">{{item.label}}</view>
          <view class="plans-hero-metric-value">{{item.value}}</view>
          <view class="plans-hero-metric-note">{{item.note}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{entryGuide.visible}}" class="form-card section rise-in stagger-1 plans-entry-banner is-{{entryGuide.tone}}">
      <view class="plans-entry-banner-title">{{entryGuide.title}}</view>
      <view class="plans-entry-banner-desc">{{entryGuide.desc}}</view>
    </view>

    <view class="surface-card section rise-in stagger-1 plans-decision-card">
      <view class="line-between plans-decision-head">
        <view>
          <view class="section-title">当前建议</view>
        </view>
      </view>
      <view class="plans-decision-title">{{planActionMeta.title}}</view>
    </view>

    <view class="section rise-in stagger-2">
      <view class="surface-card plans-dashboard-card">
        <view class="section-title">账户概览</view>
        <view class="plans-overview-grid">
          <view class="plans-overview-item" wx:for="{{overviewRows}}" wx:key="key">
            <view class="plans-overview-label">{{item.label}}</view>
            <view class="plans-overview-value">{{item.value}}</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{effectiveSubscriptionSummary}}" class="surface-card section rise-in stagger-3 plans-effective-card">
      <view class="line-between plans-subscription-head">
        <view>
          <view class="section-title">当前已生效套餐</view>
          <view class="card-subtitle plans-subscription-desc">{{effectiveSubscriptionSummary.title}} · {{effectiveSubscriptionSummary.statusText}}</view>
        </view>
        <view class="status-badge is-success">有效至 {{effectiveSubscriptionSummary.expiresAtText}}</view>
      </view>
      <view class="plans-overview-grid">
        <view class="plans-overview-item">
          <view class="plans-overview-label">订阅摘要</view>
          <view class="plans-overview-value">{{effectiveSubscriptionSummary.summaryText}}</view>
        </view>
        <view class="plans-overview-item">
          <view class="plans-overview-label">项目位</view>
          <view class="plans-overview-value">{{effectiveSubscriptionSummary.projectText}}</view>
        </view>
        <view class="plans-overview-item">
          <view class="plans-overview-label">语音剩余</view>
          <view class="plans-overview-value">{{effectiveSubscriptionSummary.voiceText}}</view>
        </view>
        <view class="plans-overview-item">
          <view class="plans-overview-label">AI 剩余</view>
          <view class="plans-overview-value">{{effectiveSubscriptionSummary.aiText}}</view>
        </view>
      </view>
    </view>

    <view id="subscription-section" class="section rise-in stagger-5">
      <view class="section-header plans-section-header">
        <view>
          <view class="section-title">订阅套餐</view>
        </view>
      </view>
      <view class="plans-card-wall">
        <view class="surface-card plans-product-card {{item.isRecommended ? 'is-highlight is-recommended' : (item.badgeClass ? 'is-highlight' : '')}}" wx:for="{{subscriptionPlans}}" wx:key="key">
          <view class="line-between plans-product-head">
            <view>
              <view class="soft-badge plans-product-kicker">{{item.summaryTag}}</view>
              <view class="plans-product-title">{{item.title}}</view>
              <view class="plans-product-billing">{{item.billingText}}</view>
            </view>
            <view class="status-badge {{item.badgeClass}}">{{item.badgeText}}</view>
          </view>
          <view class="plans-price-row">
            <view class="plans-product-price {{item.priceClass}}">{{item.priceText}}</view>
            <view wx:if="{{item.originalPriceText}}" class="plans-product-original-price">{{item.originalPriceText}}</view>
          </view>
          <view class="card-subtitle plans-product-desc">{{item.desc}}</view>
          <view class="plans-feature-list">
            <view class="plans-feature-row" wx:for="{{item.featureLines}}" wx:key="*this">
              <view class="plans-feature-dot"></view>
              <view class="plans-feature-text">{{item}}</view>
            </view>
          </view>
          <view class="inline-actions plans-product-actions">
            <view class="{{item.actionButtonClass}}" data-group="subscriptions" data-key="{{item.key}}" bindtap="onProductAction">{{item.actionText}}</view>
          </view>
        </view>
      </view>
    </view>

    <view id="addon-section" class="section rise-in stagger-6">
      <view class="section-header plans-section-header">
        <view>
          <view class="section-title">语音与 AI 流量包</view>
        </view>
      </view>
      <view class="plans-card-wall">
        <view class="surface-card plans-product-card is-addon {{item.isRecommended ? 'is-highlight is-recommended' : ''}}" wx:for="{{addonPacks}}" wx:key="key">
          <view class="line-between plans-product-head">
            <view>
              <view class="soft-badge plans-product-kicker">{{item.summaryTag}}</view>
              <view class="plans-product-title">{{item.title}}</view>
              <view class="plans-product-billing">{{item.billingText}}</view>
            </view>
            <view class="status-badge {{item.badgeClass}}">{{item.badgeText}}</view>
          </view>
          <view class="plans-price-row">
            <view class="plans-product-price {{item.priceClass}}">{{item.priceText}}</view>
            <view wx:if="{{item.originalPriceText}}" class="plans-product-original-price">{{item.originalPriceText}}</view>
          </view>
          <view class="card-subtitle plans-product-desc">{{item.desc}}</view>
          <view class="plans-feature-list">
            <view class="plans-feature-row" wx:for="{{item.featureLines}}" wx:key="*this">
              <view class="plans-feature-dot"></view>
              <view class="plans-feature-text">{{item}}</view>
            </view>
          </view>
          <view class="inline-actions plans-product-actions">
            <view class="{{item.actionButtonClass}}" data-group="addons" data-key="{{item.key}}" bindtap="onProductAction">{{item.actionText}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="surface-card section rise-in stagger-7">
      <view class="section-header plans-section-header">
        <view>
          <view class="section-title">最近订单</view>
        </view>
      </view>
      <view wx:if="{{recentOrders.length}}" class="plans-order-list">
        <view class="plans-order-row" wx:for="{{recentOrders}}" wx:key="orderId" data-order-id="{{item.orderId}}" bindtap="openOrderDetail">
          <view class="plans-order-main">
            <view class="plans-order-title">{{item.title}}</view>
            <view class="card-subtitle">{{item.metaText}}</view>
          </view>
          <view class="plans-order-side">
            <view class="status-badge {{item.statusClass}}">{{item.statusLabel}}</view>
            <view class="plans-order-amount">{{item.amountText}}</view>
          </view>
        </view>
      </view>
      <view wx:else class="center-note plans-empty-copy">当前还没有订单记录。开通订阅或加购额度后，订单会显示在这里。</view>
    </view>
  </block>

  <block wx:if="{{confirmSheetVisible && confirmProduct}}">
    <view class="sheet-mask" bindtap="closeOrderConfirmSheet"></view>
    <view class="sheet-panel plans-confirm-sheet {{appearancePageClass}}" catchtap="noop">
      <view class="sheet-handle"></view>
      <view class="sheet-header">
        <view class="sheet-title">{{confirmProduct.sheetTitle}}</view>
        <view class="sheet-close" bindtap="closeOrderConfirmSheet">关闭</view>
      </view>

      <view class="plans-confirm-hero">
        <view class="soft-badge plans-confirm-kicker">{{confirmProduct.summaryTag}}</view>
        <view class="plans-confirm-title">{{confirmProduct.title}}</view>
        <view class="plans-confirm-billing">{{confirmProduct.billingText}}</view>
        <view class="plans-confirm-price-row">
          <view class="plans-confirm-price {{confirmProduct.priceClass}}">{{confirmProduct.priceText}}</view>
          <view wx:if="{{confirmProduct.originalPriceText}}" class="plans-confirm-original-price">{{confirmProduct.originalPriceText}}</view>
        </view>
        <view class="card-subtitle plans-confirm-desc">{{confirmProduct.desc}}</view>
      </view>

      <view class="plans-confirm-grid">
        <view class="plans-confirm-item" wx:for="{{confirmProduct.summaryRows}}" wx:key="key">
          <view class="plans-confirm-label">{{item.label}}</view>
          <view class="plans-confirm-value">{{item.value}}</view>
        </view>
      </view>

      <view wx:if="{{confirmProduct.capabilityLines.length}}" class="plans-confirm-capabilities">
        <view class="plans-confirm-section-title">包含能力</view>
        <view class="compact-inline-metrics plans-confirm-pills">
          <view class="compact-inline-item" wx:for="{{confirmProduct.capabilityLines}}" wx:key="*this">{{item}}</view>
        </view>
      </view>

      <view class="inline-actions plans-confirm-actions">
        <view class="btn-ghost plans-confirm-cancel" bindtap="closeOrderConfirmSheet">再想想</view>
        <view class="btn-primary plans-confirm-submit" bindtap="confirmPendingOrder">{{confirmProduct.confirmText}}</view>
      </view>
    </view>
  </block>
</view>
