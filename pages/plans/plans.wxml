<view class="page-shell plans-page {{appearancePageClass}}">
  <view wx:if="{{isLoading}}" class="rise-in">
    <loading-panel rows="3" appearance-page-class="{{appearancePageClass}}" />
  </view>

  <block wx:else>
    <view class="hero rise-in plans-hero">
      <view class="eyebrow-row">
        <view class="eyebrow">套餐与加购</view>
      </view>
      <view wx:if="{{heroCaption}}" class="plans-hero-status">{{heroCaption}}</view>
      <view class="hero-title">{{planActionMeta.title}}</view>
      <view class="hero-subtitle">{{planActionMeta.desc}}</view>
      <view class="hero-actions plans-hero-actions">
        <view class="btn-secondary" bindtap="handlePrimaryAction">{{planActionMeta.actionText}}</view>
        <view class="btn-ghost" bindtap="openEntitlementsPage">查看权益详情</view>
      </view>
    </view>

    <view wx:if="{{entryGuide.visible}}" class="form-card section rise-in stagger-1 plans-entry-banner is-{{entryGuide.tone}}">
      <view class="plans-entry-banner-title">{{entryGuide.title}}</view>
      <view wx:if="{{entryGuide.desc}}" class="plans-entry-banner-desc">{{entryGuide.desc}}</view>
    </view>

    <view wx:if="{{effectiveSubscriptionSummary}}" class="surface-card section rise-in stagger-2 plans-effective-strip">
      <view class="line-between plans-effective-strip-head">
        <view class="plans-effective-strip-title">{{effectiveSubscriptionSummary.title}}</view>
        <view class="status-badge is-success">有效期至 {{effectiveSubscriptionSummary.expiresAtText}}</view>
      </view>
      <view class="plans-effective-strip-summary">{{effectiveSubscriptionSummary.detailText}}</view>
    </view>

    <view wx:for="{{productSections}}" wx:for-item="section" wx:key="key" id="{{section.id}}" class="section rise-in {{section.staggerClass}}">
      <view class="section-header plans-section-header">
        <view>
          <view class="section-title">{{section.title}}</view>
          <view class="card-subtitle plans-section-desc">{{section.desc}}</view>
        </view>
      </view>
      <view class="plans-card-wall">
        <view class="surface-card plans-product-card {{section.group === 'addons' ? 'is-addon' : ''}} {{product.isRecommended ? 'is-highlight is-recommended' : (product.badgeText ? 'is-highlight' : '')}}" wx:for="{{section.products}}" wx:for-item="product" wx:key="key">
          <view class="line-between plans-product-head">
            <view>
              <view class="plans-product-title">{{product.title}}</view>
              <view class="plans-product-billing">{{product.billingText}}</view>
            </view>
            <view wx:if="{{product.badgeText}}" class="status-badge {{product.badgeClass}}">{{product.badgeText}}</view>
          </view>
          <block wx:if="{{product.cardLayout === 'addon'}}">
            <view class="plans-addon-primary">
              <view class="plans-addon-primary-label">{{product.primarySpec.label}}</view>
              <view class="plans-addon-primary-value">{{product.primarySpec.value}}</view>
              <view class="plans-addon-primary-meta">{{product.primarySpec.meta}}</view>
            </view>
          </block>
          <block wx:else>
            <view class="plans-price-row">
              <view class="plans-product-price {{product.priceClass}}">{{product.priceText}}</view>
              <view wx:if="{{product.originalPriceText}}" class="plans-product-original-price">{{product.originalPriceText}}</view>
            </view>
          </block>
          <view class="card-subtitle plans-product-summary">{{product.summaryText}}</view>
          <view wx:if="{{product.detailRows.length}}" class="plans-product-detail-list">
            <view class="plans-product-detail-row" wx:for="{{product.detailRows}}" wx:for-item="detail" wx:key="label">
              <view class="plans-product-detail-label">{{detail.label}}</view>
              <view class="plans-product-detail-value">{{detail.value}}</view>
            </view>
          </view>
          <view class="inline-actions plans-product-actions">
            <view class="{{product.actionButtonClass}}" data-group="{{section.group}}" data-key="{{product.key}}" bindtap="onProductAction">{{product.actionText}}</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{recentOrders.length}}" class="surface-card section rise-in stagger-5 plans-orders-card">
      <view class="section-header plans-section-header">
        <view>
          <view class="section-title">最近订单</view>
        </view>
      </view>
      <view class="plans-order-list">
        <view class="plans-order-row" wx:for="{{recentOrders}}" wx:key="orderId" data-order-id="{{item.orderId}}" bindtap="openOrderDetail">
          <view class="plans-order-main">
            <view class="plans-order-title">{{item.title}}</view>
            <view class="card-subtitle">{{item.metaText}}</view>
          </view>
          <view class="plans-order-side">
            <view class="status-badge {{item.statusClass}}">{{item.statusLabel}}</view>
            <view class="plans-order-amount">{{item.amountText}}</view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{confirmSheetVisible && confirmProduct}}">
    <view class="sheet-mask" bindtap="closeOrderConfirmSheet"></view>
    <view class="sheet-panel plans-confirm-sheet {{appearancePageClass}}" catchtap="noop">
      <view class="sheet-handle"></view>
      <view class="sheet-header">
        <view class="sheet-title">{{confirmProduct.sheetTitle}}</view>
        <view class="sheet-close" catchtap="closeOrderConfirmSheet">关闭</view>
      </view>

      <view class="plans-confirm-hero">
        <view class="soft-badge plans-confirm-kicker">{{confirmProduct.summaryTag}}</view>
        <view class="plans-confirm-title">{{confirmProduct.title}}</view>
        <view class="plans-confirm-billing">{{confirmProduct.billingText}}</view>
        <view class="plans-confirm-price-row">
          <view class="plans-confirm-price {{confirmProduct.priceClass}}">{{confirmProduct.priceText}}</view>
          <view wx:if="{{confirmProduct.originalPriceText}}" class="plans-confirm-original-price">{{confirmProduct.originalPriceText}}</view>
        </view>
        <view class="card-subtitle plans-confirm-desc">{{confirmProduct.desc}}</view>
      </view>

      <view class="plans-confirm-grid">
        <view class="plans-confirm-item" wx:for="{{confirmProduct.summaryRows}}" wx:key="key">
          <view class="plans-confirm-label">{{item.label}}</view>
          <view class="plans-confirm-value">{{item.value}}</view>
        </view>
      </view>

      <view wx:if="{{confirmProduct.capabilityLines.length}}" class="plans-confirm-capabilities">
        <view class="plans-confirm-section-title">包含功能</view>
        <view class="compact-inline-metrics plans-confirm-pills">
          <view class="compact-inline-item" wx:for="{{confirmProduct.capabilityLines}}" wx:key="*this">{{item}}</view>
        </view>
      </view>

      <view class="inline-actions plans-confirm-actions">
        <button class="btn-ghost plans-confirm-cancel plans-confirm-button" bindtap="closeOrderConfirmSheet">再想想</button>
        <button class="btn-primary plans-confirm-submit plans-confirm-button" bindtap="confirmPendingOrder">{{confirmProduct.confirmText}}</button>
      </view>
    </view>
  </block>
</view>
