.notifications-page .notifications-hero-metrics {
  margin-top: 24rpx;
}

.notifications-page .state-card {
  padding: 24rpx 26rpx;
}

.notifications-page .state-actions {
  margin-top: 18rpx;
}

.notifications-page .state-btn {
  min-width: 220rpx;
}

.notifications-page .notifications-toolbar {
  padding: 22rpx 24rpx;
}

.notifications-page .notifications-filter-row {
  gap: 12rpx;
}

.notifications-page .notifications-type-row {
  margin-top: 14rpx;
  gap: 12rpx;
}

.notifications-page .notifications-quick-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.notifications-page .notifications-quick-chip {
  box-sizing: border-box;
  width: calc((100% - 24rpx) / 3);
  padding: 16rpx 10rpx 14rpx;
  border-radius: 22rpx;
  background: var(--theme-soft-block-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.notifications-page .notifications-quick-chip.is-active {
  background: var(--theme-brand-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.notifications-page .notifications-quick-label {
  font-size: 22rpx;
  line-height: 1.2;
  color: var(--theme-text-soft);
}

.notifications-page .notifications-quick-chip.is-active .notifications-quick-label {
  color: var(--theme-brand-text);
  font-weight: 700;
}

.notifications-page .notifications-quick-count {
  font-size: 28rpx;
  line-height: 1;
  font-weight: 700;
  color: var(--theme-title);
}

.notifications-page .notifications-result-text {
  margin-top: 16rpx;
}

.notifications-page .notifications-toolbar-actions {
  margin-top: 18rpx;
  justify-content: flex-end;
}

.notifications-page .notification-card {
  position: relative;
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background: var(--theme-project-card-bg);
  box-shadow: var(--theme-project-card-shadow);
}

.notifications-page .notification-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 28rpx;
  bottom: 28rpx;
  width: 8rpx;
  border-radius: 999rpx;
  background: var(--theme-soft-badge-text);
}

.notifications-page .notification-card.is-overdue {
  background: var(--theme-project-card-bg);
  box-shadow: var(--theme-project-card-shadow);
}

.notifications-page .notification-card.is-overdue::before {
  background: var(--theme-danger-text);
}

.notifications-page .notification-card.is-today {
  background: var(--theme-project-card-bg);
}

.notifications-page .notification-card.is-today::before {
  background: var(--theme-brand-text);
}

.notifications-page .notification-card.is-tomorrow {
  background: var(--theme-project-card-bg);
}

.notifications-page .notification-card.is-tomorrow::before {
  background: var(--theme-soft-badge-text);
}

.notifications-page .notification-card.is-update {
  background: var(--theme-project-card-bg);
}

.notifications-page .notification-card.is-update::before {
  background: var(--theme-brand-text);
}

.notifications-page .notification-card.is-system::before {
  background: var(--theme-inline-text);
}

.notifications-page .notification-card.is-resolved {
  background: var(--theme-state-card-bg);
  box-shadow: var(--theme-state-card-shadow);
}

.notifications-page .notification-card.is-resolved::before {
  background: var(--theme-success-text);
}

.notifications-page .notification-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.notifications-page .notification-side {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.notifications-page .notification-main {
  flex: 1 1 auto;
  min-width: 0;
}

.notifications-page .notification-title-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.notifications-page .notification-tone-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1;
  letter-spacing: 0.04em;
  background: var(--theme-soft-badge-bg);
  color: var(--theme-soft-badge-text);
}

.notifications-page .notification-tone-pill.is-overdue {
  background: var(--theme-danger-bg);
  color: var(--theme-danger-text);
}

.notifications-page .notification-tone-pill.is-today,
.notifications-page .notification-tone-pill.is-update {
  background: var(--theme-brand-bg);
  color: var(--theme-brand-text);
}

.notifications-page .notification-tone-pill.is-tomorrow {
  background: var(--theme-soft-badge-bg);
  color: var(--theme-soft-badge-text);
}

.notifications-page .notification-tone-pill.is-system {
  background: var(--theme-inline-bg);
  color: var(--theme-inline-text);
}

.notifications-page .notification-tone-pill.is-resolved {
  background: var(--theme-success-bg);
  color: var(--theme-success-text);
}

.notifications-page .notification-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--theme-title);
}

.notifications-page .notification-project {
  margin-top: 10rpx;
  color: var(--theme-text-soft);
  font-size: 23rpx;
}

.notifications-page .notification-card-action-text {
  font-size: 21rpx;
  line-height: 1.2;
  color: var(--theme-text-soft);
}

.notifications-page .notification-summary {
  margin-top: 16rpx;
  color: var(--theme-text-main);
  font-size: 25rpx;
  line-height: 1.7;
}

.notifications-page .notification-pill-row {
  margin-top: 14rpx;
  gap: 10rpx;
}

.notifications-page .notification-category-badge {
  background: var(--theme-soft-badge-bg);
  color: var(--theme-soft-badge-text);
}

.notifications-page .notification-source-pill {
  background: var(--theme-field-pill-bg);
  color: var(--theme-field-pill-text);
}

.notifications-page .notification-hint {
  margin-top: 12rpx;
  line-height: 1.6;
}

.notifications-page .notification-actions {
  margin-top: 18rpx;
  gap: 10rpx;
}

.notifications-page .compact-action-btn {
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.notifications-page .compact-action-btn.is-single {
  min-width: 240rpx;
}
