.notifications-page .notifications-hero-metrics {
  margin-top: 24rpx;
}

.notifications-page .state-card {
  padding: 24rpx 26rpx;
}

.notifications-page .state-actions {
  margin-top: 18rpx;
}

.notifications-page .state-btn {
  min-width: 220rpx;
}

.notifications-page .notifications-toolbar {
  padding: 22rpx 24rpx;
}

.notifications-page .notifications-filter-row {
  gap: 12rpx;
}

.notifications-page .notifications-type-row {
  margin-top: 14rpx;
  gap: 12rpx;
}

.notifications-page .notifications-quick-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.notifications-page .notifications-quick-chip {
  box-sizing: border-box;
  width: calc((100% - 24rpx) / 3);
  padding: 16rpx 10rpx 14rpx;
  border-radius: 22rpx;
  background: rgba(244, 239, 231, 0.82);
  box-shadow: inset 0 0 0 2rpx rgba(24, 39, 51, 0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.notifications-page .notifications-quick-chip.is-active {
  background: rgba(53, 93, 118, 0.14);
  box-shadow: inset 0 0 0 2rpx rgba(53, 93, 118, 0.16);
}

.notifications-page .notifications-quick-label {
  font-size: 22rpx;
  line-height: 1.2;
  color: #5c6974;
}

.notifications-page .notifications-quick-chip.is-active .notifications-quick-label {
  color: #2f556c;
  font-weight: 700;
}

.notifications-page .notifications-quick-count {
  font-size: 28rpx;
  line-height: 1;
  font-weight: 700;
  color: #182730;
}

.notifications-page .notifications-result-text {
  margin-top: 16rpx;
}

.notifications-page .notifications-toolbar-actions {
  margin-top: 18rpx;
  justify-content: flex-end;
}

.notifications-page .notification-card {
  position: relative;
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background: linear-gradient(180deg, rgba(255, 254, 251, 0.98) 0%, rgba(248, 244, 237, 0.96) 100%);
  box-shadow: 0 18rpx 38rpx rgba(25, 40, 52, 0.08);
}

.notifications-page .notification-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 28rpx;
  bottom: 28rpx;
  width: 8rpx;
  border-radius: 999rpx;
  background: rgba(177, 139, 86, 0.16);
}

.notifications-page .notification-card.is-overdue {
  background: linear-gradient(180deg, rgba(255, 251, 249, 0.98) 0%, rgba(250, 240, 236, 0.98) 100%);
  box-shadow: 0 18rpx 40rpx rgba(120, 54, 42, 0.10);
}

.notifications-page .notification-card.is-overdue::before {
  background: rgba(154, 64, 64, 0.44);
}

.notifications-page .notification-card.is-today {
  background: linear-gradient(180deg, rgba(251, 253, 255, 0.98) 0%, rgba(240, 247, 250, 0.98) 100%);
}

.notifications-page .notification-card.is-today::before {
  background: rgba(36, 75, 97, 0.36);
}

.notifications-page .notification-card.is-tomorrow {
  background: linear-gradient(180deg, rgba(255, 254, 250, 0.98) 0%, rgba(247, 242, 232, 0.98) 100%);
}

.notifications-page .notification-card.is-tomorrow::before {
  background: rgba(141, 102, 49, 0.30);
}

.notifications-page .notification-card.is-update {
  background: linear-gradient(180deg, rgba(252, 254, 255, 0.98) 0%, rgba(243, 248, 250, 0.98) 100%);
}

.notifications-page .notification-card.is-update::before {
  background: rgba(53, 93, 118, 0.24);
}

.notifications-page .notification-card.is-system::before {
  background: rgba(122, 92, 56, 0.28);
}

.notifications-page .notification-card.is-resolved {
  background: linear-gradient(180deg, rgba(252, 252, 249, 0.94) 0%, rgba(245, 244, 239, 0.94) 100%);
  box-shadow: 0 12rpx 26rpx rgba(25, 40, 52, 0.05);
}

.notifications-page .notification-card.is-resolved::before {
  background: rgba(89, 116, 100, 0.22);
}

.notifications-page .notification-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.notifications-page .notification-side {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.notifications-page .notification-main {
  flex: 1 1 auto;
  min-width: 0;
}

.notifications-page .notification-title-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.notifications-page .notification-tone-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1;
  letter-spacing: 0.04em;
  background: rgba(177, 139, 86, 0.12);
  color: #8d6631;
}

.notifications-page .notification-tone-pill.is-overdue {
  background: rgba(154, 64, 64, 0.12);
  color: #9a4040;
}

.notifications-page .notification-tone-pill.is-today,
.notifications-page .notification-tone-pill.is-update {
  background: rgba(36, 75, 97, 0.12);
  color: #244b61;
}

.notifications-page .notification-tone-pill.is-tomorrow {
  background: rgba(141, 102, 49, 0.12);
  color: #8d6631;
}

.notifications-page .notification-tone-pill.is-system {
  background: rgba(122, 92, 56, 0.12);
  color: #7a5c38;
}

.notifications-page .notification-tone-pill.is-resolved {
  background: rgba(74, 132, 98, 0.12);
  color: #2b6a49;
}

.notifications-page .notification-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #16242f;
}

.notifications-page .notification-project {
  margin-top: 10rpx;
  color: #6d7882;
  font-size: 23rpx;
}

.notifications-page .notification-card-action-text {
  font-size: 21rpx;
  line-height: 1.2;
  color: #6a7b87;
}

.notifications-page .notification-summary {
  margin-top: 16rpx;
  color: #253543;
  font-size: 25rpx;
  line-height: 1.7;
}

.notifications-page .notification-pill-row {
  margin-top: 14rpx;
  gap: 10rpx;
}

.notifications-page .notification-category-badge {
  background: rgba(177, 139, 86, 0.14);
  color: #8d6631;
}

.notifications-page .notification-source-pill {
  background: #eff4f6;
  color: #36515f;
}

.notifications-page .notification-hint {
  margin-top: 12rpx;
  line-height: 1.6;
}

.notifications-page .notification-actions {
  margin-top: 18rpx;
  gap: 10rpx;
}

.notifications-page .compact-action-btn {
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.notifications-page .compact-action-btn.is-single {
  min-width: 240rpx;
}
