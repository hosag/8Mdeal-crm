<view class="page-shell mark-deal-page {{appearancePageClass}}">
  <view wx:if="{{isLoading}}" class="rise-in">
    <loading-panel rows="2" appearance-page-class="{{appearancePageClass}}" />
  </view>

  <block wx:else>
  <view class="hero">
    <view class="eyebrow-row">
      <view class="eyebrow">成交记录</view>
    </view>
    <view class="hero-title">记录成交金额、提成与回款</view>
    <view class="hero-subtitle">保存后将计入收益统计。</view>
    <view class="pill-row">
      <view class="soft-badge">{{form.projectName}}</view>
    </view>
  </view>

  <view class="form-card section">
    <view class="field-group">
      <view class="field-label">实际成交金额</view>
      <input class="input-sim input-native" type="digit" value="{{form.actualAmount}}" data-field="actualAmount" bindinput="onFieldInput" placeholder="可选，例如 980000" placeholder-class="input-placeholder" />
    </view>
    <view class="field-group">
      <view class="field-label">合同签订日期</view>
      <picker class="picker-block" mode="date" value="{{form.contractDate}}" bindchange="onContractDateChange">
        <view class="picker-sim">
          <view class="picker-value">{{form.contractDate}}</view>
        </view>
      </picker>
    </view>
    <view class="field-group">
      <view class="field-label">预期提成</view>
      <input class="input-sim input-native" type="digit" value="{{form.expectedCommission}}" data-field="expectedCommission" bindinput="onFieldInput" placeholder="可选，例如 84000" placeholder-class="input-placeholder" />
    </view>
    <view class="field-group">
      <view class="field-label">补充说明</view>
      <textarea class="textarea-sim textarea-native" value="{{form.note}}" data-field="note" bindinput="onFieldInput" placeholder="补充签约背景、回款说明或需要复盘的关键节点" placeholder-class="input-placeholder" maxlength="-1"></textarea>
    </view>
  </view>

  <view class="form-card section">
    <view class="form-card-title">保存后同步</view>
    <view class="form-card-desc">保存后将计入收益统计，并显示在首页时间线中。</view>
  </view>

  <view class="bottom-space"></view>
  </block>
</view>

<view wx:if="{{!isLoading}}" class="footer-bar {{appearancePageClass}}">
  <view class="btn-ghost" bindtap="goBack">返回详情</view>
  <view class="btn-primary" bindtap="handleSave">{{isSaving ? '提交中...' : '提交成交'}}</view>
</view>
