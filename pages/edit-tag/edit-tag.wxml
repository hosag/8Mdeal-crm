<view class="page-shell">
  <view wx:if="{{isLoading}}" class="rise-in">
    <loading-panel rows="2" />
  </view>

  <block wx:else>
  <view class="hero rise-in">
    <view class="eyebrow-row">
      <view class="eyebrow">标签设置</view>
      <view class="source-badge">{{dataSource}}</view>
    </view>
    <view class="hero-title">{{tagName || '新建标签'}}</view>
    <view class="hero-subtitle">通过字段选择器直接定义“接收者能看到什么”，适合微信场景里的快速设置。</view>
  </view>

  <view class="form-card section">
    <view class="field-group">
      <view class="field-label">标签名称</view>
      <input class="input-sim input-native" value="{{tagName}}" bindinput="onTagNameInput" placeholder="例如：重点伙伴" placeholder-class="input-placeholder" />
    </view>
    <view class="field-group">
      <view class="field-label">标签说明</view>
      <textarea class="textarea-sim textarea-native" value="{{tagDesc}}" bindinput="onTagDescInput" placeholder="说明这个标签下接收者能看到哪些信息" placeholder-class="input-placeholder" maxlength="-1"></textarea>
    </view>
  </view>

  <view class="form-card section">
    <view class="form-card-title">可见字段</view>
    <view class="form-card-desc">已选字段会出现在分享卡片页中，未选字段由云函数过滤。</view>
    <view class="pill-row">
      <view
        wx:for="{{visibleFieldOptions}}"
        wx:key="name"
        class="field-pill {{item.active ? 'is-active' : ''}}"
        data-field="{{item.name}}"
        bindtap="toggleField"
      >
        {{item.name}}
      </view>
    </view>
  </view>

  <view class="bottom-space"></view>
  </block>
</view>

<view wx:if="{{!isLoading}}" class="footer-bar">
  <view class="btn-ghost" bindtap="goBack">取消</view>
  <view class="btn-primary" bindtap="handleSave">{{isSaving ? '保存中...' : '保存标签'}}</view>
</view>
