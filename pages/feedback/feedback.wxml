<view class="page-shell feedback-page {{appearancePageClass}}">
  <view class="hero rise-in">
    <view class="eyebrow-row">
      <view class="eyebrow">反馈与建议</view>
    </view>
    <view class="hero-title">说说哪里不顺手</view>
    <view class="hero-subtitle">反馈被采纳后将获得奖励。</view>
  </view>

  <block wx:if="{{!isSubmitted}}">
    <view class="form-card section rise-in stagger-1 feedback-tip-card">
      <view class="card-title">我们会认真阅读每条反馈</view>
    </view>

    <view class="form-card section rise-in stagger-2">
      <view class="field-group">
        <view class="field-label">反馈类型</view>
        <view class="pill-row feedback-pill-row">
          <view
            wx:for="{{feedbackTypes}}"
            wx:key="key"
            class="chip feedback-chip {{selectedType === item.key ? 'is-active' : ''}}"
            data-key="{{item.key}}"
            bindtap="selectType"
          >{{item.label}}</view>
        </view>
      </view>

      <view class="field-group">
        <view class="field-label">发生场景</view>
        <view class="pill-row feedback-pill-row">
          <view
            wx:for="{{sceneOptions}}"
            wx:key="key"
            class="chip feedback-chip {{selectedScene === item.key ? 'is-active' : ''}}"
            data-key="{{item.key}}"
            bindtap="selectScene"
          >{{item.label}}</view>
        </view>
      </view>

      <view class="field-group">
        <view class="field-label">反馈内容</view>
        <textarea
          class="textarea-sim textarea-native feedback-textarea"
          value="{{content}}"
          bindinput="onContentInput"
          placeholder="描述问题现象与你的期望"
          placeholder-class="input-placeholder"
          maxlength="1000"
        ></textarea>
      </view>

      <view class="field-group">
        <view class="field-label">联系方式</view>
        <input
          class="input-sim input-native"
          value="{{contact}}"
          bindinput="onContactInput"
          placeholder="可留手机号或微信，方便确认细节"
          placeholder-class="input-placeholder"
        />
        <view wx:if="{{accountSummary.phoneMasked}}" class="helper-text feedback-contact-hint">当前账号 {{accountSummary.phoneMasked}}</view>
      </view>

      <view class="feedback-contact-row">
        <view class="feedback-contact-copy">
          <view class="field-label">允许平台联系我确认细节</view>
          <view class="helper-text">关闭后仍可提交反馈。</view>
        </view>
        <switch color="#355d76" checked="{{allowContact}}" bindchange="onAllowContactChange" />
      </view>
    </view>

    <view class="bottom-space"></view>
  </block>

  <view wx:else class="form-card section feedback-success-card rise-in stagger-1">
    <view class="feedback-success-mark">已收到</view>
    <view class="form-card-title">反馈已提交</view>
    <view class="form-card-desc">反馈被采纳后将获得奖励。</view>
    <view class="hero-actions feedback-success-actions">
      <view class="btn-primary feedback-action" bindtap="resetForm">继续提交</view>
      <view class="btn-ghost feedback-action" bindtap="goBackMine">返回我的</view>
    </view>
  </view>
</view>

<view wx:if="{{!isSubmitted}}" class="footer-bar {{appearancePageClass}}">
  <view class="btn-ghost" bindtap="goBackMine">取消</view>
  <view class="btn-primary" bindtap="submitFeedback">{{isSubmitting ? '提交中...' : '提交反馈'}}</view>
</view>
