.entitlements-page {
  padding-bottom: 120rpx;
}

.entitlements-hero {
  padding: 26rpx 26rpx 28rpx;
  border-radius: 34rpx;
}

.entitlements-hero-actions {
  margin-top: 0;
}

.entitlements-hero-primary-btn {
  min-width: 220rpx;
  height: 72rpx;
  padding: 0 30rpx;
  border-radius: 22rpx;
  background: var(--theme-hero-primary-bg);
  color: var(--theme-hero-primary-text);
  border: 1rpx solid var(--theme-hero-primary-border);
  box-shadow: var(--theme-hero-primary-shadow);
  font-size: 24rpx;
}

.entitlements-hero-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 24rpx;
}

.entitlements-hero-metric {
  padding: 18rpx 18rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(14rpx);
}

.entitlements-hero-metric-label {
  font-size: 18rpx;
  color: rgba(246, 240, 229, 0.72);
}

.entitlements-hero-metric-value {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--theme-hero-text);
}

.entitlements-entry-banner {
  position: relative;
  overflow: hidden;
  padding: 20rpx 22rpx 22rpx;
  border-radius: 26rpx;
  background: var(--theme-state-card-bg);
  box-shadow: var(--theme-state-card-shadow);
}

.entitlements-entry-banner::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  border-radius: 26rpx 0 0 26rpx;
  background: linear-gradient(180deg, rgba(160, 174, 189, 0.96) 0%, rgba(101, 118, 136, 0.96) 100%);
}

.entitlements-entry-banner.is-danger::before {
  background: linear-gradient(180deg, rgba(244, 162, 150, 0.98) 0%, rgba(214, 103, 90, 0.98) 100%);
}

.entitlements-entry-banner.is-soft::before {
  background: linear-gradient(180deg, rgba(244, 214, 145, 0.98) 0%, rgba(206, 163, 79, 0.98) 100%);
}

.entitlements-entry-banner.is-brand::before {
  background: linear-gradient(180deg, rgba(174, 209, 229, 0.98) 0%, rgba(92, 153, 190, 0.98) 100%);
}

.entitlements-entry-banner.is-neutral::before {
  background: linear-gradient(180deg, rgba(164, 179, 135, 0.98) 0%, rgba(111, 132, 95, 0.98) 100%);
}

.entitlements-entry-banner-title {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--theme-title);
}

.entitlements-effective-head,
.entitlements-capability-head {
  align-items: flex-start;
  gap: 16rpx;
}

.entitlements-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 16rpx;
}

.entitlements-item {
  padding: 16rpx 16rpx 14rpx;
  border-radius: 22rpx;
  background: var(--theme-soft-block-bg);
  box-shadow: inset 0 0 0 1rpx rgba(24, 39, 51, 0.05);
}

.entitlements-item-label {
  font-size: 18rpx;
  color: var(--theme-text-muted);
}

.entitlements-item-value {
  margin-top: 8rpx;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.45;
  color: var(--theme-title);
}

.entitlements-effective-card {
  padding: 22rpx;
  background: linear-gradient(180deg, rgba(228, 242, 233, 0.98), rgba(245, 251, 247, 0.98));
  box-shadow: 0 18rpx 36rpx rgba(73, 122, 93, 0.1);
}

.entitlements-recent-card {
  padding: 22rpx;
}

.entitlements-recent-list {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
}

.entitlements-recent-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: var(--theme-soft-block-bg);
  box-shadow: inset 0 0 0 1rpx rgba(24, 39, 51, 0.05);
}

.entitlements-recent-main {
  flex: 1 1 auto;
  min-width: 0;
}

.entitlements-recent-title {
  font-size: 22rpx;
  line-height: 1.45;
  font-weight: 600;
  color: var(--theme-title);
}

.entitlements-recent-meta {
  margin-top: 6rpx;
  font-size: 18rpx;
  line-height: 1.5;
  color: var(--theme-text-muted);
}

.entitlements-recent-delta {
  flex: 0 0 auto;
  font-size: 22rpx;
  line-height: 1.35;
  font-weight: 700;
}

.entitlements-recent-delta.is-consume {
  color: #b85b43;
}

.entitlements-recent-delta.is-grant {
  color: #2d7f5e;
}

.entitlements-section-header {
  margin-bottom: 18rpx;
}

.entitlements-capability-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 14rpx;
}

.entitlements-capability-card {
  padding: 22rpx;
}

.entitlements-capability-title {
  flex: 1 1 auto;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.38;
  font-weight: 700;
  color: var(--theme-title);
}

.entitlements-capability-desc {
  margin-top: 12rpx;
}

.entitlements-capability-pills {
  margin-top: 14rpx;
}

.page-shell.entitlements-page.appearance-font-readable .entitlements-hero-grid,
.page-shell.entitlements-page.appearance-font-readable .entitlements-grid {
  grid-template-columns: repeat(1, minmax(0, 1fr));
}
