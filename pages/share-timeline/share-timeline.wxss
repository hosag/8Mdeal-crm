.share-timeline-page .timeline-overview-card {
  padding: 24rpx 26rpx;
}

.share-timeline-page .timeline-body .helper-text + .helper-text {
  margin-top: 4rpx;
}

.share-timeline-page .timeline-meta-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.share-timeline-page .timeline-type-badge {
  flex: 0 0 auto;
}

.share-timeline-page .timeline-title {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #182730;
}

.share-timeline-page .timeline-meta-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx 16rpx;
  margin-top: 8rpx;
}

.share-timeline-page .timeline-card {
  margin-top: 12rpx;
  padding: 18rpx 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(248, 245, 239, 0.9);
  box-shadow: inset 0 0 0 2rpx rgba(24, 39, 51, 0.04);
}

.share-timeline-page .timeline-pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.share-timeline-page .timeline-section + .timeline-section {
  margin-top: 14rpx;
}
