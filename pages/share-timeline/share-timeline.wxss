.share-timeline-page .timeline-overview-card {
  padding: 24rpx 26rpx;
}

.share-timeline-page .timeline-body .helper-text + .helper-text {
  margin-top: 4rpx;
}

.share-timeline-page .timeline-meta-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.share-timeline-page .timeline-type-badge {
  flex: 0 0 auto;
}

.share-timeline-page .timeline-title {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--theme-title);
}

.share-timeline-page .timeline-meta-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx 16rpx;
  margin-top: 8rpx;
}

.share-timeline-page .timeline-card {
  margin-top: 12rpx;
  padding: 18rpx 18rpx 20rpx;
  border-radius: 22rpx;
  background: var(--theme-summary-bg);
  box-shadow: var(--theme-summary-shadow);
}

.share-timeline-page .timeline-pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.share-timeline-page .timeline-section + .timeline-section {
  margin-top: 14rpx;
}

.page-shell.share-timeline-page.appearance-font-large .timeline-section-label {
  font-size: 28rpx;
}

.page-shell.share-timeline-page.appearance-font-large .timeline-list-item,
.page-shell.share-timeline-page.appearance-font-large .timeline-type-badge {
  font-size: 27rpx;
}

.page-shell.share-timeline-page.appearance-font-readable .timeline-section-label {
  font-size: 36rpx;
}

.page-shell.share-timeline-page.appearance-font-readable .timeline-list-item,
.page-shell.share-timeline-page.appearance-font-readable .timeline-type-badge {
  font-size: 34rpx;
}
