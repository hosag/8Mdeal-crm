.task-complete-mask {
  z-index: 80;
  background: var(--theme-sheet-mask);
  backdrop-filter: blur(10rpx);
}

.task-complete-sheet {
  z-index: 81;
  top: 46vh;
  bottom: 0;
  height: auto;
  max-height: none;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding-bottom: calc(34rpx + env(safe-area-inset-bottom));
  background: var(--theme-sheet-bg);
  box-shadow: var(--theme-sheet-shadow);
}

.task-complete-sheet.is-editing {
  top: 18vh;
}

.task-complete-body {
  flex: 1 1 auto;
  min-height: 0;
  overflow-y: auto;
  padding-right: 4rpx;
  padding-bottom: 190rpx;
}

.task-complete-field {
  margin-top: 6rpx;
}

.task-complete-field.is-inline-first {
  margin-top: 16rpx;
}

.task-complete-textarea {
  min-height: 48rpx;
  line-height: 1.65;
}

.task-complete-sheet .primary-title-input {
  min-height: 76rpx;
  height: 76rpx;
  padding: 16rpx 22rpx;
  border-radius: 20rpx;
  background: var(--theme-card-bg);
  box-shadow:
    inset 0 0 0 2rpx rgba(23, 98, 96, 0.18),
    0 6rpx 14rpx rgba(24, 39, 51, 0.04);
  font-size: 26rpx;
  font-weight: 700;
  color: var(--theme-title);
  line-height: 44rpx;
}

.task-complete-voice-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.task-complete-voice-btn {
  min-width: 168rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: var(--theme-button-secondary-bg);
  color: var(--theme-button-secondary-text);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.task-complete-voice-btn.is-recording {
  background: var(--theme-danger-bg);
  color: var(--theme-danger-text);
  box-shadow: inset 0 0 0 2rpx var(--theme-danger-bg);
}

.task-complete-voice-btn.is-busy {
  color: var(--theme-text-soft);
  background: var(--theme-inline-bg);
}

.task-complete-inline-entry {
  margin-top: 12rpx;
}

.task-complete-inline-btn {
  margin-top: 0;
  min-width: 220rpx;
}

.task-complete-next-card {
  margin-top: 18rpx;
  padding: 20rpx 20rpx 22rpx;
  border-radius: 24rpx;
  background: var(--theme-soft-block-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.task-complete-next-head {
  align-items: center;
  gap: 18rpx;
}

.task-complete-toggle-title {
  font-size: 27rpx;
  font-weight: 700;
  color: var(--theme-title);
}

.task-complete-type-wall {
  gap: 10rpx;
  margin-top: 10rpx;
}

.task-complete-time-row {
  gap: 12rpx;
}

.task-complete-time-row .picker-block {
  flex: 1 1 0;
}

.task-complete-next-textarea {
  min-height: 150rpx;
  line-height: 1.65;
}

.task-complete-actions.is-fixed {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 2;
  margin-top: 0;
  padding-top: 16rpx;
  padding-bottom: 0;
  border-top: 2rpx solid var(--theme-divider);
  background: var(--theme-sheet-bg);
  box-shadow: 0 -16rpx 24rpx rgba(19, 31, 40, 0.05);
}

.task-complete-actions.is-fixed.is-editing {
  margin-top: 0;
}

.task-complete-sheet.appearance-font-large .sheet-title,
.task-complete-sheet.appearance-font-large .task-complete-toggle-title {
  font-size: 30rpx;
}

