.projects-page .search-panel {
  position: relative;
}

.projects-page .projects-search-input {
  padding-right: 110rpx;
  background: rgba(255, 255, 255, 0.88);
}

.projects-page .search-clear {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 22rpx;
  color: #6d7a87;
}

.projects-page .compact-toolbar {
  gap: 12rpx;
}

.projects-page .summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.projects-page .summary-card {
  padding: 22rpx;
  border-radius: 26rpx;
  background: rgba(255, 252, 247, 0.9);
  box-shadow: 0 16rpx 32rpx rgba(24, 39, 51, 0.08);
}

.projects-page .summary-card-label {
  font-size: 22rpx;
  color: #6b7985;
}

.projects-page .summary-card-value {
  margin-top: 8rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #172530;
}

.projects-page .summary-card-note {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7b8793;
}

.projects-page .result-bar,
.projects-page .state-card {
  padding: 24rpx 26rpx;
}

.projects-page .state-actions {
  margin-top: 18rpx;
}

.projects-page .state-btn {
  min-width: 220rpx;
}

.projects-page .practical-project-card {
  padding: 26rpx;
}

.projects-page .practical-project-card.has-task-focus {
  border: 1rpx solid rgba(181, 145, 94, 0.26);
  box-shadow: 0 20rpx 40rpx rgba(25, 40, 52, 0.08);
}

.projects-page .project-main {
  flex: 1 1 auto;
  min-width: 0;
}

.projects-page .project-owner-badge {
  flex: 0 0 auto;
  max-width: 240rpx;
  padding: 10rpx 16rpx;
  font-size: 21rpx;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.projects-page .project-pill-row {
  gap: 10rpx;
}

.projects-page .project-search-locator {
  margin-top: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(245, 240, 230, 0.72);
  box-shadow: inset 0 0 0 2rpx rgba(177, 139, 86, 0.08);
}

.projects-page .project-search-label {
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.5;
  color: #805f32;
}

.projects-page .project-search-snippet {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #445562;
}

.projects-page .project-search-segment {
  color: inherit;
}

.projects-page .project-search-segment.is-highlight {
  color: #8a6230;
  font-weight: 700;
}

.projects-page .status-badge.is-soft {
  background: rgba(177, 139, 86, 0.14);
  color: #8d6631;
}

.projects-page .project-footer {
  margin-top: 18rpx;
}

.task-complete-mask {
  z-index: 21;
  background: rgba(14, 24, 31, 0.5);
  backdrop-filter: blur(10rpx);
}

.task-complete-sheet {
  z-index: 22;
  top: 46vh;
  bottom: 0;
  height: auto;
  max-height: none;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding-bottom: calc(34rpx + env(safe-area-inset-bottom));
  background: rgba(249, 246, 240, 0.995);
}

.task-complete-sheet.is-editing {
  top: 18vh;
}

.task-complete-body {
  flex: 1 1 auto;
  min-height: 0;
  overflow-y: auto;
  padding-right: 4rpx;
  padding-bottom: 164rpx;
}

.task-complete-field {
  margin-top: 6rpx;
}

.task-complete-field.is-inline-first {
  margin-top: 16rpx;
}

.task-complete-textarea {
  min-height: 48rpx;
  line-height: 1.65;
}

.task-complete-inline-entry {
  margin-top: 12rpx;
}

.task-complete-inline-btn {
  margin-top: 0;
  min-width: 220rpx;
}

.task-complete-next-card {
  margin-top: 18rpx;
  padding: 20rpx 20rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(247, 243, 236, 0.92);
  box-shadow: inset 0 0 0 2rpx rgba(24, 39, 51, 0.04);
}

.task-complete-next-head {
  align-items: center;
  gap: 18rpx;
}

.task-complete-toggle-title {
  font-size: 27rpx;
  font-weight: 700;
  color: #182730;
}

.task-complete-type-wall {
  gap: 10rpx;
  margin-top: 10rpx;
}

.task-complete-time-row {
  gap: 12rpx;
}

.task-complete-time-row .picker-block {
  flex: 1 1 0;
}

.task-complete-next-textarea {
  min-height: 150rpx;
  line-height: 1.65;
}

.task-complete-actions.is-fixed {
  flex: 0 0 auto;
  margin-top: 16rpx;
  padding-top: 16rpx;
  padding-bottom: 4rpx;
  border-top: 2rpx solid rgba(24, 39, 51, 0.08);
  background: rgba(249, 246, 240, 0.98);
}

.task-complete-actions.is-fixed.is-editing {
  margin-top: 12rpx;
}
