.shared-page .hero {
  padding: 26rpx 28rpx 28rpx;
  border-radius: 32rpx;
  box-shadow: var(--theme-hero-shadow);
}

.shared-page .hero-title {
  margin-top: 18rpx;
  font-size: 40rpx;
}

.shared-page .hero-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.55;
}

.shared-page .search-panel {
  position: relative;
}

.shared-page .shared-control-card {
  padding: 18rpx 20rpx;
}

.shared-page .projects-search-input {
  padding-right: 110rpx;
  background: var(--theme-glass-bg);
}

.shared-page .search-clear {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 22rpx;
  color: var(--theme-text-soft);
}

.shared-page .shared-scroll-row {
  width: 100%;
  white-space: nowrap;
}

.shared-page .shared-control-block {
  margin-top: 10rpx;
}

.shared-page .shared-control-label {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--theme-text-muted);
}

.shared-page .shared-status-scroll {
  margin-top: 8rpx;
}

.shared-page .shared-status-row {
  display: inline-flex;
  min-width: 100%;
  gap: 10rpx;
  padding-bottom: 2rpx;
}

.shared-page .shared-status-chip,
.shared-page .shared-sort-chip {
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 19rpx;
  background: var(--theme-chip-bg);
  color: var(--theme-chip-text);
  box-shadow: inset 0 0 0 1rpx var(--theme-divider);
}

.shared-page .shared-status-chip.is-active,
.shared-page .shared-sort-chip.is-active {
  background: var(--theme-chip-active-bg);
  color: var(--theme-chip-active-text);
  box-shadow: inset 0 0 0 1rpx var(--theme-hero-primary-border);
}

.shared-page .shared-sort-block {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.shared-page .shared-sort-block .shared-control-label {
  flex: 0 0 auto;
}

.shared-page .shared-sort-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 10rpx;
}

.shared-page .summary-grid {
  display: grid;
  gap: 10rpx;
  margin-top: 14rpx;
}

.shared-page .shared-summary-strip {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.shared-page .summary-card {
  padding: 16rpx 14rpx 14rpx;
  border-radius: 22rpx;
  background: var(--theme-project-card-bg);
  box-shadow: var(--theme-project-card-shadow);
  text-align: center;
}

.shared-page .summary-card-label {
  font-size: 19rpx;
  color: var(--theme-text-soft);
}

.shared-page .summary-card-value {
  margin-top: 6rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--theme-title);
}

.shared-page .summary-card-note {
  margin-top: 4rpx;
  font-size: 18rpx;
  line-height: 1.45;
  color: var(--theme-text-muted);
}

.shared-page .result-bar,
.shared-page .state-card {
  padding: 16rpx 20rpx;
}

.shared-page .result-bar {
  margin-top: 14rpx;
  background: var(--theme-glass-bg);
  box-shadow: var(--theme-surface-shadow);
}

.shared-page .result-bar-text {
  font-size: 21rpx;
  line-height: 1.6;
  color: var(--theme-text-soft);
}

.shared-page .state-actions {
  margin-top: 18rpx;
}

.shared-page .state-btn {
  min-width: 220rpx;
}

.shared-page .practical-project-card {
  padding: 22rpx;
}

.shared-page .project-main {
  flex: 1 1 auto;
  min-width: 0;
}

.shared-page .shared-status-badge {
  flex: 0 0 auto;
  max-width: 220rpx;
  padding: 9rpx 14rpx;
  font-size: 20rpx;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.shared-page .project-pill-row {
  gap: 8rpx;
}

.shared-page .shared-summary-card {
  margin-top: 12rpx;
}

.shared-page .compact-inline-metrics {
  margin-top: 10rpx;
}

.shared-page .compact-project-footer {
  margin-top: 8rpx;
}

.shared-page .compact-project-footer .helper-text + .helper-text {
  margin-top: 4rpx;
}

.shared-page .compact-inline-actions {
  margin-top: 12rpx;
  gap: 8rpx;
}

.shared-page .compact-inline-actions .btn-primary {
  min-width: 220rpx;
}

.page-shell.shared-page.appearance-font-large .hero {
  padding: 30rpx;
}

.page-shell.shared-page.appearance-font-large .hero-title {
  font-size: 50rpx;
}

.page-shell.shared-page.appearance-font-large .hero-subtitle {
  font-size: 28rpx;
  line-height: 1.68;
}

.page-shell.shared-page.appearance-font-large .summary-card,
.page-shell.shared-page.appearance-font-large .practical-project-card {
  border-radius: 24rpx;
}

.page-shell.shared-page.appearance-font-large .compact-inline-metrics {
  gap: 10rpx;
}

.page-shell.shared-page.appearance-font-readable .hero {
  padding: 34rpx;
}

.page-shell.shared-page.appearance-font-readable .hero-title {
  font-size: 60rpx;
  line-height: 1.34;
}

.page-shell.shared-page.appearance-font-readable .hero-subtitle {
  font-size: 36rpx;
  line-height: 1.76;
}

.page-shell.shared-page.appearance-font-readable .shared-control-card,
.page-shell.shared-page.appearance-font-readable .result-bar,
.page-shell.shared-page.appearance-font-readable .state-card {
  padding: 22rpx 24rpx;
}

.page-shell.shared-page.appearance-font-readable .summary-card,
.page-shell.shared-page.appearance-font-readable .practical-project-card {
  border-radius: 26rpx;
}

.page-shell.shared-page.appearance-font-readable .compact-inline-metrics {
  gap: 12rpx;
}
