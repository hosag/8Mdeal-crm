.shared-page .search-panel {
  position: relative;
}

.shared-page .projects-search-input {
  padding-right: 110rpx;
  background: rgba(255, 255, 255, 0.88);
}

.shared-page .search-clear {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 22rpx;
  color: #6d7a87;
}

.shared-page .compact-toolbar {
  gap: 12rpx;
}

.shared-page .summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.shared-page .summary-card {
  padding: 22rpx;
  border-radius: 26rpx;
  background: rgba(255, 252, 247, 0.9);
  box-shadow: 0 16rpx 32rpx rgba(24, 39, 51, 0.08);
}

.shared-page .summary-card-label {
  font-size: 22rpx;
  color: #6b7985;
}

.shared-page .summary-card-value {
  margin-top: 8rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #172530;
}

.shared-page .summary-card-note {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7b8793;
}

.shared-page .result-bar,
.shared-page .state-card {
  padding: 24rpx 26rpx;
}

.shared-page .state-actions {
  margin-top: 18rpx;
}

.shared-page .state-btn {
  min-width: 220rpx;
}

.shared-page .practical-project-card {
  padding: 26rpx;
}

.shared-page .project-main {
  flex: 1 1 auto;
  min-width: 0;
}

.shared-page .shared-status-badge {
  flex: 0 0 auto;
  max-width: 220rpx;
  padding: 10rpx 16rpx;
  font-size: 21rpx;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.shared-page .project-pill-row {
  gap: 10rpx;
}

.shared-page .shared-summary-card {
  margin-top: 14rpx;
}

.shared-page .compact-inline-metrics {
  margin-top: 14rpx;
}

.shared-page .compact-project-footer {
  margin-top: 12rpx;
}

.shared-page .compact-project-footer .helper-text + .helper-text {
  margin-top: 4rpx;
}

.shared-page .compact-inline-actions {
  margin-top: 16rpx;
  gap: 10rpx;
}

.shared-page .shared-note {
  margin-top: 16rpx;
}
