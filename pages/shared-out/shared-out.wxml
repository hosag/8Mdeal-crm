<view class="page-shell shared-page {{appearancePageClass}}">
  <view class="custom-nav-spacer" style="height: {{tabNavigationSpacerHeight}}px;"></view>
  <view wx:if="{{isLoading && !hasLoadedOnce}}" class="rise-in">
    <loading-panel rows="2" appearance-page-class="{{appearancePageClass}}" />
  </view>

  <block wx:else>
    <view class="hero rise-in">
      <view class="eyebrow-row">
        <view class="eyebrow">外发项目</view>
      </view>
      <view class="hero-title">外发进展</view>
      <view class="hero-subtitle">这里专门查看已转交项目的打开、接手和继续推进状态。</view>
    </view>

    <view wx:if="{{isLoadFailed}}" class="form-card section state-card rise-in stagger-1">
      <view class="form-card-title">外发项目加载失败</view>
      <view class="form-card-desc">{{loadError}}</view>
      <view class="hero-actions state-actions">
        <view class="btn-primary state-btn" bindtap="retryFetch">重新加载</view>
      </view>
    </view>

    <view class="section rise-in stagger-1">
      <view class="form-card projects-filter-card shared-control-card">
        <view class="search-panel compact-search-panel">
          <input class="input-sim input-native projects-search-input" value="{{searchKeyword}}" bindinput="onSearchInput" placeholder="搜索项目名 / 接收方 / 标签" placeholder-class="input-placeholder" confirm-type="search" />
          <view wx:if="{{searchKeyword}}" class="search-clear" bindtap="clearSearch">清空</view>
        </view>
        <view class="shared-control-block">
          <view class="shared-control-label">状态</view>
          <scroll-view scroll-x class="shared-scroll-row shared-status-scroll" enable-flex show-scrollbar="{{false}}">
            <view class="shared-status-row">
              <view class="chip shared-status-chip {{statusFilter === item.key ? 'is-active' : ''}}" wx:for="{{statusFilters}}" wx:key="key" data-filter="{{item.key}}" bindtap="setStatusFilter">{{item.label}}</view>
            </view>
          </scroll-view>
        </view>
        <view class="shared-control-block shared-sort-block">
          <view class="shared-control-label">排序</view>
          <view class="shared-sort-row">
            <view class="chip shared-sort-chip {{sortMode === item.key ? 'is-active' : ''}}" wx:for="{{sortOptions}}" wx:key="key" data-sort="{{item.key}}" bindtap="setSortMode">{{item.label}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="summary-grid shared-summary-strip rise-in stagger-2">
      <view class="summary-card" wx:for="{{summaryCards}}" wx:key="label">
        <view class="summary-card-label">{{item.label}}</view>
        <view class="summary-card-value">{{item.value}}</view>
        <view class="summary-card-note">{{item.note}}</view>
      </view>
    </view>

    <view class="form-card section result-bar rise-in stagger-2">
      <view class="result-bar-text">{{resultSummaryText}}</view>
    </view>

    <view class="section rise-in stagger-3">
      <view class="project-card practical-project-card" wx:for="{{filteredRecords}}" wx:key="id" data-url="/pages/project-detail/project-detail" data-project-id="{{item.projectId}}" bindtap="openPage">
        <view class="project-top">
          <view class="project-main">
            <view class="project-name">{{item.name}}</view>
            <view class="project-meta shared-record-meta">{{item.partner}} · {{item.createdAt}}</view>
          </view>
          <view class="status-badge shared-status-badge {{item.progressBadgeClass}}">
            <text>{{item.statusText}}</text>
            <text wx:if="{{item.unreadProgressBadgeText}}" class="shared-status-count">{{item.unreadProgressBadgeText}}</text>
          </view>
        </view>

        <view class="pill-row project-pill-row shared-top-pills">
          <view class="soft-badge">接收方 {{item.receiverName}}</view>
          <view class="field-pill">阶段 {{item.stageBadgeText}}</view>
          <view class="field-pill">{{item.viewed}}</view>
          <view wx:if="{{item.collaboratorFollowCount}}" class="field-pill">推进 {{item.collaboratorFollowCount}} 条</view>
        </view>

        <view class="project-summary-compact shared-summary-card shared-core-card">
          <view class="project-summary-row">
            <view class="project-summary-label">当前</view>
            <view class="project-summary-text">{{item.coreSummary}}</view>
          </view>
        </view>

        <view class="compact-inline-metrics shared-card-metrics">
          <view class="compact-inline-item">首次 {{item.firstTouchText}}</view>
          <view class="compact-inline-item">更新 {{item.latestTrackingText}}</view>
          <view wx:if="{{item.statusKey === 'taken_over' || item.statusKey === 'followed'}}" class="compact-inline-item">接手 {{item.takeoverText}}</view>
        </view>

        <view class="inline-actions compact-inline-actions">
          <view class="btn-primary" data-project-id="{{item.projectId}}" catchtap="openRecordDetail">查看详情</view>
        </view>
      </view>

      <empty-state
        wx:if="{{!filteredRecords.length}}"
        appearance-page-class="{{appearancePageClass}}"
        title="{{emptyTitle}}"
        desc="{{emptyDesc}}"
        image="/assets/illustrations/empty-share.svg"
        actionText="{{emptyActionText}}"
        bind:action="handleEmptyAction"
      />
    </view>
  </block>
</view>
