<view class="page-shell {{appearancePageClass}}">
  <view wx:if="{{isLoading}}" class="rise-in">
    <loading-panel rows="2" appearance-page-class="{{appearancePageClass}}" />
  </view>

  <block wx:else>
  <view class="hero rise-in">
    <view class="eyebrow-row">
      <view class="eyebrow">隐私标签</view>
    </view>
    <view class="hero-title">分享可见范围</view>
    <view class="hero-subtitle">分别管理发送资料和转交项目时，对方可以看到哪些信息。</view>
  </view>

  <view class="section rise-in stagger-1">
    <view class="tag-card" wx:for="{{privacyScopes}}" wx:key="mode" data-tag-id="{{item.id}}" data-mode="{{item.mode}}" bindtap="openPage">
      <view class="line-between">
        <view>
          <view class="tag-title">{{item.name}}</view>
          <view class="tag-desc">{{item.desc}}</view>
        </view>
        <view class="chip">编辑</view>
      </view>
      <view class="pill-row">
        <view class="field-pill" wx:for="{{item.fields}}" wx:key="*this">{{item}}</view>
      </view>
    </view>
    <empty-state
      wx:if="{{!privacyScopes.length}}"
      appearance-page-class="{{appearancePageClass}}"
      title="暂无可用范围"
      desc="当前无法加载分享范围设置。"
      image="/assets/illustrations/empty-tags.svg"
    />
  </view>
  </block>
</view>
