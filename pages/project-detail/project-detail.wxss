  gap: 16rpx;
}

.project-detail-page .timeline-type-badge {
  flex: 0 0 auto;
}

.project-detail-page .timeline-title {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--theme-title);
}

.project-detail-page .timeline-meta-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx 16rpx;
  margin-top: 8rpx;
}

.project-detail-page .timeline-card {
  margin-top: 12rpx;
  padding: 18rpx 18rpx 20rpx;
  border-radius: 22rpx;
  background: var(--theme-summary-bg);
  box-shadow: var(--theme-summary-shadow);
}

.project-detail-page .timeline-pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.project-detail-page .timeline-section + .timeline-section {
  margin-top: 14rpx;
}

.project-detail-page .timeline-section-label {
  font-size: 21rpx;
  font-weight: 700;
  color: var(--theme-text-soft);
  letter-spacing: 0.06em;
}

.project-detail-page .timeline-section-text {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--theme-text-main);
}

.project-detail-page .timeline-list {
  margin-top: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.project-detail-page .timeline-list-item {
  position: relative;
  padding-left: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--theme-text-main);
}

.project-detail-page .timeline-list-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 14rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--theme-brand-text);
}

.project-detail-page .timeline-list-item.is-risk::before {
  background: var(--theme-soft-badge-text);
}

.project-detail-page .share-history-card {
