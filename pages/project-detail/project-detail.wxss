.transfer-mode-sheet {
  max-height: 82vh;
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
}

.transfer-mode-mask {
  backdrop-filter: blur(10rpx);
}

.transfer-mode-caption {
  margin-top: 6rpx;
  max-width: 520rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: var(--theme-text-soft);
}

.transfer-mode-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.transfer-mode-card {
  position: relative;
  overflow: hidden;
  padding: 22rpx;
  border-radius: 24rpx;
  background: var(--theme-project-card-bg);
  box-shadow: inset 0 0 0 1rpx var(--theme-divider);
}

.transfer-mode-card.is-active {
  background: var(--theme-summary-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-brand-bg);
}

.transfer-selected-mark {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 58rpx;
  height: 46rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 2rpx 0 8rpx;
  border-top-left-radius: 22rpx;
  background: rgba(49, 112, 92, 0.08);
  color: rgba(49, 112, 92, 0.72);
  box-shadow: inset 1rpx 1rpx 0 rgba(49, 112, 92, 0.1);
  font-size: 21rpx;
  font-weight: 600;
  line-height: 1;
}

.transfer-name-field {
  margin-top: 18rpx;
}

.transfer-mode-note {
  margin-top: 14rpx;
}

.transfer-mode-actions {
  margin-top: 20rpx;
}
