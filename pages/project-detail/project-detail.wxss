.project-detail-page .hero-summary-grid {
  margin-top: 20rpx;
}

.project-detail-page .detail-section-card {
  padding: 26rpx;
}

.project-detail-page .detail-overview-card {
  margin-top: 18rpx;
}

.project-detail-page .detail-overview-footer {
  margin-top: 12rpx;
}

.project-detail-page .detail-overview-footer .helper-text + .helper-text {
  margin-top: 4rpx;
}

.project-detail-page .contact-card {
  margin-top: 16rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: var(--theme-project-card-bg);
  box-shadow: var(--theme-project-card-shadow);
}

.project-detail-page .contact-card:first-of-type {
  margin-top: 18rpx;
}

.project-detail-page .contact-card .chip {
  flex: 0 0 auto;
}

.project-detail-page .contact-security-headline {
  margin-top: 6rpx;
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: var(--theme-soft-badge-bg);
  box-shadow: inset 0 0 0 1rpx var(--theme-divider);
  font-size: 19rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  color: var(--theme-soft-badge-text);
}

.project-detail-contact-sheet .contact-sheet-list {
  margin-top: 2rpx;
}

.project-detail-contact-sheet .contact-sheet-security-card {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
  padding: 18rpx 26rpx;
}

.project-detail-contact-sheet .contact-sheet-banner {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: var(--theme-soft-badge-bg);
  box-shadow: inset 0 0 0 1rpx var(--theme-divider);
  color: var(--theme-soft-badge-text);
  font-size: 18rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.project-detail-contact-sheet .contact-sheet-card {
  padding: 24rpx 26rpx;
}

.project-detail-contact-sheet .contact-sheet-card + .contact-sheet-card {
  margin-top: 14rpx;
}

.project-detail-page .timeline-header-note,
.project-detail-page .share-header-note,
.project-detail-page .task-header-note {
  margin-top: 10rpx;
}

.project-detail-page .task-latest-done {
  margin-top: 10rpx;
}

.project-detail-page .task-card {
  margin-top: 16rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: var(--theme-project-card-bg);
  box-shadow: var(--theme-project-card-shadow);
}

.project-detail-page .task-card-head {
  align-items: flex-start;
}

.project-detail-page .task-card-main {
  flex: 1 1 auto;
  min-width: 0;
}

.project-detail-page .task-card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--theme-title);
}

.project-detail-page .task-card-metrics {
  margin-top: 12rpx;
}

.project-detail-page .task-card-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--theme-text-secondary);
}

.project-detail-page .task-card-actions {
  margin-top: 14rpx;
}

.share-entry-sheet {
  background: var(--theme-sheet-bg);
  box-shadow: var(--theme-sheet-shadow);
}

.share-entry-header {
  margin-top: 2rpx;
  padding: 2rpx 4rpx 0;
}

.share-entry-header-title {
  font-size: 29rpx;
  font-weight: 700;
  color: var(--theme-title);
}

.share-entry-header-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: var(--theme-text-soft);
}

.share-entry-list {
  margin-top: 14rpx;
}

.share-entry-card {
  padding: 20rpx 22rpx 18rpx;
  border-radius: 24rpx;
  background: var(--theme-project-card-bg);
  box-shadow: var(--theme-state-card-shadow);
}

.share-entry-card + .share-entry-card {
  margin-top: 12rpx;
}

.share-entry-head {
  align-items: flex-start;
}

.share-entry-head .mode-desc {
  margin-top: 8rpx;
  line-height: 1.62;
}

.share-entry-head .status-badge {
  flex: 0 0 auto;
  margin-top: 2rpx;
  padding: 6rpx 14rpx;
  font-size: 20rpx;
  color: var(--theme-brand-text);
  background: var(--theme-brand-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.task-complete-mask {
  z-index: 21;
  background: var(--theme-sheet-mask);
  backdrop-filter: blur(10rpx);
}

.task-complete-sheet {
  z-index: 22;
  top: 46vh;
  bottom: 0;
  height: auto;
  max-height: none;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding-bottom: calc(34rpx + env(safe-area-inset-bottom));
  background: var(--theme-sheet-bg);
  box-shadow: var(--theme-sheet-shadow);
}

.task-complete-sheet.is-editing {
  top: 18vh;
}

.task-complete-body {
  flex: 1 1 auto;
  min-height: 0;
  overflow-y: auto;
  padding-right: 4rpx;
  padding-bottom: 164rpx;
}

.task-complete-field {
  margin-top: 6rpx;
}

.task-complete-field.is-inline-first {
  margin-top: 16rpx;
}

.task-complete-textarea {
  min-height: 48rpx;
  line-height: 1.65;
}

.task-complete-toggle-title {
  font-size: 27rpx;
  font-weight: 700;
  color: var(--theme-title);
}

.task-complete-inline-entry {
  margin-top: 12rpx;
}

.task-complete-inline-btn {
  margin-top: 0;
  min-width: 220rpx;
}

.task-complete-next-card {
  margin-top: 18rpx;
  padding: 20rpx 20rpx 22rpx;
  border-radius: 24rpx;
  background: var(--theme-soft-block-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.task-complete-next-head {
  align-items: center;
  gap: 18rpx;
}

.task-complete-type-wall {
  gap: 10rpx;
  margin-top: 10rpx;
}

.task-complete-time-row {
  gap: 12rpx;
}

.task-complete-next-textarea {
  min-height: 150rpx;
  line-height: 1.65;
}

.task-complete-next-note {
  margin-top: 14rpx;
}

.task-complete-actions {
  margin-top: 22rpx;
}

.task-complete-actions.is-fixed {
  flex: 0 0 auto;
  margin-top: 16rpx;
  padding-top: 16rpx;
  padding-bottom: 4rpx;
  border-top: 2rpx solid var(--theme-divider);
  background: var(--theme-sheet-bg);
}

.task-complete-actions.is-fixed.is-editing {
  margin-top: 12rpx;
}

.project-detail-page .timeline-body .helper-text + .helper-text {
