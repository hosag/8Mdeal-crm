<view class="page-shell project-detail-page {{appearancePageClass}}">
  <view wx:if="{{isLoading}}" class="rise-in">
    <loading-panel rows="3" appearance-page-class="{{appearancePageClass}}" />
  </view>

  <block wx:else>
  <view class="hero rise-in">
    <view class="eyebrow-row">
      <view class="eyebrow">项目详情</view>
    </view>
    <view class="hero-title">{{projectDetail.name}}</view>
    <view class="hero-subtitle">{{projectDetail.client || '未填写客户'}}</view>
    <view class="pill-row">
      <view wx:for="{{projectBadges}}" wx:key="text" class="{{item.className}}">{{item.text}}</view>
    </view>
    <view class="detail-grid hero-summary-grid">
      <view class="detail-box" wx:for="{{heroMetrics}}" wx:key="label">
        <view class="detail-box-label">{{item.label}}</view>
        <view class="detail-box-value">{{item.value}}</view>
        <view class="detail-box-note">{{item.note}}</view>
      </view>
    </view>
  </view>

  <view class="section surface-card rise-in stagger-1 detail-section-card">
    <view class="section-header">
      <view class="section-title">项目摘要</view>
      <view class="section-actions">
        <view wx:if="{{showProjectAiAction}}" class="section-link section-link-brand ai-entry ai-entry-link" bindtap="handleProjectAiJudge">
          <image wx:if="{{!isProjectAiLoading}}" class="ai-entry-icon" src="/assets/icons/ai-agent-dark.svg" mode="aspectFit" />
          <view wx:else class="ai-agent-loader">
            <view class="ai-agent-loader-antenna is-left"><view class="ai-agent-loader-dot"></view></view>
            <view class="ai-agent-loader-antenna is-right"><view class="ai-agent-loader-dot"></view></view>
            <view class="ai-agent-loader-cap"></view>
            <view class="ai-agent-loader-ear is-left"></view>
            <view class="ai-agent-loader-ear is-right"></view>
            <view class="ai-agent-loader-head">
              <view class="ai-agent-loader-eye is-left"></view>
              <view class="ai-agent-loader-eye is-right"></view>
              <view class="ai-agent-loader-mouth"></view>
            </view>
          </view>
          <view class="ai-entry-text">{{isProjectAiLoading ? '生成中...' : 'AI研判'}}</view>
        </view>
        <view wx:if="{{showProjectReviewAction}}" class="section-link section-link-brand ai-entry ai-entry-link" bindtap="handleProjectAiReview">
          <image wx:if="{{!isProjectReviewLoading}}" class="ai-entry-icon" src="/assets/icons/ai-agent-dark.svg" mode="aspectFit" />
          <view wx:else class="ai-agent-loader">
            <view class="ai-agent-loader-antenna is-left"><view class="ai-agent-loader-dot"></view></view>
            <view class="ai-agent-loader-antenna is-right"><view class="ai-agent-loader-dot"></view></view>
            <view class="ai-agent-loader-cap"></view>
            <view class="ai-agent-loader-ear is-left"></view>
            <view class="ai-agent-loader-ear is-right"></view>
            <view class="ai-agent-loader-head">
              <view class="ai-agent-loader-eye is-left"></view>
              <view class="ai-agent-loader-eye is-right"></view>
              <view class="ai-agent-loader-mouth"></view>
            </view>
          </view>
          <view class="ai-entry-text">{{isProjectReviewLoading ? '生成中...' : 'AI复盘'}}</view>
        </view>
        <view wx:if="{{projectAccess.canEditProject}}" class="section-link" bindtap="copyProject">{{isCopyingProject ? '复制中...' : '复制项目'}}</view>
        <view wx:if="{{projectAccess.canEditProject}}" class="section-link {{!projectId ? 'is-muted' : ''}}" bindtap="goEditProject">编辑项目</view>
        <view wx:if="{{!projectAccess.canEditProject}}" class="section-link is-muted">当前只读</view>
      </view>
    </view>
    <view wx:if="{{projectDetail.description}}" class="helper-text detail-overview-desc">{{projectDetail.description}}</view>
    <view class="project-summary-compact detail-overview-card">
      <view class="detail-overview-focus">
        <view class="project-summary-label">当前重点</view>
        <view class="detail-overview-focus-text">{{projectOverview.focusText}}</view>
      </view>
      <view class="detail-overview-summary">{{projectOverview.latestSummary}}</view>
    </view>
    <view class="compact-inline-metrics detail-overview-metrics">
      <view class="compact-inline-item">主要联系人 {{projectOverview.primaryContactText}}</view>
      <view class="compact-inline-item">跟进记录 {{projectOverview.recordCountText}}</view>
      <view class="compact-inline-item">推进归属 {{projectOverview.ownerLabel}}</view>
      <view class="compact-inline-item">最近回填 {{projectOverview.latestFollowText}}</view>
      <view class="compact-inline-item">分享状态 {{projectOverview.shareStatusText}}</view>
    </view>
    <view class="pill-row" wx:if="{{projectDetail.tags && projectDetail.tags.length}}">
      <view class="field-pill" wx:for="{{projectDetail.tags}}" wx:key="*this">{{item}}</view>
    </view>
  </view>

  <view class="section surface-card rise-in stagger-2 detail-section-card">
    <view class="section-header">
      <view>
        <view class="section-title">联系人</view>
        <view class="helper-text contact-security-headline">联系方式加密存储</view>
      </view>
      <view wx:if="{{projectAccess.canManageContacts}}" class="section-link" bindtap="openAddContactSheet">新增联系人</view>
      <view wx:if="{{!projectAccess.canManageContacts}}" class="section-link is-muted">当前只读</view>
    </view>
    <view class="compact-inline-metrics detail-section-meta" wx:if="{{contactMeta.countText}}">
      <view class="compact-inline-item">{{contactMeta.countText}}</view>
      <view class="compact-inline-item">{{contactMeta.primaryText}}</view>
    </view>
    <view wx:if="{{!contacts.length}}" class="card-subtitle compact-empty-text">还没有联系人，先补关键决策人即可。</view>
    <view class="contact-summary contact-card" wx:for="{{contacts}}" wx:key="id" bindtap="toggleContacts">
      <view class="line-between">
        <view>
          <view class="contact-name">{{item.name}}</view>
          <view class="contact-role">{{item.role}} · {{item.company}}</view>
        </view>
        <view class="chip">查看信息</view>
      </view>
    </view>
  </view>

  <view class="section surface-card rise-in stagger-3 detail-section-card">
    <view class="section-header">
      <view class="section-title">推进任务</view>
      <view wx:if="{{projectAccess.canManageTasks}}" class="section-link" bindtap="openFollowUp">新增任务</view>
      <view wx:if="{{!projectAccess.canManageTasks}}" class="section-link is-muted">当前只读</view>
    </view>
    <view wx:if="{{taskFeedback.title}}" class="task-feedback-banner">
      <view class="task-feedback-main">
        <view class="task-feedback-title">{{taskFeedback.title}}</view>
        <view class="task-feedback-detail">{{taskFeedback.detail}}</view>
      </view>
      <view class="task-feedback-dismiss" bindtap="dismissTaskFeedback">收起</view>
    </view>
    <view class="compact-inline-metrics" wx:if="{{taskSummary.total}}">
      <view class="compact-inline-item">未完成 {{taskSummary.openCount || 0}} 条</view>
      <view class="compact-inline-item">已逾期 {{taskSummary.overdueCount || 0}} 条</view>
      <view class="compact-inline-item">已完成 {{taskSummary.completedCount || 0}} 条</view>
    </view>
    <view wx:if="{{taskSummary.latestDoneText}}" class="helper-text task-latest-done">最近完成：{{taskSummary.latestDoneText}}</view>
    <view wx:if="{{!tasks.length}}" class="card-subtitle compact-empty-text">暂无推进任务。</view>
    <view class="task-card" wx:for="{{tasks}}" wx:key="id">
      <view class="line-between task-card-head">
        <view class="task-card-main">
          <view class="task-card-title">{{item.title}}</view>
          <view class="helper-text">{{item.typeLabel}} · {{item.priorityLabel}}</view>
        </view>
        <view class="status-badge {{item.statusBadgeClass}}">{{item.statusText}}</view>
      </view>
      <view class="compact-inline-metrics task-card-metrics">
        <view class="compact-inline-item">截止 {{item.dueText}}</view>
        <view class="compact-inline-item">归属 {{item.ownerName}}</view>
      </view>
      <view wx:if="{{item.description}}" class="task-card-desc">{{item.description}}</view>
      <view wx:if="{{item.resultSummary}}" class="helper-text">完成结果：{{item.resultSummary}}</view>
      <view wx:if="{{projectAccess.canManageTasks && item.hasActions}}" class="inline-actions compact-inline-actions task-card-actions">
        <view wx:if="{{item.canCancel}}" class="btn-ghost" data-task-id="{{item.id}}" data-status="canceled" bindtap="updateTaskStatus">{{taskActionId === item.id ? '处理中...' : '取消任务'}}</view>
        <view wx:if="{{item.canComplete}}" class="btn-primary" data-task-id="{{item.id}}" bindtap="openTaskCompleteSheet">{{taskActionId === item.id ? '处理中...' : '去完成'}}</view>
      </view>
    </view>
  </view>

  <view class="section glass-card rise-in stagger-4 detail-section-card">
    <view class="section-header">
      <view class="section-title">跟进时间线</view>
      <view wx:if="{{projectAccess.canAdvanceProject}}" class="section-link" bindtap="openFollowUp">新增跟进</view>
      <view wx:if="{{!projectAccess.canAdvanceProject}}" class="section-link is-muted">当前只读</view>
    </view>
    <view class="compact-inline-metrics detail-section-meta">
      <view class="compact-inline-item">{{timelineMeta.totalText}}</view>
      <view class="compact-inline-item">{{timelineMeta.latestText}}</view>
      <view wx:if="{{timelineMeta.extraText}}" class="compact-inline-item">{{timelineMeta.extraText}}</view>
    </view>
    <view wx:if="{{!followTimeline.length}}" class="card-subtitle compact-empty-text">暂无跟进记录。</view>
    <view class="timeline-group" wx:for="{{followTimeline}}" wx:key="date">
      <view class="timeline-group-title">{{item.date}}</view>
      <view class="timeline-item" wx:for="{{item.items}}" wx:key="timelineKey">
        <view class="timeline-axis">
          <view class="timeline-dot"></view>
          <view class="timeline-line"></view>
        </view>
        <view class="timeline-body">
          <view class="timeline-meta-top">
            <view class="timeline-time">{{item.time}}</view>
            <view class="status-badge timeline-type-badge {{item.typeBadgeClass}}">{{item.typeLabel}}</view>
          </view>
          <view class="timeline-title">{{item.title}}</view>
          <view class="timeline-meta-line">
            <view class="helper-text">记录人：{{item.actorName || '当前用户'}}</view>
            <view class="helper-text" wx:if="{{item.methodLabel && item.typeKey !== 'task_done'}}">方式：{{item.methodLabel}}</view>
            <view class="helper-text" wx:if="{{item.collaborationLabel}}">{{item.collaborationLabel}}</view>
          </view>
          <view class="timeline-card">
            <view class="timeline-pill-row" wx:if="{{item.stageChange || item.nextFollowUpText || (item.recommendedStage && item.recommendedStage !== item.stageChange)}}">
              <view wx:if="{{item.stageChange}}" class="soft-badge">阶段 {{item.stageChange}}</view>
              <view wx:if="{{item.nextFollowUpText}}" class="field-pill">下次 {{item.nextFollowUpText}}</view>
              <view wx:if="{{item.recommendedStage && item.recommendedStage !== item.stageChange}}" class="chip">建议 {{item.recommendedStage}}</view>
            </view>
            <view class="timeline-section" wx:if="{{item.summary}}">
              <view class="timeline-section-label">{{item.summaryLabel || '整理摘要'}}</view>
              <view class="timeline-section-text">{{item.summary}}</view>
            </view>
            <view class="timeline-section" wx:if="{{item.highlights && item.highlights.length}}">
              <view class="timeline-section-label">{{item.highlightsLabel || '关键进展'}}</view>
              <view class="timeline-list">
                <view class="timeline-list-item" wx:for="{{item.highlights}}" wx:key="*this">{{item}}</view>
              </view>
            </view>
            <view class="timeline-section" wx:if="{{item.risks && item.risks.length}}">
              <view class="timeline-section-label">风险</view>
              <view class="timeline-list">
                <view class="timeline-list-item is-risk" wx:for="{{item.risks}}" wx:key="*this">{{item}}</view>
              </view>
            </view>
            <view class="timeline-section" wx:if="{{item.stageChangeReason}}">
              <view class="timeline-section-label">阶段说明</view>
              <view class="timeline-section-text">{{item.stageChangeReason}}</view>
            </view>
            <view class="timeline-section" wx:if="{{item.missingInfo && item.missingInfo.length}}">
              <view class="timeline-section-label">待补信息</view>
              <view class="timeline-list">
                <view class="timeline-list-item" wx:for="{{item.missingInfo}}" wx:key="*this">{{item}}</view>
              </view>
            </view>
            <view class="timeline-section timeline-section-raw" wx:if="{{item.desc && item.desc !== item.summary}}">
              <view class="timeline-section-label">{{item.rawLabel || '原始录入'}}</view>
              <view class="timeline-section-text timeline-raw-text">{{item.desc}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section surface-card rise-in stagger-5 detail-section-card">
    <view class="section-header">
      <view class="section-title">项目资料</view>
      <view wx:if="{{projectAssetSummary.total}}" class="section-link" bindtap="openProjectAssetsPage">查看全部</view>
    </view>
    <view class="compact-inline-metrics detail-section-meta">
      <view class="compact-inline-item">{{projectAssetSummary.totalText}}</view>
      <view class="compact-inline-item">{{projectAssetSummary.imageText}}</view>
      <view class="compact-inline-item">{{projectAssetSummary.fileText}}</view>
      <view wx:if="{{projectAssetSummary.recentText}}" class="compact-inline-item">{{projectAssetSummary.recentText}}</view>
    </view>
    <view wx:if="{{!projectAssetSummary.total}}" class="card-subtitle compact-empty-text">暂无项目资料。</view>
    <view wx:else class="project-assets-preview-grid">
      <view
        class="project-asset-preview {{item.type === 'image' ? 'is-image' : 'is-file'}}"
        wx:for="{{projectAssetSummary.previewAssets}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="previewProjectAsset"
      >
        <image wx:if="{{item.type === 'image'}}" class="project-asset-thumb" src="{{item.previewUrl || item.url || item.fileId}}" mode="aspectFill" />
        <view wx:else class="project-asset-file">
          <view class="project-asset-file-type">{{item.extensionText}}</view>
          <view class="project-asset-file-name">{{item.name}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section surface-card rise-in stagger-5 detail-section-card">
    <view class="section-header">
      <view class="section-title">资料分享历史</view>
    </view>
    <view class="compact-inline-metrics detail-section-meta">
      <view class="compact-inline-item">{{shareHistoryMeta.totalText}}</view>
      <view class="compact-inline-item">{{shareHistoryMeta.openedText}}</view>
      <view wx:if="{{shareHistoryMeta.unopenedText}}" class="compact-inline-item">{{shareHistoryMeta.unopenedText}}</view>
    </view>
    <view wx:if="{{!shareHistory.length}}" class="card-subtitle compact-empty-text">暂无资料发送记录。</view>
    <view wx:for="{{shareHistory}}" wx:key="id" class="tag-card share-history-card">
      <view class="line-between share-history-top">
        <view>
          <view class="tag-title">{{item.receiverLabel}}</view>
          <view class="tag-desc share-history-meta">{{item.mode}} · {{item.createdAt}}</view>
          <view class="project-meta share-history-receiver">{{item.receiverSummary}}</view>
        </view>
        <view class="status-badge {{item.statusBadgeClass}}">{{item.displayStatus}}</view>
      </view>
      <view class="pill-row share-history-pill-row">
        <view class="soft-badge">查看 {{item.viewed}} 次</view>
        <view class="field-pill">{{item.progressText}}</view>
      </view>
      <view class="project-summary-compact share-history-summary-card">
        <view class="project-summary-row">
          <view class="project-summary-label">进展</view>
          <view class="project-summary-text">{{item.collaborationSummary}}</view>
        </view>
        <view class="project-summary-row">
          <view class="project-summary-label">状态</view>
          <view class="project-summary-text">{{item.statusSummary}}</view>
        </view>
      </view>
      <view class="compact-inline-metrics share-history-metrics">
        <view class="compact-inline-item">首次 {{item.firstOpenedAt || '尚未打开'}}</view>
        <view class="compact-inline-item">最近 {{item.lastViewedAt || '暂无更新'}}</view>
      </view>
    </view>
  </view>

  <view class="bottom-space"></view>
  </block>
</view>

<view wx:if="{{!isLoading && showActionFooter}}" class="footer-bar footer-bar-detail is-three {{appearancePageClass}}">
  <view class="btn-primary footer-primary-action {{!projectAccess.canAdvanceProject ? 'is-disabled' : ''}}" bindtap="openFollowUp">新增跟进</view>
  <view class="btn-secondary footer-secondary-action {{!projectAccess.canShareProject ? 'is-disabled' : ''}}" bindtap="openShareSheet">分享</view>
  <view wx:if="{{canMarkDeal && projectAccess.canMarkDeal}}" class="btn-ghost footer-tertiary-action" bindtap="openDealPage">登记成交</view>
  <view wx:else class="btn-ghost footer-tertiary-action is-disabled">{{projectAccess.canMarkDeal ? '已成交' : '当前只读'}}</view>
</view>

<view wx:if="{{showContacts}}">
  <view class="sheet-mask" bindtap="toggleContacts"></view>
  <view class="sheet-panel project-detail-contact-sheet {{appearancePageClass}}">
    <view class="sheet-handle"></view>
    <view class="sheet-header">
      <view class="sheet-title">联系人完整信息</view>
      <view class="sheet-close" bindtap="toggleContacts">关闭</view>
    </view>
    <view class="sheet-list contact-sheet-list">
      <view class="sheet-card contact-sheet-security-card contact-sheet-intro-card">
        <view class="contact-sheet-banner">已加密存储</view>
        <view class="sheet-meta contact-sheet-intro-text">电话与微信仅在你本人查看时展示。</view>
      </view>
      <view class="sheet-card contact-sheet-card" wx:for="{{contacts}}" wx:key="id">
        <view class="contact-name">{{item.name}}</view>
        <view class="sheet-meta">{{item.role}} · {{item.company}}</view>
        <view class="contact-sheet-grid">
          <view class="contact-sheet-item">
            <view class="contact-sheet-label">电话</view>
            <view class="contact-sheet-value">{{item.phone}}</view>
          </view>
          <view class="contact-sheet-item">
            <view class="contact-sheet-label">微信</view>
            <view class="contact-sheet-value">{{item.wechat}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<view wx:if="{{showAddContactSheet}}">
  <view class="sheet-mask" bindtap="closeAddContactSheet"></view>
  <view class="sheet-panel project-detail-add-contact-sheet {{appearancePageClass}}">
    <view class="sheet-handle"></view>
    <view class="sheet-header">
      <view class="sheet-title">新增联系人</view>
      <view class="sheet-close" bindtap="closeAddContactSheet">关闭</view>
    </view>
    <view class="sheet-card contact-sheet-security-card contact-sheet-intro-card">
      <view class="contact-sheet-banner">保存后即加密</view>
    </view>
    <view class="sheet-card add-contact-form-card">
      <view class="field-group add-contact-field add-contact-first-field">
        <view class="field-label">姓名</view>
        <input class="input-sim input-native" value="{{contactDraft.name}}" data-field="name" bindinput="onAddContactInput" placeholder="请输入姓名" placeholder-class="input-placeholder" />
      </view>
      <view class="field-group add-contact-field">
        <view class="field-label">角色</view>
        <input class="input-sim input-native" value="{{contactDraft.role}}" data-field="role" bindinput="onAddContactInput" placeholder="决策人 / 技术对接" placeholder-class="input-placeholder" />
      </view>
      <view class="split-row add-contact-split-row">
        <view class="field-group add-contact-field">
          <view class="field-label">电话</view>
          <input class="input-sim input-native" value="{{contactDraft.phone}}" data-field="phone" bindinput="onAddContactInput" placeholder="请输入电话" placeholder-class="input-placeholder" />
        </view>
        <view class="field-group add-contact-field">
          <view class="field-label">微信</view>
          <input class="input-sim input-native" value="{{contactDraft.wechat}}" data-field="wechat" bindinput="onAddContactInput" placeholder="请输入微信" placeholder-class="input-placeholder" />
        </view>
      </view>
      <view class="field-group add-contact-field">
        <view class="field-label">所属公司</view>
        <input class="input-sim input-native" value="{{contactDraft.company}}" data-field="company" bindinput="onAddContactInput" placeholder="请输入所属公司" placeholder-class="input-placeholder" />
      </view>
    </view>
    <view class="inline-actions add-contact-actions">
      <view class="btn-ghost" bindtap="closeAddContactSheet">取消</view>
      <view class="btn-primary" bindtap="saveContactDraft">{{isSavingContact ? '保存中...' : '保存联系人'}}</view>
    </view>
  </view>
</view>

<view wx:if="{{showProjectAiSheet}}">
  <view class="sheet-mask" bindtap="closeProjectAiSheet"></view>
  <view class="sheet-panel project-ai-sheet {{appearancePageClass}}">
    <view class="sheet-handle"></view>
    <view class="sheet-header">
      <view class="project-ai-header-main">
        <view class="sheet-title">项目研判</view>
        <view class="project-ai-header-caption">{{projectDetail.name}}</view>
      </view>
      <view class="sheet-close" bindtap="closeProjectAiSheet">关闭</view>
    </view>
    <view class="pill-row project-ai-meta-row">
      <view wx:if="{{projectDetail.stage}}" class="soft-badge">阶段 {{projectDetail.stage}}</view>
    </view>
    <scroll-view scroll-y class="project-ai-scroll">
      <view wx:if="{{isProjectAiLoading}}" class="surface-card project-ai-state-card project-ai-loading-card">
        <view class="ai-agent-loader is-large">
          <view class="ai-agent-loader-antenna is-left"><view class="ai-agent-loader-dot"></view></view>
          <view class="ai-agent-loader-antenna is-right"><view class="ai-agent-loader-dot"></view></view>
          <view class="ai-agent-loader-cap"></view>
          <view class="ai-agent-loader-ear is-left"></view>
          <view class="ai-agent-loader-ear is-right"></view>
          <view class="ai-agent-loader-head">
            <view class="ai-agent-loader-eye is-left"></view>
            <view class="ai-agent-loader-eye is-right"></view>
            <view class="ai-agent-loader-mouth"></view>
          </view>
        </view>
        <view class="form-card-title project-ai-state-title">正在生成项目研判</view>
        <view class="form-card-desc project-ai-state-desc">会结合最近时间线和未完成动作，给你一条更聚焦的判断。</view>
      </view>

      <view wx:elif="{{projectAiError && !projectAiResult}}" class="surface-card project-ai-state-card">
        <view class="form-card-title project-ai-state-title">当前无法生成项目研判</view>
        <view class="form-card-desc project-ai-state-desc">{{projectAiError}}</view>
        <view class="inline-actions project-ai-actions">
          <view class="btn-ghost ai-entry ai-entry-button" bindtap="regenerateProjectAiJudge">
            <image class="ai-entry-icon" src="/assets/icons/ai-agent-dark.svg" mode="aspectFit" />
            <view class="ai-entry-text">重新生成</view>
          </view>
        </view>
      </view>

      <block wx:elif="{{projectAiResult}}">
        <view class="project-ai-result-wrap">
          <view class="project-ai-origin">{{projectAiResult.sourceMetaText}}</view>

          <view class="project-ai-panel">
            <view class="project-ai-label">项目全貌</view>
            <view class="project-ai-text">{{projectAiResult.summary}}</view>
          </view>

          <view class="project-ai-panel">
            <view class="project-ai-label">当前判断</view>
            <view class="project-ai-text">{{projectAiResult.statusJudgement}}</view>
          </view>

          <view class="project-ai-panel" wx:if="{{projectAiResult.keyBlockers.length}}">
            <view class="project-ai-label">关键卡点</view>
            <view class="project-ai-list">
              <view class="project-ai-list-item is-blocker" wx:for="{{projectAiResult.keyBlockers}}" wx:key="*this">{{item}}</view>
            </view>
          </view>

          <view class="project-ai-panel" wx:if="{{projectAiResult.positiveSignals.length}}">
            <view class="project-ai-label">推进信号</view>
            <view class="project-ai-list">
              <view class="project-ai-list-item" wx:for="{{projectAiResult.positiveSignals}}" wx:key="*this">{{item}}</view>
            </view>
          </view>

          <view class="project-ai-panel">
            <view class="project-ai-label">最值得关注的动作</view>
            <view class="project-ai-text">{{projectAiResult.priorityAction}}</view>
          </view>

          <view class="inline-actions project-ai-actions">
            <view class="btn-ghost ai-entry ai-entry-button" bindtap="regenerateProjectAiJudge">
              <image wx:if="{{!isProjectAiLoading}}" class="ai-entry-icon" src="/assets/icons/ai-agent-dark.svg" mode="aspectFit" />
              <view wx:else class="ai-agent-loader">
                <view class="ai-agent-loader-antenna is-left"><view class="ai-agent-loader-dot"></view></view>
                <view class="ai-agent-loader-antenna is-right"><view class="ai-agent-loader-dot"></view></view>
                <view class="ai-agent-loader-cap"></view>
                <view class="ai-agent-loader-ear is-left"></view>
                <view class="ai-agent-loader-ear is-right"></view>
                <view class="ai-agent-loader-head">
                  <view class="ai-agent-loader-eye is-left"></view>
                  <view class="ai-agent-loader-eye is-right"></view>
                  <view class="ai-agent-loader-mouth"></view>
                </view>
              </view>
              <view class="ai-entry-text">{{isProjectAiLoading ? '生成中...' : projectAiResult.regenerateLabel}}</view>
            </view>
            <view wx:if="{{projectAiResultBackup}}" class="btn-ghost" bindtap="restoreProjectAiJudgeVersion">恢复上一版</view>
          </view>
        </view>
      </block>
    </scroll-view>
  </view>
</view>

<view wx:if="{{showProjectReviewSheet}}">
  <view class="sheet-mask" bindtap="closeProjectReviewSheet"></view>
  <view class="sheet-panel project-review-sheet {{appearancePageClass}}">
    <view class="sheet-handle"></view>
    <view class="sheet-header">
      <view class="project-ai-header-main">
        <view class="sheet-title">项目复盘</view>
        <view class="project-ai-header-caption">{{projectDetail.name}}</view>
      </view>
      <view class="sheet-close" bindtap="closeProjectReviewSheet">关闭</view>
    </view>
    <view class="pill-row project-ai-meta-row">
      <view wx:if="{{projectDetail.stage}}" class="soft-badge">阶段 {{projectDetail.stage}}</view>
      <view wx:if="{{projectDetail.actualAmountValue}}" class="field-pill">已签 {{projectDetail.actualAmount}}</view>
    </view>
    <scroll-view scroll-y class="project-ai-scroll" style="height: calc(82vh - 180rpx);">
      <view wx:if="{{isProjectReviewLoading}}" class="surface-card project-ai-state-card project-ai-loading-card">
        <view class="ai-agent-loader is-large">
          <view class="ai-agent-loader-antenna is-left"><view class="ai-agent-loader-dot"></view></view>
          <view class="ai-agent-loader-antenna is-right"><view class="ai-agent-loader-dot"></view></view>
          <view class="ai-agent-loader-cap"></view>
          <view class="ai-agent-loader-ear is-left"></view>
          <view class="ai-agent-loader-ear is-right"></view>
          <view class="ai-agent-loader-head">
            <view class="ai-agent-loader-eye is-left"></view>
            <view class="ai-agent-loader-eye is-right"></view>
            <view class="ai-agent-loader-mouth"></view>
          </view>
        </view>
        <view class="form-card-title project-ai-state-title">正在生成项目复盘</view>
        <view class="form-card-desc project-ai-state-desc">会结合关键时间线和推进动作，把这条项目收成可复用经验。</view>
      </view>

      <view wx:elif="{{projectReviewError && !projectReviewResult}}" class="surface-card project-ai-state-card">
        <view class="form-card-title project-ai-state-title">当前无法生成项目复盘</view>
        <view class="form-card-desc project-ai-state-desc">{{projectReviewError}}</view>
        <view class="inline-actions project-ai-actions">
          <view class="btn-ghost ai-entry ai-entry-button" bindtap="regenerateProjectAiReview">
            <image class="ai-entry-icon" src="/assets/icons/ai-agent-dark.svg" mode="aspectFit" />
            <view class="ai-entry-text">重新生成</view>
          </view>
        </view>
      </view>

      <block wx:elif="{{projectReviewResult}}">
        <view class="project-ai-result-wrap">
          <view class="project-ai-result-head">
            <view class="project-ai-origin">{{projectReviewResult.sourceMetaText}}</view>
            <view class="inline-actions project-ai-actions project-ai-head-actions">
              <view class="btn-ghost ai-entry ai-entry-button" bindtap="regenerateProjectAiReview">
                <image wx:if="{{!isProjectReviewLoading}}" class="ai-entry-icon" src="/assets/icons/ai-agent-dark.svg" mode="aspectFit" />
                <view wx:else class="ai-agent-loader">
                  <view class="ai-agent-loader-antenna is-left"><view class="ai-agent-loader-dot"></view></view>
                  <view class="ai-agent-loader-antenna is-right"><view class="ai-agent-loader-dot"></view></view>
                  <view class="ai-agent-loader-cap"></view>
                  <view class="ai-agent-loader-ear is-left"></view>
                  <view class="ai-agent-loader-ear is-right"></view>
                  <view class="ai-agent-loader-head">
                    <view class="ai-agent-loader-eye is-left"></view>
                    <view class="ai-agent-loader-eye is-right"></view>
                    <view class="ai-agent-loader-mouth"></view>
                  </view>
                </view>
                <view class="ai-entry-text">{{isProjectReviewLoading ? '生成中...' : projectReviewResult.regenerateLabel}}</view>
              </view>
              <view wx:if="{{projectReviewResultBackup}}" class="btn-ghost" bindtap="restoreProjectAiReviewVersion">恢复上一版</view>
            </view>
          </view>

          <view class="project-ai-panel">
            <view class="project-ai-label">过程简述</view>
            <view class="project-ai-text">{{projectReviewResult.reviewOverview}}</view>
          </view>

          <view class="project-ai-panel" wx:if="{{projectDetail.stage === '成交' ? projectReviewResult.turningPoints.length : projectReviewResult.slowdownPoints.length}}">
            <view class="project-ai-label">{{projectDetail.stage === '成交' ? '关键转折点' : '关键失速点'}}</view>
            <view class="project-ai-list">
              <view class="project-ai-list-item" wx:for="{{projectDetail.stage === '成交' ? projectReviewResult.turningPoints : projectReviewResult.slowdownPoints}}" wx:key="*this">{{item}}</view>
            </view>
          </view>

          <view wx:if="{{projectDetail.stage === '成交'}}" class="project-ai-panel" >
            <view class="project-ai-label">成功原因</view>
            <view wx:if="{{projectReviewResult.effectiveActions.length}}" class="project-ai-list">
              <view class="project-ai-list-item" wx:for="{{projectReviewResult.effectiveActions}}" wx:key="*this">{{item}}</view>
            </view>
            <view wx:else class="project-ai-text">当前记录不足以判断明确成功原因，可能更多来自价格合适、品牌认可或客户窗口期。</view>
          </view>

          <view wx:if="{{projectDetail.stage === '成交'}}" class="project-ai-panel">
            <view class="project-ai-label">后续指导价值</view>
            <view wx:if="{{projectReviewResult.reusableLessons.length}}" class="project-ai-list">
              <view class="project-ai-list-item" wx:for="{{projectReviewResult.reusableLessons}}" wx:key="*this">{{item}}</view>
            </view>
            <view wx:else class="project-ai-text">当前记录不足以提炼稳定经验。</view>
          </view>

          <view wx:if="{{projectDetail.stage === '流失'}}" class="project-ai-panel">
            <view class="project-ai-label">失败原因</view>
            <view wx:if="{{projectReviewResult.lossReasons.length}}" class="project-ai-list">
              <view class="project-ai-list-item is-blocker" wx:for="{{projectReviewResult.lossReasons}}" wx:key="*this">{{item}}</view>
            </view>
            <view wx:else class="project-ai-text">当前记录不足以判断明确失败原因。</view>
          </view>

          <view wx:if="{{projectDetail.stage === '流失'}}" class="project-ai-panel" >
            <view class="project-ai-label">后续指导价值</view>
            <view class="project-ai-text">{{projectReviewResult.reactivationAdvice || '当前记录不足以提炼稳定经验。'}}</view>
          </view>
        </view>
      </block>
    </scroll-view>
  </view>
</view>

<share-entry-sheet
  visible="{{showShareSheet}}"
  appearance-page-class="{{appearancePageClass}}"
  project-name="{{projectDetail.name}}"
  project-meta="{{projectDetail.shareSheetMeta}}"
  options="{{shareActionOptions}}"
  bind:close="closeShareSheet"
  bind:select="openShareFlow"
/>

<view wx:if="{{showTransferSheet}}">
  <view class="sheet-mask transfer-mode-mask" bindtap="closeTransferSheet"></view>
  <view class="sheet-panel transfer-mode-sheet {{appearancePageClass}}">
    <view class="sheet-handle"></view>
    <view class="sheet-header">
      <view>
        <view class="sheet-title">转交项目</view>
        <view class="transfer-mode-caption">{{projectDetail.name}}</view>
      </view>
      <view class="sheet-close" bindtap="closeTransferSheet">关闭</view>
    </view>
    <view class="transfer-mode-list">
      <view class="mode-card transfer-mode-card {{transferMode === 'transfer_original' ? 'is-active' : ''}}" data-mode="transfer_original" bindtap="setTransferMode">
        <view class="line-between">
          <view>
            <view class="mode-title">全部转交</view>
            <view class="mode-desc">对方接手原项目，你保留只读查看。</view>
          </view>
          <view class="status-badge {{transferMode === 'transfer_original' ? 'is-brand' : ''}}">原项目</view>
        </view>
        <view wx:if="{{transferMode === 'transfer_original'}}" class="transfer-selected-mark">✓</view>
      </view>
      <view class="mode-card transfer-mode-card {{transferMode === 'clone_seed' ? 'is-active' : ''}}" data-mode="clone_seed" bindtap="setTransferMode">
        <view class="line-between">
          <view>
            <view class="mode-title">新建转交</view>
            <view class="mode-desc">只带客户和联系方式，你继续管理当前项目。</view>
          </view>
          <view class="status-badge {{transferMode === 'clone_seed' ? 'is-brand' : ''}}">新项目</view>
        </view>
        <view wx:if="{{transferMode === 'clone_seed'}}" class="transfer-selected-mark">✓</view>
      </view>
    </view>
    <view wx:if="{{transferMode === 'clone_seed'}}" class="field-group transfer-name-field">
      <view class="field-label">新项目名称</view>
      <input class="input-sim input-native" value="{{transferProjectName}}" bindinput="onTransferProjectNameInput" placeholder="请输入给对方的新项目名称" placeholder-class="input-placeholder" />
    </view>
    <view class="helper-text transfer-mode-note">新建转交不会同步当前项目历史，双方后续独立推进。</view>
    <view class="inline-actions transfer-mode-actions">
      <view class="btn-ghost" bindtap="closeTransferSheet">取消</view>
      <view class="btn-primary" bindtap="confirmTransferFlow">{{isTransferOpening ? '处理中...' : (transferMode === 'clone_seed' ? '新建转交' : '确认转交')}}</view>
    </view>
  </view>
</view>

<view wx:if="{{showTaskCompleteSheet}}">
  <view class="sheet-mask task-complete-mask" bindtap="closeTaskCompleteSheet"></view>
  <view class="sheet-panel task-complete-sheet {{appearancePageClass}} {{isTaskCompletionEditing ? 'is-editing' : ''}}" style="{{taskCompleteSheetStyle}}">
    <view class="sheet-handle"></view>
    <view class="sheet-header">
      <view class="sheet-title">完成：{{taskCompletionTaskTitle}}</view>
      <view class="sheet-close" bindtap="closeTaskCompleteSheet">关闭</view>
    </view>
    <view class="task-complete-body" style="{{taskCompleteBodyStyle}}">
      <view class="field-group task-complete-field">
        <view class="field-label">完成情况 · 提交后自动写入时间线</view>
        <textarea
          class="textarea-sim textarea-native task-complete-textarea"
          value="{{taskCompletionText}}"
          bindinput="onTaskCompletionInput"
          bindfocus="onTaskCompletionFieldFocus"
          cursor-spacing="{{taskCompletionCursorSpacing}}"
          placeholder="例如：报价已发送，客户确认本周三内部评审，若通过则进入合同沟通。"
          placeholder-class="input-placeholder"
          maxlength="-1"
        ></textarea>
        <view wx:if="{{isTaskCompletionVoiceSupported}}" class="task-complete-voice-row">
          <view class="btn-ghost task-complete-voice-btn {{isTaskCompletionVoiceRecording ? 'is-recording' : ''}} {{isTaskCompletionVoiceRecognizing ? 'is-busy' : ''}}" bindtap="handleTaskCompletionVoiceInput">
            <view class="voice-button-content">
              <view wx:if="{{isTaskCompletionVoiceRecording}}" class="voice-receiver">
                <view class="voice-receiver-bar is-one"></view>
                <view class="voice-receiver-bar is-two"></view>
                <view class="voice-receiver-bar is-three"></view>
                <view class="voice-receiver-bar is-four"></view>
              </view>
              <text class="voice-button-label">{{isTaskCompletionVoiceRecording ? '结束录音' : (isTaskCompletionVoiceRecognizing ? '识别中...' : '语音录入')}}</text>
              <text wx:if="{{isTaskCompletionVoiceRecording && taskCompletionVoiceElapsedText}}" class="voice-button-timer">{{taskCompletionVoiceElapsedText}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="task-complete-inline-entry">
        <view wx:if="{{!taskCompletionCreateNextTask}}" class="btn-ghost task-complete-inline-btn" bindtap="toggleTaskCompletionCreateNextTask">补下一步动作</view>
      </view>
      <view wx:if="{{taskCompletionCreateNextTask}}" class="task-complete-next-card">
        <view class="line-between task-complete-next-head">
          <view>
            <view class="task-complete-toggle-title">下一步任务</view>
          </view>
          <view class="section-link" bindtap="toggleTaskCompletionCreateNextTask">收起</view>
        </view>
        <view class="field-group task-complete-field is-inline-first">
          <input
            class="input-sim input-native primary-title-input task-complete-title-input"
            value="{{taskCompletionNextTaskTitle}}"
            data-field="taskCompletionNextTaskTitle"
            bindinput="onTaskCompletionNextTaskInput"
            bindfocus="onTaskCompletionFieldFocus"
            cursor-spacing="{{taskCompletionCursorSpacing}}"
            placeholder="填写下一步任务，例如：3天后回访报价反馈"
            placeholder-class="input-placeholder"
          />
        </view>
        <view class="field-group task-complete-field">
          <view class="field-label">任务类型</view>
          <view class="chips task-complete-type-wall">
            <view
              class="chip {{taskCompletionNextTaskType === item.type ? 'is-active' : ''}}"
              wx:for="{{nextTaskTemplates}}"
              wx:key="type"
              data-type="{{item.type}}"
              bindtap="setTaskCompletionNextTaskType"
            >{{item.label}}</view>
          </view>
        </view>
        <view class="field-group task-complete-field">
          <view class="field-label">下一步时间</view>
          <view class="split-row task-complete-time-row">
            <picker class="picker-block" mode="date" value="{{taskCompletionNextTaskDate}}" data-field="taskCompletionNextTaskDate" bindchange="onTaskCompletionNextTaskPicker">
              <view class="picker-sim">
                <view class="picker-value {{!taskCompletionNextTaskDate ? 'is-placeholder' : ''}}">{{taskCompletionNextTaskDate || '选择日期'}}</view>
              </view>
            </picker>
            <picker class="picker-block" mode="time" value="{{taskCompletionNextTaskTime}}" data-field="taskCompletionNextTaskTime" bindchange="onTaskCompletionNextTaskPicker">
              <view class="picker-sim">
                <view class="picker-value {{!taskCompletionNextTaskTime ? 'is-placeholder' : ''}}">{{taskCompletionNextTaskTime || '选择时间'}}</view>
              </view>
            </picker>
          </view>
        </view>
        <view class="field-group task-complete-field">
          <view class="field-label">动作说明</view>
          <textarea
            class="textarea-sim textarea-native task-complete-next-textarea"
            value="{{taskCompletionNextTaskDescription}}"
            data-field="taskCompletionNextTaskDescription"
            bindinput="onTaskCompletionNextTaskInput"
            bindfocus="onTaskCompletionFieldFocus"
            cursor-spacing="{{taskCompletionCursorSpacing}}"
            placeholder="可选：补一句下一步要重点确认什么。"
            placeholder-class="input-placeholder"
            maxlength="-1"
          ></textarea>
        </view>
      </view>
    </view>
    <view class="inline-actions task-complete-actions is-fixed {{isTaskCompletionEditing ? 'is-editing' : ''}}" style="{{taskCompleteActionsStyle}}">
      <view class="btn-ghost" bindtap="closeTaskCompleteSheet">取消</view>
      <view class="btn-primary" bindtap="submitTaskCompletion">{{taskActionId === taskCompletionTaskId ? '提交中...' : '确认完成'}}</view>
    </view>
  </view>
</view>
