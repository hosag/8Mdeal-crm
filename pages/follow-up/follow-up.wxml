<view class="page-shell follow-page {{appearancePageClass}}">
  <view class="hero">
    <view class="eyebrow-row">
      <view class="eyebrow">新增跟进</view>
    </view>
    <view class="hero-title">{{projectTitle}}</view>
    <view class="pill-row">
      <view class="chip">当前阶段 {{projectStage}}</view>
    </view>
    <view wx:if="{{entryHintText}}" class="helper-text">{{entryHintText}}</view>
  </view>

  <view wx:if="{{entitlementPrompt.visible}}" class="form-card section entitlement-banner is-{{entitlementPrompt.tone}}">
    <view class="entitlement-banner-title">{{entitlementPrompt.title}}</view>
    <view class="entitlement-banner-desc">{{entitlementPrompt.desc}}</view>
    <view wx:if="{{entitlementPrompt.actionText}}" class="entitlement-banner-action" bindtap="handleEntitlementPromptAction">{{entitlementPrompt.actionText}}</view>
  </view>

  <view class="form-card section follow-editor">
    <view class="editor-section editor-section-meta editor-section-meta-compact">
      <view class="editor-head">
        <view class="card-help-row">
          <view class="editor-title">跟进记录</view>
        </view>
        <view wx:if="{{draftUpdatedAt}}" class="editor-badge">已暂存</view>
      </view>

      <view class="record-meta-row">
        <picker class="record-meta-chip" mode="date" value="{{followUpDate}}" bindchange="onFollowUpDateInput">
          <view class="record-meta-chip-text">{{followUpDate}}</view>
        </picker>
        <picker class="record-meta-chip" mode="time" value="{{followUpClock}}" bindchange="onFollowUpClockInput">
          <view class="record-meta-chip-text">{{followUpClock}}</view>
        </picker>
        <view class="record-meta-chip {{currentMethod ? '' : 'is-muted'}}" bindtap="toggleMethodOptions">
          <view class="record-meta-chip-text">{{currentMethod || '待 AI 判断'}}</view>
        </view>
      </view>

      <view wx:if="{{showMethodOptions}}" class="chips editor-chip-wall method-chip-wall method-chip-grid">
        <view class="chip {{currentMethod === item ? 'is-active' : ''}}" wx:for="{{methods}}" wx:key="*this" data-method="{{item}}" bindtap="setMethod">{{item}}</view>
      </view>

      <view id="follow-up-content-field" class="field-group editor-field-group editor-field-group-compact content-inline-group">
        <textarea class="textarea-sim textarea-native editor-textarea editor-textarea-compact" value="{{content}}" bindinput="onContentInput" placeholder="记录本次沟通原话、客户反馈、报价或风险点。" placeholder-class="input-placeholder" maxlength="-1"></textarea>
        <view wx:if="{{voicePreviewText}}" class="voice-preview-card">
          <view class="voice-preview-label">本次识别</view>
          <view class="voice-preview-text">{{voicePreviewText}}</view>
        </view>
        <view class="content-action-row">
          <view class="btn-ghost content-action voice-entry-btn {{isVoiceSupported ? '' : 'is-disabled'}} {{isVoiceRecording ? 'is-recording' : ''}} {{isVoiceRecognizing ? 'is-busy' : ''}}" bindtap="handleVoiceInput">
            <view class="voice-button-content">
              <view wx:if="{{isVoiceRecording}}" class="voice-receiver">
                <view class="voice-receiver-bar is-one"></view>
                <view class="voice-receiver-bar is-two"></view>
                <view class="voice-receiver-bar is-three"></view>
                <view class="voice-receiver-bar is-four"></view>
              </view>
              <text class="voice-button-label">{{isVoiceRecording ? '结束录音' : (isVoiceRecognizing ? '识别中...' : '语音录入')}}</text>
              <text wx:if="{{isVoiceRecording && voiceRecordingElapsedText}}" class="voice-button-timer">{{voiceRecordingElapsedText}}</text>
            </view>
          </view>
          <view class="btn-secondary content-action ai-entry ai-entry-button {{isAiLoading ? 'is-loading' : ''}} {{(!content || isAiLoading) ? 'is-disabled' : ''}}" bindtap="handleAiSummary">
            <image wx:if="{{!isAiLoading}}" class="ai-entry-icon" src="/assets/icons/ai-agent-dark.svg" mode="aspectFit" />
            <view wx:else class="ai-agent-loader">
              <view class="ai-agent-loader-antenna is-left"><view class="ai-agent-loader-dot"></view></view>
              <view class="ai-agent-loader-antenna is-right"><view class="ai-agent-loader-dot"></view></view>
              <view class="ai-agent-loader-cap"></view>
              <view class="ai-agent-loader-ear is-left"></view>
              <view class="ai-agent-loader-ear is-right"></view>
              <view class="ai-agent-loader-head">
                <view class="ai-agent-loader-eye is-left"></view>
                <view class="ai-agent-loader-eye is-right"></view>
                <view class="ai-agent-loader-mouth"></view>
              </view>
            </view>
            <view class="ai-entry-text">{{isAiLoading ? 'AI整理中...' : 'AI整理'}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="editor-section">
      <view class="editor-head">
        <view class="card-help-row">
          <view class="editor-title">下一步动作</view>
        </view>
      </view>

      <view class="field-group editor-field-group editor-field-group-compact task-board-group">
        <view class="chips editor-chip-wall task-template-row">
          <view class="chip" wx:for="{{taskTemplates}}" wx:key="type" data-type="{{item.type}}" data-label="{{item.label}}" bindtap="addTaskTemplate">{{item.label}}</view>
        </view>
        <view wx:if="{{taskDrafts.length}}" class="task-draft-list">
          <view class="task-draft-card" wx:for="{{taskDrafts}}" wx:key="localId">
            <view class="line-between task-draft-head">
              <view class="soft-badge">{{item.typeLabel}}</view>
              <view class="sheet-close task-remove-btn" data-index="{{index}}" bindtap="removeTaskDraft">删除</view>
            </view>
            <input class="input-sim input-native task-title-input primary-title-input" value="{{item.title}}" data-index="{{index}}" data-field="title" bindinput="updateTaskDraftField" placeholder="填写下一步动作，例如：周五前发正式报价单" placeholder-class="input-placeholder" />
            <view class="split-row compact-split-row task-time-row">
              <picker class="picker-block compact-picker-block" mode="date" value="{{item.dueDate}}" data-index="{{index}}" data-field="dueDate" bindchange="updateTaskDraftPicker">
                <view class="picker-sim compact-picker-sim">
                  <view class="picker-value {{!item.dueDate ? 'is-placeholder' : ''}}">{{item.dueDate || '截止日期'}}</view>
                </view>
              </picker>
              <picker class="picker-block compact-picker-block" mode="time" value="{{item.dueTime}}" data-index="{{index}}" data-field="dueTime" bindchange="updateTaskDraftPicker">
                <view class="picker-sim compact-picker-sim">
                  <view class="picker-value {{!item.dueTime ? 'is-placeholder' : ''}}">{{item.dueTime || '截止时间'}}</view>
                </view>
              </picker>
            </view>
            <textarea class="textarea-sim textarea-native task-desc-input" value="{{item.description}}" data-index="{{index}}" data-field="description" bindinput="updateTaskDraftField" placeholder="可选：补一句动作说明，方便自己后续执行。" placeholder-class="input-placeholder" maxlength="-1"></textarea>
          </view>
        </view>
        <view class="task-add-row">
          <view class="btn-ghost task-add-btn" bindtap="addCustomTask">新增动作</view>
        </view>
      </view>
    </view>

    <view class="editor-section">
      <view class="editor-head">
        <view class="card-help-row">
          <view class="editor-title">附件</view>
        </view>
      </view>
      <view class="field-group editor-field-group editor-field-group-tight">
        <view wx:if="{{attachments.length}}" class="attachment-grid">
          <view class="attachment attachment-image" wx:for="{{attachments}}" wx:key="fileId">
            <image class="attachment-thumb" src="{{item.previewPath || item.tempFilePath || item.fileId}}" mode="aspectFill" />
            <view class="attachment-remove" data-index="{{index}}" bindtap="removeAttachment">删除</view>
            <view class="attachment-caption">{{item.name}}</view>
          </view>
        </view>
        <view class="attachment is-add attachment-trigger" bindtap="chooseImages">上传图片</view>
      </view>
    </view>

  </view>

  <view wx:if="{{aiError}}" class="form-card section">
    <view class="form-card-title">当前无法生成整理结果</view>
    <view class="form-card-desc">{{aiError}}</view>
  </view>

  <view class="bottom-space"></view>
</view>

<view class="footer-bar {{appearancePageClass}}">
  <view class="btn-ghost" bindtap="saveDraft">暂存草稿</view>
  <view class="btn-primary" bindtap="handleSave">{{isSaving ? '提交中...' : '提交跟进'}}</view>
</view>

<view wx:if="{{showAiDialog && aiResult}}">
  <view class="sheet-mask ai-sheet-mask" bindtap="closeAiDialog"></view>
  <view class="sheet-panel ai-sheet-panel {{appearancePageClass}}">
    <view class="sheet-handle"></view>
    <view class="follow-result-card">
      <view class="sheet-header result-sheet-header">
        <view class="result-sheet-header-main">
          <view class="card-help-row">
            <view class="sheet-title">整理结果</view>
            <view class="result-status-badge {{aiResult.isAdopted ? 'is-adopted' : 'is-pending'}}">{{aiResult.isAdopted ? '已采用' : '待采用'}}</view>
          </view>
          <view class="ai-origin-row">
            <view class="ai-origin-text">{{aiResult.sourceMetaText}}</view>
          </view>
        </view>
        <view wx:if="{{aiNextSuggestion.canApplyAll}}" class="btn-primary result-apply-all-btn" bindtap="applyAllAiSuggestions">全部采用</view>
        <view class="sheet-close" bindtap="closeAiDialog">关闭</view>
      </view>

      <view class="result-panel result-panel-summary">
        <view class="result-label">摘要</view>
        <view class="result-text">{{aiResult.summary}}</view>
      </view>

      <view class="result-panel" wx:if="{{aiResult.highlights.length}}">
        <view class="result-label">关键进展</view>
        <view class="checklist result-checklist">
          <view class="check-item" wx:for="{{aiResult.highlights}}" wx:key="*this">{{item}}</view>
        </view>
      </view>

      <view class="result-panel result-panel-risk" wx:if="{{aiResult.risks.length}}">
        <view class="result-label">风险提示</view>
        <view class="checklist result-checklist">
          <view class="check-item" wx:for="{{aiResult.risks}}" wx:key="*this">{{item}}</view>
        </view>
      </view>

      <view class="result-panel" wx:if="{{aiResult.showRecommendedStage}}">
        <view class="result-label">建议阶段</view>
        <view class="result-text">{{aiResult.recommendedStage}}</view>
        <view class="helper-text result-helper-text">{{aiResult.stageChangeReason}}</view>
      </view>

      <view class="result-panel" wx:if="{{aiResult.missingInfo.length}}">
        <view class="result-label">仍缺少的信息</view>
        <view class="checklist result-checklist">
          <view class="check-item" wx:for="{{aiResult.missingInfo}}" wx:key="*this">{{item}}</view>
        </view>
      </view>

      <view class="inline-actions follow-result-actions">
        <view class="btn-primary result-action-btn" bindtap="applyAiSummary">{{aiResult.isAdopted ? '已采用整理' : '采用整理'}}</view>
        <view class="btn-ghost result-action-btn ai-entry ai-entry-button {{isAiNextLoading ? 'is-loading' : ''}} {{(!aiResult || !aiResult.summary || isAiNextLoading) ? 'is-disabled' : ''}}" bindtap="handleAiNextSuggestion">
          <image wx:if="{{!isAiNextLoading}}" class="ai-entry-icon" src="/assets/icons/ai-agent-dark.svg" mode="aspectFit" />
          <view wx:else class="ai-agent-loader">
            <view class="ai-agent-loader-antenna is-left"><view class="ai-agent-loader-dot"></view></view>
            <view class="ai-agent-loader-antenna is-right"><view class="ai-agent-loader-dot"></view></view>
            <view class="ai-agent-loader-cap"></view>
            <view class="ai-agent-loader-ear is-left"></view>
            <view class="ai-agent-loader-ear is-right"></view>
            <view class="ai-agent-loader-head">
              <view class="ai-agent-loader-eye is-left"></view>
              <view class="ai-agent-loader-eye is-right"></view>
              <view class="ai-agent-loader-mouth"></view>
            </view>
          </view>
          <view class="ai-entry-text">{{isAiNextLoading ? (aiNextSuggestion ? '生成中...' : 'AI建议中...') : (aiNextSuggestion ? '重新生成' : 'AI建议下一步')}}</view>
        </view>
        <view wx:if="{{aiResultBackup}}" class="btn-ghost result-action-btn" bindtap="restoreAiSummaryVersion">恢复上一版</view>
      </view>
      <view wx:if="{{aiResult.isAdopted}}" class="helper-text result-adopted-text">当前跟进记录已采用本版整理。</view>

      <view class="result-panel result-panel-next">
        <view class="line-between result-panel-head">
          <view class="card-help-row">
            <view class="result-label">下一步建议</view>
          </view>
          <view wx:if="{{aiNextSuggestion && aiNextSuggestion.isAdopted}}" class="result-status-badge is-adopted">已采用</view>
        </view>

        <view wx:if="{{aiNextError}}" class="helper-text result-helper-text is-danger">{{aiNextError}}</view>

        <block wx:if="{{aiNextSuggestion}}">
          <view class="result-subpanel">
            <view class="result-sublabel">最优先动作</view>
            <view class="result-text">{{aiNextSuggestion.nextAction}}</view>
          </view>

          <view class="inline-actions follow-result-actions is-follow-up">
            <view class="btn-primary result-action-btn" bindtap="applyAiNextSuggestion">{{aiNextSuggestion.isAdopted ? '已采用动作' : '采用动作'}}</view>
          </view>
        </block>
      </view>
    </view>
  </view>
</view>
