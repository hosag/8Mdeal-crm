.follow-page {
  padding: 24rpx 24rpx 164rpx;
}

.follow-page .section {
  margin-top: 20rpx;
}

.follow-page .hero {
  padding: 28rpx 30rpx;
  border-radius: 30rpx;
}

.follow-page .hero-title {
  margin-top: 18rpx;
  font-size: 42rpx;
}

.follow-page .hero-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.55;
}

.follow-page .pill-row {
  margin-top: 14rpx;
}

.intro-card {
  padding: 24rpx 26rpx;
}

.intro-card .step-row {
  margin-top: 14rpx;
  gap: 10rpx;
}

.intro-card .step-pill {
  padding: 10rpx 16rpx;
  font-size: 21rpx;
}

.follow-editor {
  padding: 14rpx;
  background: var(--theme-state-card-bg);
  box-shadow: var(--theme-state-card-shadow);
}

.card-help-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-help-row-inline {
  justify-content: flex-start;
}

.help-trigger {
  flex: 0 0 auto;
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid var(--theme-divider);
  background: var(--theme-glass-bg);
  color: transparent;
  font-size: 0;
  box-sizing: border-box;
}

.help-trigger-small {
  width: 30rpx;
  height: 30rpx;
}

.help-trigger::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 12rpx;
  height: 2rpx;
  border-radius: 999rpx;
  background: var(--theme-text-muted);
  transform: translate(-50%, -50%);
  box-shadow: 0 -5rpx 0 var(--theme-text-muted), 0 5rpx 0 var(--theme-text-muted);
}

.help-trigger-small::before {
  width: 10rpx;
  box-shadow: 0 -4rpx 0 var(--theme-text-muted), 0 4rpx 0 var(--theme-text-muted);
}

.editor-section {
  padding: 20rpx;
  border-radius: 24rpx;
  background: var(--theme-glass-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.editor-section + .editor-section {
  margin-top: 14rpx;
}

.editor-section-meta {
  background: var(--theme-summary-bg);
}

.editor-section-meta-compact {
  padding: 16rpx 18rpx 18rpx;
}

.editor-section-meta-compact .editor-head {
  align-items: center;
  gap: 10rpx;
}

.editor-section-meta-compact .editor-title {
  font-size: 27rpx;
}

.editor-section-meta-compact .editor-badge {
  min-width: 88rpx;
  padding: 6rpx 12rpx;
  font-size: 18rpx;
}

.editor-section-highlight {
  background: var(--theme-state-card-bg);
  box-shadow: var(--theme-state-card-shadow);
}

.content-inline-group {
  margin-top: 12rpx;
}

.editor-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.editor-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--theme-title);
}

.editor-badge {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 100rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: var(--theme-brand-bg);
  color: var(--theme-brand-text);
  font-size: 20rpx;
  font-weight: 700;
}

.editor-field-group {
  margin-top: 18rpx;
}

.editor-field-group-compact {
  margin-top: 10rpx;
}

.editor-field-group-tight {
  margin-top: 14rpx;
}

.editor-chip-wall {
  gap: 10rpx;
}

.compact-split-row {
  gap: 12rpx;
}

.time-field-group {
  margin-top: 8rpx;
}

.compact-picker-block {
  min-width: 0;
}

.compact-picker-sim {
  min-height: 46rpx;
  padding: 5rpx 10rpx;
  border-radius: 12rpx;
}

.compact-picker-sim .picker-value {
  font-size: 22rpx;
  line-height: 1.2;
}

.editor-section-meta-compact .field-label {
  margin-bottom: 4rpx;
  font-size: 22rpx;
}

.editor-section-meta-compact .picker-sim {
  min-height: 72rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
}

.editor-section-meta-compact .compact-picker-sim {
  min-height: 46rpx;
  padding: 5rpx 10rpx;
  border-radius: 12rpx;
}


.method-chip-wall {
  margin-top: 6rpx;
  gap: 6rpx;
}

.method-chip-wall .chip {
  padding: 8rpx 14rpx;
  font-size: 22rpx;
}

.method-chip-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 6rpx;
  margin-top: 4rpx;
}

.method-chip-grid .chip {
  min-width: 0;
  margin-top: 0;
  padding: 6rpx 0;
  font-size: 20rpx;
  text-align: center;
  border-radius: 14rpx;
}

.editor-textarea {
  margin-top: 18rpx;
  min-height: 190rpx;
  background: var(--theme-glass-bg);
}

.editor-textarea-compact {
  margin-top: 10rpx;
  min-height: 160rpx;
}

.task-board-group {
  margin-top: 14rpx;
}

.task-template-row {
  margin-top: 8rpx;
  gap: 8rpx;
}

.task-draft-list {
  margin-top: 12rpx;
}

.task-draft-card {
  padding: 16rpx;
  border-radius: 20rpx;
  background: var(--theme-soft-block-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.task-draft-card + .task-draft-card {
  margin-top: 10rpx;
}

.task-draft-head {
  align-items: center;
  gap: 10rpx;
}

.task-remove-btn {
  font-size: 22rpx;
  color: var(--theme-text-muted);
}

.task-title-input {
  margin-top: 12rpx;
}

.task-time-row {
  margin-top: 10rpx;
}

.task-desc-input {
  min-height: 110rpx;
  margin-top: 10rpx;
  background: var(--theme-glass-bg);
}

.task-add-row {
  margin-top: 12rpx;
}

.task-add-btn {
  min-width: 220rpx;
}

.voice-entry-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 12rpx;
}

.voice-disabled-tip {
  margin-top: 12rpx;
}

.voice-entry-btn {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 168rpx;
  min-height: 64rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: var(--theme-button-secondary-bg);
  color: var(--theme-button-secondary-text);
  font-size: 22rpx;
  font-weight: 700;
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.voice-entry-btn.is-recording {
  background: var(--theme-danger-bg);
  color: var(--theme-danger-text);
  box-shadow: inset 0 0 0 2rpx var(--theme-danger-bg);
}

.voice-entry-btn.is-busy {
  color: var(--theme-text-soft);
  background: var(--theme-inline-bg);
}

.voice-entry-status {
  flex: 1 1 auto;
  min-width: 0;
  font-size: 21rpx;
  line-height: 1.6;
  color: var(--theme-text-soft);
}

.voice-entry-status.is-recording {
  color: var(--theme-danger-text);
}

.voice-preview-card {
  margin-top: 10rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: var(--theme-glass-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.voice-preview-label {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--theme-text-soft);
}

.voice-preview-text {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--theme-text-main);
}

.content-action-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 18rpx;
  margin-top: 14rpx;
}

.content-action {
  flex: 0 0 auto;
  min-width: 192rpx;
}

.follow-result-card {
  padding: 18rpx;
  border-radius: 30rpx;
  background: var(--theme-state-card-bg);
  box-shadow: var(--theme-state-card-shadow);
}

.result-sheet-header {
  align-items: flex-start;
  gap: 16rpx;
}

.result-sheet-header-main {
  flex: 1 1 auto;
  min-width: 0;
}

.result-status-badge {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 108rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--theme-success-bg);
  color: var(--theme-success-text);
  font-size: 21rpx;
  font-weight: 700;
}

.result-panel {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: var(--theme-glass-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.result-panel-summary {
  background: var(--theme-summary-bg);
  box-shadow: var(--theme-summary-shadow);
}

.result-panel-risk {
  background: var(--theme-danger-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-danger-bg);
}

.result-checklist {
  margin-top: 14rpx;
}

.result-helper-text {
  margin-top: 10rpx;
}

.result-helper-text.is-danger {
  color: var(--theme-danger-text);
}

.follow-result-actions {
  margin-top: 18rpx;
  gap: 16rpx;
}

.follow-result-actions .result-action-btn {
  flex: 1 1 0;
}

.follow-result-actions.is-follow-up {
  margin-top: 16rpx;
}

.result-action-btn {
  min-width: 0;
}

.result-panel-head {
  align-items: center;
}

.result-panel-next {
  background: var(--theme-soft-block-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.result-subpanel {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: var(--theme-glass-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.result-sublabel {
  font-size: 22rpx;
  color: var(--theme-text-soft);
}

.result-detail-grid {
  margin-top: 16rpx;
}

.result-task-list {
  margin-top: 12rpx;
}

.result-task-card {
  background: var(--theme-project-card-bg);
  box-shadow: var(--theme-project-card-shadow);
}

.result-task-card + .result-task-card {
  margin-top: 10rpx;
}

.task-draft-title {
  margin-top: 10rpx;
  font-size: 25rpx;
  font-weight: 700;
  color: var(--theme-title);
}

.result-task-desc {
  margin-top: 8rpx;
}

.ai-sheet-mask {
  z-index: 21;
  background: var(--theme-sheet-mask);
  backdrop-filter: blur(10rpx);
}

.ai-sheet-panel {
  z-index: 22;
  max-height: 72vh;
  overflow-y: auto;
  padding: 0 18rpx calc(34rpx + env(safe-area-inset-bottom));
  background: var(--theme-sheet-bg);
  box-shadow: var(--theme-sheet-shadow);
}

.ai-sheet-note {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.65;
  color: var(--theme-text-soft);
}

.ai-origin-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.ai-origin-row-inline {
  margin-top: 0;
  margin-bottom: 14rpx;
}

.ai-origin-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: var(--theme-brand-bg);
  color: var(--theme-brand-text);
  font-size: 20rpx;
  font-weight: 700;
}

.ai-origin-text {
  font-size: 21rpx;
  line-height: 1.55;
  color: var(--theme-text-soft);
}

.follow-page .field-label {
  margin-bottom: 8rpx;
}

.follow-page .input-sim,
.follow-page .textarea-sim,
.follow-page .picker-sim {
  padding: 18rpx 20rpx;
  min-height: 80rpx;
  border-radius: 20rpx;
  font-size: 25rpx;
}

.follow-page .textarea-sim,
.follow-page .textarea-native {
  min-height: 190rpx;
}

.follow-page .helper-text {
  font-size: 22rpx;
  line-height: 1.65;
}

.follow-page .attachment-grid {
  gap: 12rpx;
  margin-top: 14rpx;
}

.follow-page .attachment {
  height: 136rpx;
  border-radius: 20rpx;
}

.follow-page .attachment-trigger {
  margin-top: 12rpx;
}

.help-dialog {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 28rpx;
  border-radius: 30rpx;
  background: var(--theme-sheet-bg);
  box-shadow: var(--theme-sheet-shadow);
  z-index: 20;
}

.help-dialog-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.help-dialog-body {
  margin-top: 18rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: var(--theme-text-secondary);
}

.footer-bar.appearance-font-large .btn-primary,
.footer-bar.appearance-font-large .btn-ghost,
.help-dialog.appearance-font-large .sheet-title,
.ai-sheet-panel.appearance-font-large .sheet-title {
  font-size: 30rpx;
}

.help-dialog.appearance-font-large .sheet-close,
.ai-sheet-panel.appearance-font-large .sheet-close,
.help-dialog.appearance-font-large .help-dialog-body,
.ai-sheet-panel.appearance-font-large .ai-sheet-note,
.ai-sheet-panel.appearance-font-large .ai-origin-text,
.ai-sheet-panel.appearance-font-large .result-label,
.ai-sheet-panel.appearance-font-large .result-sublabel,
.ai-sheet-panel.appearance-font-large .helper-text {
  font-size: 26rpx;
}

.ai-sheet-panel.appearance-font-large .ai-origin-badge {
  font-size: 24rpx;
}

.ai-sheet-panel.appearance-font-large .result-text,
.ai-sheet-panel.appearance-font-large .task-draft-title {
  font-size: 28rpx;
}

.footer-bar.appearance-font-readable .btn-primary,
.footer-bar.appearance-font-readable .btn-ghost,
.help-dialog.appearance-font-readable .sheet-title,
.ai-sheet-panel.appearance-font-readable .sheet-title {
  font-size: 38rpx;
}

.help-dialog.appearance-font-readable .sheet-close,
.ai-sheet-panel.appearance-font-readable .sheet-close,
.help-dialog.appearance-font-readable .help-dialog-body,
.ai-sheet-panel.appearance-font-readable .ai-sheet-note,
.ai-sheet-panel.appearance-font-readable .ai-origin-text,
.ai-sheet-panel.appearance-font-readable .result-label,
.ai-sheet-panel.appearance-font-readable .result-sublabel,
.ai-sheet-panel.appearance-font-readable .helper-text {
  font-size: 34rpx;
}

.ai-sheet-panel.appearance-font-readable .ai-origin-badge {
  font-size: 30rpx;
}

.ai-sheet-panel.appearance-font-readable .result-text,
.ai-sheet-panel.appearance-font-readable .task-draft-title {
  font-size: 38rpx;
}
