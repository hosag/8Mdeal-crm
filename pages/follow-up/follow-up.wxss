.follow-page {
  padding: 24rpx 24rpx 164rpx;
}

.follow-page .section {
  margin-top: 20rpx;
}

.follow-page .hero {
  padding: 28rpx 30rpx;
  border-radius: 30rpx;
}

.follow-page .hero-title {
  margin-top: 18rpx;
  font-size: 42rpx;
}

.follow-page .entitlement-banner {
  position: relative;
  overflow: hidden;
  padding: 18rpx 20rpx 20rpx;
  border-radius: 24rpx;
  background: var(--theme-state-card-bg);
  box-shadow: var(--theme-state-card-shadow);
}

.follow-page .entitlement-banner::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  border-radius: 24rpx 0 0 24rpx;
  background: linear-gradient(180deg, rgba(160, 174, 189, 0.96) 0%, rgba(101, 118, 136, 0.96) 100%);
}

.follow-page .entitlement-banner.is-danger::before {
  background: linear-gradient(180deg, rgba(244, 162, 150, 0.98) 0%, rgba(214, 103, 90, 0.98) 100%);
}

.follow-page .entitlement-banner.is-soft::before {
  background: linear-gradient(180deg, rgba(244, 214, 145, 0.98) 0%, rgba(206, 163, 79, 0.98) 100%);
}

.follow-page .entitlement-banner.is-brand::before {
  background: linear-gradient(180deg, rgba(174, 209, 229, 0.98) 0%, rgba(92, 153, 190, 0.98) 100%);
}

.follow-page .entitlement-banner.is-neutral::before {
  background: linear-gradient(180deg, rgba(164, 179, 135, 0.98) 0%, rgba(111, 132, 95, 0.98) 100%);
}

.follow-page .entitlement-banner-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--theme-title);
}

.follow-page .entitlement-banner-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: var(--theme-text-soft);
}

.follow-page .entitlement-banner-action {
  margin-top: 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 62rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: var(--theme-hero-primary-bg);
  color: var(--theme-hero-primary-text);
  border: 1rpx solid var(--theme-hero-primary-border);
  box-shadow: var(--theme-hero-primary-shadow);
  font-size: 22rpx;
  font-weight: 700;
}

.follow-page .pill-row {
  margin-top: 14rpx;
}

.follow-editor {
  padding: 14rpx;
  background: var(--theme-state-card-bg);
  box-shadow: var(--theme-state-card-shadow);
}

.card-help-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-help-row-inline {
  justify-content: flex-start;
}

.editor-section {
  padding: 20rpx;
  border-radius: 24rpx;
  background: var(--theme-glass-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.editor-section + .editor-section {
  margin-top: 14rpx;
}

.editor-section-meta {
  background: var(--theme-summary-bg);
}

.editor-section-meta-compact {
  padding: 16rpx 18rpx 18rpx;
}

.editor-section-meta-compact .editor-head {
  align-items: center;
  gap: 10rpx;
}

.editor-section-meta-compact .editor-title {
  font-size: 27rpx;
}

.editor-section-meta-compact .editor-badge {
  min-width: 88rpx;
  padding: 6rpx 12rpx;
  font-size: 18rpx;
}

.record-meta-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}

.record-meta-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: var(--theme-chip-bg);
  color: var(--theme-chip-text);
  box-shadow: inset 0 0 0 1rpx rgba(24, 39, 51, 0.05);
}

.record-meta-chip.is-muted {
  color: var(--theme-text-soft);
}

.record-meta-chip-text {
  font-size: 21rpx;
  line-height: 1.2;
}

.editor-section-highlight {
  background: var(--theme-state-card-bg);
  box-shadow: var(--theme-state-card-shadow);
}

.content-inline-group {
  margin-top: 12rpx;
}

.editor-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.editor-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--theme-title);
}

.editor-badge {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 100rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: var(--theme-brand-bg);
  color: var(--theme-brand-text);
  font-size: 20rpx;
  font-weight: 700;
}

.editor-field-group {
  margin-top: 18rpx;
}

.editor-field-group-compact {
  margin-top: 10rpx;
}

.editor-field-group-tight {
  margin-top: 14rpx;
}

.editor-chip-wall {
  gap: 10rpx;
}

.compact-split-row {
  gap: 12rpx;
}

.time-field-group {
  margin-top: 8rpx;
}

.compact-picker-block {
  min-width: 0;
}

.compact-picker-sim {
  min-height: 46rpx;
  padding: 5rpx 10rpx;
  border-radius: 12rpx;
}

.compact-picker-sim .picker-value {
  font-size: 22rpx;
  line-height: 1.2;
}

.editor-section-meta-compact .field-label {
  margin-bottom: 4rpx;
  font-size: 22rpx;
}

.editor-section-meta-compact .picker-sim {
  min-height: 72rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
}

.editor-section-meta-compact .compact-picker-sim {
  min-height: 46rpx;
  padding: 5rpx 10rpx;
  border-radius: 12rpx;
}


.method-chip-wall {
  margin-top: 6rpx;
  gap: 6rpx;
}

.method-chip-wall .chip {
  padding: 8rpx 14rpx;
  font-size: 22rpx;
}

.method-chip-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 6rpx;
  margin-top: 10rpx;
}

.method-chip-grid .chip {
  min-width: 0;
  margin-top: 0;
  padding: 6rpx 0;
  font-size: 20rpx;
  text-align: center;
  border-radius: 14rpx;
}

.editor-textarea {
  margin-top: 18rpx;
  min-height: 190rpx;
  background: var(--theme-glass-bg);
}

.editor-textarea-compact {
  margin-top: 10rpx;
  min-height: 160rpx;
}

.task-board-group {
  margin-top: 10rpx;
}

.task-template-row {
  margin-top: 0;
  gap: 8rpx;
}

.task-draft-list {
  margin-top: 12rpx;
}

.task-draft-card {
  padding: 16rpx;
  border-radius: 20rpx;
  background: var(--theme-soft-block-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.task-draft-card + .task-draft-card {
  margin-top: 10rpx;
}

.task-draft-head {
  align-items: center;
  gap: 10rpx;
}

.task-remove-btn {
  font-size: 22rpx;
  color: var(--theme-text-muted);
}

.task-title-input {
  margin-top: 12rpx;
}

.primary-title-input {
  min-height: 76rpx;
  height: 76rpx;
  padding: 16rpx 22rpx;
  border-radius: 20rpx;
  background: var(--theme-card-bg);
  box-shadow:
    inset 0 0 0 2rpx rgba(23, 98, 96, 0.18),
    0 6rpx 14rpx rgba(24, 39, 51, 0.04);
  font-size: 26rpx;
  font-weight: 700;
  color: var(--theme-title);
  line-height: 44rpx;
}

.task-time-row {
  margin-top: 10rpx;
}

.task-desc-input {
  min-height: 110rpx;
  margin-top: 10rpx;
  background: var(--theme-glass-bg);
}

.task-add-row {
  margin-top: 12rpx;
}

.task-add-btn {
  min-width: 160rpx;
}

.next-action-meta-row {
  margin-top: 12rpx;
}

.voice-entry-btn {
  background: var(--theme-button-secondary-bg);
  color: var(--theme-button-secondary-text);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.voice-entry-btn.is-recording {
  background: var(--theme-danger-bg);
  color: var(--theme-danger-text);
  box-shadow: inset 0 0 0 2rpx var(--theme-danger-bg);
}

.voice-entry-btn.is-busy {
  color: var(--theme-text-soft);
  background: var(--theme-inline-bg);
}

.voice-preview-card {
  margin-top: 10rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: var(--theme-glass-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.voice-preview-label {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--theme-text-soft);
}

.voice-preview-text {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--theme-text-main);
}

.content-action-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 14rpx;
}

.content-action {
  flex: 1 1 0;
  min-width: auto;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: var(--theme-brand-bg);
  color: var(--theme-brand-text);
  box-shadow: inset 0 0 0 1rpx rgba(24, 39, 51, 0.06);
  font-size: 22rpx;
  font-weight: 700;
}

.content-action .ai-entry-icon,
.content-action .ai-agent-loader {
  width: 28rpx;
  height: 28rpx;
}

.content-action .ai-agent-loader {
  --ai-loader-size: 28rpx;
  --ai-loader-stroke: 3rpx;
}

.content-action .ai-entry-text {
  min-height: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
}

.follow-result-card {
  padding: 18rpx;
  border-radius: 30rpx;
  background: var(--theme-state-card-bg);
  box-shadow: var(--theme-state-card-shadow);
}

.result-sheet-header {
  align-items: flex-start;
  gap: 16rpx;
}

.result-sheet-header-main {
  flex: 1 1 auto;
  min-width: 0;
}

.result-status-badge {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 108rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--theme-success-bg);
  color: var(--theme-success-text);
  font-size: 21rpx;
  font-weight: 700;
}

.result-status-badge.is-pending {
  background: var(--theme-chip-bg);
  color: var(--theme-text-soft);
}

.result-status-badge.is-adopted {
  background: var(--theme-success-bg);
  color: var(--theme-success-text);
}

.result-panel {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: var(--theme-glass-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.result-panel-summary {
  background: var(--theme-summary-bg);
  box-shadow: var(--theme-summary-shadow);
}

.result-panel-risk {
  background: var(--theme-danger-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-danger-bg);
}

.result-checklist {
  margin-top: 14rpx;
}

.result-helper-text {
  margin-top: 10rpx;
}

.result-helper-text.is-danger {
  color: var(--theme-danger-text);
}

.result-adopted-text {
  margin-top: 10rpx;
  color: var(--theme-success-text);
}

.follow-result-actions {
  margin-top: 18rpx;
  gap: 16rpx;
}

.follow-result-actions .result-action-btn {
  flex: 1 1 0;
}

.result-apply-all-btn {
  flex: 0 0 auto;
  min-height: 56rpx;
  padding: 0 18rpx;
  font-size: 23rpx;
  white-space: nowrap;
}

.follow-result-actions.is-follow-up {
  margin-top: 16rpx;
}

.result-action-btn {
  min-width: 0;
}

.result-panel-head {
  align-items: center;
}

.result-panel-next {
  background: var(--theme-soft-block-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.result-subpanel {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: var(--theme-glass-bg);
  box-shadow: inset 0 0 0 2rpx var(--theme-divider);
}

.result-sublabel {
  font-size: 22rpx;
  color: var(--theme-text-soft);
}

.result-detail-grid {
  margin-top: 16rpx;
}

.result-task-list {
  margin-top: 12rpx;
}

.result-task-card {
  background: var(--theme-project-card-bg);
  box-shadow: var(--theme-project-card-shadow);
}

.result-task-card + .result-task-card {
  margin-top: 10rpx;
}

.task-draft-title {
  margin-top: 10rpx;
  font-size: 25rpx;
  font-weight: 700;
  color: var(--theme-title);
}

.result-task-desc {
  margin-top: 8rpx;
}

.ai-sheet-mask {
  z-index: 21;
  background: var(--theme-sheet-mask);
  backdrop-filter: blur(10rpx);
}

.ai-sheet-panel {
  z-index: 22;
  max-height: 72vh;
  overflow-y: auto;
  padding: 0 18rpx calc(34rpx + env(safe-area-inset-bottom));
  background: var(--theme-sheet-bg);
  box-shadow: var(--theme-sheet-shadow);
}

.ai-sheet-note {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.65;
  color: var(--theme-text-soft);
}

.ai-origin-row {
  display: flex;
  align-items: flex-start;
  margin-top: 12rpx;
}

.ai-origin-row-inline {
  margin-top: 0;
  margin-bottom: 14rpx;
}

.ai-origin-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: var(--theme-brand-bg);
  color: var(--theme-brand-text);
  font-size: 20rpx;
  font-weight: 700;
}

.ai-origin-text {
  font-size: 20rpx;
  line-height: 1.6;
  color: var(--theme-text-soft);
}

.follow-page .field-label {
  margin-bottom: 8rpx;
}

.follow-page .input-sim,
.follow-page .textarea-sim,
.follow-page .picker-sim {
  padding: 18rpx 20rpx;
  min-height: 80rpx;
  border-radius: 20rpx;
  font-size: 25rpx;
}

.follow-page .primary-title-input {
  min-height: 76rpx;
  height: 76rpx;
  padding: 16rpx 22rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.follow-page .textarea-sim,
.follow-page .textarea-native {
  min-height: 190rpx;
}

.follow-page .helper-text {
  font-size: 22rpx;
  line-height: 1.65;
}

.follow-page .attachment-grid {
  gap: 12rpx;
  margin-top: 14rpx;
}

.follow-page .attachment {
  height: 136rpx;
  border-radius: 20rpx;
}

.follow-page .attachment-trigger {
  margin-top: 12rpx;
}

.footer-bar.appearance-font-large .btn-primary,
.footer-bar.appearance-font-large .btn-ghost,
.ai-sheet-panel.appearance-font-large .sheet-title {
  font-size: 30rpx;
}

.ai-sheet-panel.appearance-font-large .sheet-close,
.ai-sheet-panel.appearance-font-large .ai-sheet-note,
.ai-sheet-panel.appearance-font-large .ai-origin-text,
.ai-sheet-panel.appearance-font-large .ai-generated-text,
.ai-sheet-panel.appearance-font-large .result-label,
.ai-sheet-panel.appearance-font-large .result-sublabel,
.ai-sheet-panel.appearance-font-large .helper-text {
  font-size: 26rpx;
}

.ai-sheet-panel.appearance-font-large .ai-origin-badge {
  font-size: 24rpx;
}

.ai-sheet-panel.appearance-font-large .result-text,
.ai-sheet-panel.appearance-font-large .task-draft-title {
  font-size: 28rpx;
}

.footer-bar.appearance-font-readable .btn-primary,
.footer-bar.appearance-font-readable .btn-ghost,
.ai-sheet-panel.appearance-font-readable .sheet-title {
  font-size: 38rpx;
}

.ai-sheet-panel.appearance-font-readable .sheet-close,
.ai-sheet-panel.appearance-font-readable .ai-sheet-note,
.ai-sheet-panel.appearance-font-readable .ai-origin-text,
.ai-sheet-panel.appearance-font-readable .ai-generated-text,
.ai-sheet-panel.appearance-font-readable .result-label,
.ai-sheet-panel.appearance-font-readable .result-sublabel,
.ai-sheet-panel.appearance-font-readable .helper-text {
  font-size: 34rpx;
}

.ai-sheet-panel.appearance-font-readable .ai-origin-badge {
  font-size: 30rpx;
}

.ai-sheet-panel.appearance-font-readable .result-text,
.ai-sheet-panel.appearance-font-readable .task-draft-title {
  font-size: 38rpx;
}
