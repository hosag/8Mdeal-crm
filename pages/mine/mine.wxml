<view class="page-shell mine-page {{appearancePageClass}}">
  <view class="custom-nav-spacer" style="height: {{tabNavigationSpacerHeight}}px;"></view>
  <view wx:if="{{isLoading}}" class="rise-in">
    <loading-panel rows="2" appearance-page-class="{{appearancePageClass}}" />
  </view>

  <block wx:else>
    <view class="hero rise-in mine-hero">
      <view class="mine-hero-profile" bindtap="openDisplayNameSheet">
        <view class="mine-hero-avatar">{{heroAvatarText}}</view>
        <view class="mine-hero-profile-main">
          <view class="hero-title">{{heroTitle}}</view>
          <view class="hero-subtitle">{{heroSubtitle}}</view>
        </view>
      </view>
    </view>

    <view class="surface-card section mine-access-card rise-in stagger-1">
      <view class="section-title mine-section-title">账户与权益</view>
      <view wx:if="{{isAccessLoading}}" class="menu-caption mine-access-loading">正在同步账户状态...</view>
      <view wx:else class="mine-access-grid">
        <view class="mine-access-item" wx:for="{{accountAccessRows}}" wx:key="key">
          <view class="mine-access-label">{{item.label}}</view>
          <view class="mine-access-value">{{item.value}}</view>
        </view>
      </view>
      <view class="mine-access-notice">{{accountAccessNotice}}</view>
      <view class="hero-actions mine-access-actions">
        <view class="btn-secondary mine-access-action" bindtap="openPlansPage">套餐与加购</view>
        <view wx:if="{{!accountSummary.phoneVerified}}" class="btn-ghost mine-access-action" bindtap="openPhoneBindPage">绑定手机号</view>
        <view wx:else class="btn-ghost mine-access-action" bindtap="openEntitlementsPage">权益详情</view>
      </view>
    </view>

    <view class="surface-card section mine-overview-card rise-in stagger-3">
      <view class="line-between mine-section-head">
        <view>
          <view class="section-title mine-section-title">本月概览</view>
        </view>
      </view>
      <view class="mine-overview-grid">
        <view class="mine-overview-metric" wx:for="{{overviewMetrics}}" wx:key="label">
          <view class="metric-label">{{item.label}}</view>
          <view class="metric-value">{{item.value}}</view>
        </view>
      </view>
    </view>

    <view class="section mine-entry-grid rise-in stagger-4">
      <view class="nav-card mine-entry-card" data-url="/pages/referral/referral" bindtap="openPage">
        <view class="line-between mine-entry-head">
          <view class="mine-entry-main">
            <view class="card-title">推荐朋友</view>
            <view class="card-subtitle">朋友创建第一个项目后，双方各得 10 万 AI 额度</view>
          </view>
          <view class="section-link">进入</view>
        </view>
      </view>

      <view class="nav-card mine-entry-card" data-url="/pages/feedback/feedback" bindtap="openPage">
        <view class="line-between mine-entry-head">
          <view class="mine-entry-main">
            <view class="card-title">反馈与建议</view>
            <view class="card-subtitle">提交问题、需求或使用想法，获得平台百万AI额度奖励</view>
          </view>
          <view class="section-link">进入</view>
        </view>
      </view>

      <view class="nav-card mine-entry-card" data-url="/pages/earnings/earnings" bindtap="openPage">
        <view class="line-between mine-entry-head">
          <view class="mine-entry-main">
            <view class="card-title">收益统计</view>
            <view class="card-subtitle">查看成交与回款。</view>
          </view>
          <view class="section-link">进入</view>
        </view>
      </view>

      <view class="nav-card mine-entry-card" data-url="/pages/contacts/contacts" bindtap="openPage">
        <view class="line-between mine-entry-head">
          <view class="mine-entry-main">
            <view class="card-title">关键联系人</view>
            <view class="card-subtitle">从关键人切入看最近沟通与关联项目。</view>
          </view>
          <view class="section-link">进入</view>
        </view>
      </view>

      <view class="nav-card mine-entry-card" data-url="/pages/privacy-tags/privacy-tags" bindtap="openPage">
        <view class="line-between mine-entry-head">
          <view class="mine-entry-main">
            <view class="card-title">隐私标签</view>
            <view class="card-subtitle">管理默认分享范围。</view>
          </view>
          <view class="section-link">进入</view>
        </view>
      </view>
    </view>

    <view class="surface-card section mine-settings-card rise-in stagger-5">
      <view class="section-title mine-section-title">账户与偏好</view>

      <view class="mine-setting-group">
        <view class="mine-group-title">站内提醒</view>

        <view class="mine-reminder-card">
          <view class="menu-row reminder-menu-row mine-reminder-row">
            <view class="menu-main">
              <view class="menu-title-row">
                <view>项目回看提醒</view>
                <view wx:if="{{preferenceSavingKey === 'followUpEnabled'}}" class="menu-saving-text">保存中</view>
              </view>
              <view class="menu-caption">控制较久未推进项目的弱提醒。</view>
            </view>
            <switch
              color="#355d76"
              checked="{{reminderSettings.followUpEnabled}}"
              data-field="followUpEnabled"
              bindchange="onReminderToggleChange"
            />
          </view>
        </view>

        <view class="mine-reminder-card">
          <view class="menu-row reminder-menu-row mine-reminder-row">
            <view class="menu-main">
              <view class="menu-title-row">
                <view>任务提醒</view>
                <view wx:if="{{preferenceSavingKey === 'taskEnabled' || preferenceSavingKey === 'taskAdvance'}}" class="menu-saving-text">保存中</view>
              </view>
              <view class="menu-caption">控制推进任务的到期与逾期提醒。</view>
            </view>
            <switch
              color="#355d76"
              checked="{{reminderSettings.taskEnabled}}"
              data-field="taskEnabled"
              bindchange="onReminderToggleChange"
            />
          </view>
          <view class="reminder-option-row mine-reminder-option-row">
            <view class="menu-caption">提醒时间</view>
            <view class="pill-row reminder-pill-row mine-reminder-pill-row">
              <view
                wx:for="{{reminderAdvanceOptions}}"
                wx:key="key"
                class="chip mine-reminder-chip {{reminderSettings.taskAdvance === item.key ? 'is-active' : ''}} {{!reminderSettings.taskEnabled ? 'is-disabled' : ''}}"
                data-field="taskAdvance"
                data-value="{{item.key}}"
                bindtap="onReminderAdvanceTap"
              >{{item.label}}</view>
            </view>
          </view>
        </view>
      </view>

      <view class="mine-setting-group">
        <view class="mine-group-title">外观</view>
        <view class="mine-font-card mine-theme-card">
          <view class="line-between mine-font-head">
            <view>
              <view class="field-label mine-font-title">视觉主题</view>
              <view class="menu-caption">当前使用 {{currentThemeLabel}}</view>
            </view>
            <view wx:if="{{preferenceSavingKey === 'themeKey'}}" class="menu-saving-text">保存中</view>
          </view>
          <view class="mine-theme-grid">
            <view
              wx:for="{{themeOptions}}"
              wx:key="key"
              class="mine-theme-option {{item.isActive ? 'is-active' : ''}} {{item.isDisabled ? 'is-disabled' : ''}}"
              data-theme="{{item.key}}"
              bindtap="onThemeTap"
            >
              <view class="mine-theme-preview mine-theme-preview-{{item.key}}">
                <view class="mine-theme-preview-badge"></view>
                <view class="mine-theme-preview-bars">
                  <view class="mine-theme-preview-bar is-strong"></view>
                  <view class="mine-theme-preview-bar"></view>
                </view>
                <view class="mine-theme-preview-pills">
                  <view class="mine-theme-preview-pill"></view>
                  <view class="mine-theme-preview-pill is-active"></view>
                  <view class="mine-theme-preview-pill"></view>
                </view>
              </view>
              <view class="mine-theme-copy">
                <view class="mine-theme-label">{{item.label}}</view>
                <view class="mine-theme-desc">{{item.desc}}</view>
              </view>
            </view>
          </view>
        </view>
        <view class="mine-font-card">
          <view class="line-between mine-font-head">
            <view>
              <view class="field-label mine-font-title">字体与阅读</view>
              <view class="menu-caption">按你的阅读习惯调整字号与控件密度。</view>
            </view>
            <view wx:if="{{preferenceSavingKey === 'fontScaleMode'}}" class="menu-saving-text">保存中</view>
          </view>
          <view class="pill-row mine-font-pill-row">
            <view
              wx:for="{{fontScaleOptions}}"
              wx:key="key"
              class="chip mine-font-chip {{appearanceSettings.fontScaleMode === item.key ? 'is-active' : ''}} {{preferenceSavingKey === 'fontScaleMode' ? 'is-disabled' : ''}}"
              data-mode="{{item.key}}"
              bindtap="onFontScaleModeTap"
            >{{item.label}}</view>
          </view>
        </view>
      </view>

      <view class="mine-setting-group mine-security-group">
        <view class="mine-group-title">账号安全</view>
        <view class="mine-signout-card">
          <view class="mine-signout-copy">
            <view class="mine-signout-title">退出当前账号</view>
            <view class="mine-signout-desc">清除本机账号状态和页面缓存，云端项目数据不会删除。</view>
          </view>
          <view class="mine-signout-action {{isSigningOut ? 'is-disabled' : ''}}" bindtap="handleSignOutTap">{{isSigningOut ? '退出中' : '退出'}}</view>
        </view>
      </view>
    </view>
  </block>
</view>

<block wx:if="{{showDisplayNameSheet}}">
  <view class="sheet-mask" bindtap="closeDisplayNameSheet"></view>
  <view class="sheet-panel mine-name-sheet {{appearancePageClass}}">
    <view class="sheet-handle"></view>
    <view class="sheet-header">
      <view class="sheet-title">显示名称</view>
      <view class="sheet-close" bindtap="closeDisplayNameSheet">关闭</view>
    </view>
    <view class="mine-name-sheet-body">
      <view class="mine-name-sheet-meta">
        <view class="mine-access-label">当前显示</view>
        <view class="mine-access-value">{{accountSummary.displayName || accountSummary.phoneMasked || '未设置'}}</view>
      </view>
      <view class="mine-name-sheet-meta">
        <view class="mine-access-label">微信昵称</view>
        <view class="mine-access-value">{{wechatNicknameText}}</view>
      </view>
      <view class="mine-name-form">
        <input
          class="mine-name-input"
          maxlength="24"
          placeholder="输入显示名称，留空则恢复默认"
          value="{{displayNameInput}}"
          bindinput="onDisplayNameInput"
        />
        <view class="menu-caption mine-name-tip">留空则使用微信昵称或账号信息。</view>
      </view>
      <view class="hero-actions mine-access-actions mine-name-sheet-actions">
        <view class="btn-secondary mine-access-action" bindtap="saveDisplayName">{{preferenceSavingKey === 'customDisplayName' ? '保存中...' : '保存'}}</view>
        <view class="btn-ghost mine-access-action" bindtap="resetDisplayName">恢复默认</view>
      </view>
    </view>
  </view>
</block>
