<view class="page-shell mine-page {{appearancePageClass}}">
  <view wx:if="{{isLoading}}" class="rise-in">
    <loading-panel rows="2" appearance-page-class="{{appearancePageClass}}" />
  </view>

  <block wx:else>
    <view class="hero rise-in mine-hero">
      <view class="eyebrow-row">
        <view class="eyebrow">我的</view>
        <view class="source-badge">{{dataSource}}</view>
      </view>
      <view class="hero-title">账户与偏好</view>
      <view class="hero-subtitle">收益、标签和偏好集中管理。</view>
    </view>

    <view class="surface-card section mine-overview-card rise-in stagger-1">
      <view class="line-between mine-section-head">
        <view>
          <view class="section-title mine-section-title">本月概览</view>
        </view>
        <view class="section-link" data-url="/pages/earnings/earnings" bindtap="openPage">明细</view>
      </view>
      <view class="mine-overview-grid">
        <view class="mine-overview-metric" wx:for="{{overviewMetrics}}" wx:key="label">
          <view class="metric-label">{{item.label}}</view>
          <view class="metric-value">{{item.value}}</view>
        </view>
      </view>
    </view>

    <view class="section mine-entry-grid rise-in stagger-2">
      <view class="nav-card mine-entry-card" data-url="/pages/earnings/earnings" bindtap="openPage">
        <view class="line-between mine-entry-head">
          <view class="mine-entry-main">
            <view class="card-title">收益统计</view>
            <view class="card-subtitle">查看成交与回款。</view>
          </view>
          <view class="section-link">进入</view>
        </view>
      </view>

      <view class="nav-card mine-entry-card" data-url="/pages/privacy-tags/privacy-tags" bindtap="openPage">
        <view class="line-between mine-entry-head">
          <view class="mine-entry-main">
            <view class="card-title">隐私标签</view>
            <view class="card-subtitle">管理默认分享范围。</view>
          </view>
          <view class="section-link">进入</view>
        </view>
      </view>
    </view>

    <view class="surface-card section mine-settings-card rise-in stagger-3">
      <view class="section-title mine-section-title">账户与偏好</view>

      <view class="mine-setting-group">
        <view class="mine-group-title">云环境</view>
        <view class="menu-row mine-plain-row">
          <view class="menu-main">
            <view>云开发环境</view>
            <view class="menu-caption">{{cloudEnvCaption}}</view>
          </view>
          <view class="section-link">{{cloudEnvLabel}}</view>
        </view>
      </view>

      <view class="mine-setting-group">
        <view class="mine-group-title">站内提醒</view>

        <view class="mine-reminder-card">
          <view class="menu-row reminder-menu-row mine-reminder-row">
            <view class="menu-main">
              <view class="menu-title-row">
                <view>跟进提醒</view>
                <view wx:if="{{preferenceSavingKey === 'followUpEnabled' || preferenceSavingKey === 'followUpAdvance'}}" class="menu-saving-text">保存中</view>
              </view>
              <view class="menu-caption">控制项目下次跟进提醒。</view>
            </view>
            <switch
              color="#355d76"
              checked="{{reminderSettings.followUpEnabled}}"
              data-field="followUpEnabled"
              bindchange="onReminderToggleChange"
            />
          </view>
          <view class="reminder-option-row mine-reminder-option-row">
            <view class="menu-caption">提醒时间</view>
            <view class="pill-row reminder-pill-row mine-reminder-pill-row">
              <view
                wx:for="{{reminderAdvanceOptions}}"
                wx:key="key"
                class="chip mine-reminder-chip {{reminderSettings.followUpAdvance === item.key ? 'is-active' : ''}} {{!reminderSettings.followUpEnabled ? 'is-disabled' : ''}}"
                data-field="followUpAdvance"
                data-value="{{item.key}}"
                bindtap="onReminderAdvanceTap"
              >{{item.label}}</view>
            </view>
          </view>
        </view>

        <view class="mine-reminder-card">
          <view class="menu-row reminder-menu-row mine-reminder-row">
            <view class="menu-main">
              <view class="menu-title-row">
                <view>任务提醒</view>
                <view wx:if="{{preferenceSavingKey === 'taskEnabled' || preferenceSavingKey === 'taskAdvance'}}" class="menu-saving-text">保存中</view>
              </view>
              <view class="menu-caption">控制推进任务的到期与逾期提醒。</view>
            </view>
            <switch
              color="#355d76"
              checked="{{reminderSettings.taskEnabled}}"
              data-field="taskEnabled"
              bindchange="onReminderToggleChange"
            />
          </view>
          <view class="reminder-option-row mine-reminder-option-row">
            <view class="menu-caption">提醒时间</view>
            <view class="pill-row reminder-pill-row mine-reminder-pill-row">
              <view
                wx:for="{{reminderAdvanceOptions}}"
                wx:key="key"
                class="chip mine-reminder-chip {{reminderSettings.taskAdvance === item.key ? 'is-active' : ''}} {{!reminderSettings.taskEnabled ? 'is-disabled' : ''}}"
                data-field="taskAdvance"
                data-value="{{item.key}}"
                bindtap="onReminderAdvanceTap"
              >{{item.label}}</view>
            </view>
          </view>
        </view>
      </view>

      <view class="mine-setting-group">
        <view class="mine-group-title">外观</view>
        <view class="mine-font-card mine-theme-card">
          <view class="line-between mine-font-head">
            <view>
              <view class="field-label mine-font-title">视觉主题</view>
              <view class="menu-caption">当前使用 {{currentThemeLabel}}</view>
            </view>
            <view wx:if="{{preferenceSavingKey === 'themeKey'}}" class="menu-saving-text">保存中</view>
          </view>
          <view class="mine-theme-grid">
            <view
              wx:for="{{themeOptions}}"
              wx:key="key"
              class="mine-theme-option {{item.isActive ? 'is-active' : ''}} {{item.isDisabled ? 'is-disabled' : ''}}"
              data-theme="{{item.key}}"
              bindtap="onThemeTap"
            >
              <view class="mine-theme-preview mine-theme-preview-{{item.key}}">
                <view class="mine-theme-preview-badge"></view>
                <view class="mine-theme-preview-bars">
                  <view class="mine-theme-preview-bar is-strong"></view>
                  <view class="mine-theme-preview-bar"></view>
                </view>
                <view class="mine-theme-preview-pills">
                  <view class="mine-theme-preview-pill"></view>
                  <view class="mine-theme-preview-pill is-active"></view>
                  <view class="mine-theme-preview-pill"></view>
                </view>
              </view>
              <view class="mine-theme-copy">
                <view class="mine-theme-label">{{item.label}}</view>
                <view class="mine-theme-desc">{{item.desc}}</view>
              </view>
            </view>
          </view>
        </view>
        <view class="mine-font-card">
          <view class="line-between mine-font-head">
            <view>
              <view class="field-label mine-font-title">字体与阅读</view>
              <view class="menu-caption">按你的阅读习惯调整字号与控件密度。</view>
            </view>
            <view wx:if="{{preferenceSavingKey === 'fontScaleMode'}}" class="menu-saving-text">保存中</view>
          </view>
          <view class="pill-row mine-font-pill-row">
            <view
              wx:for="{{fontScaleOptions}}"
              wx:key="key"
              class="chip mine-font-chip {{appearanceSettings.fontScaleMode === item.key ? 'is-active' : ''}} {{preferenceSavingKey === 'fontScaleMode' ? 'is-disabled' : ''}}"
              data-mode="{{item.key}}"
              bindtap="onFontScaleModeTap"
            >{{item.label}}</view>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>

<bottom-nav current="mine" appearance-page-class="{{appearancePageClass}}" />
