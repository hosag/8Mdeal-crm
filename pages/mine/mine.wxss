.menu-row.reminder-menu-row {
  align-items: flex-start;
  gap: 24rpx;
}

.menu-main {
  flex: 1 1 auto;
  min-width: 0;
}

.menu-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.menu-saving-text {
  font-size: 22rpx;
  color: #8a6d52;
}

.reminder-option-row {
  padding: 8rpx 0 22rpx;
  border-bottom: 1rpx solid rgba(24, 39, 51, 0.08);
}

.reminder-option-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.reminder-pill-row {
  margin-top: 12rpx;
}

.chip.is-disabled {
  opacity: 0.42;
}
