<view class="page-shell home-page {{appearancePageClass}}">
  <view wx:if="{{isLoading}}" class="rise-in">
    <loading-panel rows="2" appearance-page-class="{{appearancePageClass}}" />
  </view>

  <block wx:else>
    <view class="hero rise-in">
      <view class="hero-top-actions">
        <view class="home-avatar-entry" bindtap="openMinePage">{{homeAvatarText}}</view>
        <view class="notify-entry" bindtap="openNotificationsPage">
          <view class="notify-entry-text">消息中心</view>
          <view wx:if="{{notificationUnreadCount}}" class="notify-entry-count">{{notificationUnreadCount > 99 ? '99+' : notificationUnreadCount}}</view>
        </view>
      </view>
      <view class="brand-lockup">
        <view class="brand-lockup-logo-shell">
          <image class="brand-lockup-image" src="/assets/brand/logo-home-export-4-transparent-cropped.png" mode="aspectFit" />
        </view>
        <view class="brand-lockup-slogan {{homeSloganFontLoaded ? 'is-custom-title-font' : ''}}">
          <view class="brand-lockup-slogan-bottom">
            <text class="brand-lockup-slogan-emphasis {{homeSloganFontLoaded ? 'is-custom-title-font' : ''}}">私人CRM</text>
            <text class="brand-lockup-slogan-tail">引擎</text>
          </view>
        </view>
      </view>
      <view class="hero-heading">
        <view class="hero-heading-meta">
          <view class="hero-heading-kicker">今日优先</view>
          <view class="hero-heading-rule"></view>
        </view>
        <view class="hero-title">今天先处理 <text class="hero-title-emphasis">{{dashboard.taskBoard.summary.openCount || 0}} 条</text>推进动作</view>
        <view class="hero-subtitle">把项目全局、推进动作和关键动态都收进八面成交，先看动作，再看项目，判断会更快。</view>
      </view>
      <view class="hero-message-strip {{notificationHeadlineToneClass}}" bindtap="openHeadlineNotification">
        <view class="hero-message-copy">
          <view class="hero-message-topline">
            <view class="hero-message-badge">{{notificationHeadlineBadgeText}}</view>
            <view wx:if="{{notificationHeadlineProjectName}}" class="hero-message-project">{{notificationHeadlineProjectName}}</view>
          </view>
          <view class="hero-message-title">{{notificationHeadlineTitle}}</view>
          <view class="hero-message-desc">{{notificationHeadlineDesc}}</view>
        </view>
        <view class="hero-message-action">{{notificationHeadlineActionText}}</view>
      </view>
      <view class="hero-actions">
        <view class="btn-secondary hero-primary-btn" data-url="/pages/project-form/project-form" bindtap="openPage">新建项目</view>
        <view class="btn-ghost hero-secondary-btn" data-url="/pages/projects/projects" bindtap="openPage">我的项目</view>
      </view>
      <view class="pill-row hero-quick-pills">
        <view class="field-pill" data-filter="open" data-sort="priority" bindtap="openTasksCenter">查看推进任务</view>
        <view class="field-pill" data-filter="overdue" data-sort="priority" bindtap="openTasksCenter">查看逾期动作</view>
        <view class="field-pill" data-quick-filter="shared" data-sort-mode="updated" data-source="home-shared" bindtap="openProjectsWithFilter">查看我接手的</view>
      </view>
      <view class="hero-metrics section hero-metrics-compact">
        <view class="metric-card" wx:for="{{dashboard.metrics}}" wx:key="label">
          <view class="metric-label">{{item.label}}</view>
          <view class="metric-value">{{item.value}}</view>
          <view class="metric-note">{{item.note}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{homeAccessCard.visible}}" class="form-card section home-access-card rise-in stagger-1">
      <view class="home-access-head">
        <view class="home-access-title-wrap">
          <view class="section-title">{{homeAccessCard.title}}</view>
        </view>
        <view wx:if="{{homeAccessCard.actionText}}" class="home-access-action" bindtap="handleHomeAccessAction">{{homeAccessCard.actionText}}</view>
      </view>
      <view wx:if="{{homeAccessCard.desc}}" class="card-subtitle home-access-desc">{{homeAccessCard.desc}}</view>
      <view class="home-access-grid">
        <view class="home-access-item" wx:for="{{homeAccessCard.rows}}" wx:key="key">
          <view class="home-access-label">{{item.label}}</view>
          <view class="home-access-value">{{item.value}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{isLoadFailed}}" class="form-card section state-card rise-in stagger-1">
      <view class="form-card-title">当前无法同步云端数据</view>
      <view class="form-card-desc">{{loadError}}</view>
      <view class="hero-actions state-actions">
        <view class="btn-primary state-btn" bindtap="retryFetch">重新加载</view>
        <view class="btn-ghost state-btn" bindtap="openProjectsPage">查看我的项目</view>
      </view>
    </view>

    <view class="section rise-in stagger-1">
      <view class="section-header">
        <view class="section-title">推进动作优先</view>
        <view class="section-link" data-filter="open" data-sort="priority" bindtap="openTasksCenter">查看全部</view>
      </view>
      <view class="task-summary-strip">
        <view class="task-summary-item">
          <view class="task-summary-value">{{dashboard.taskBoard.summary.openCount || 0}}</view>
          <view class="task-summary-label">未完成</view>
        </view>
        <view class="task-summary-item">
          <view class="task-summary-value is-danger">{{dashboard.taskBoard.summary.overdueCount || 0}}</view>
          <view class="task-summary-label">逾期</view>
        </view>
        <view class="task-summary-item">
          <view class="task-summary-value is-brand">{{dashboard.taskBoard.summary.todayCount || 0}}</view>
          <view class="task-summary-label">今日</view>
        </view>
      </view>

      <view wx:if="{{taskFeedback.title}}" class="task-feedback-banner">
        <view class="task-feedback-main">
          <view class="task-feedback-title">{{taskFeedback.title}}</view>
          <view class="task-feedback-detail">{{taskFeedback.detail}}</view>
        </view>
        <view class="task-feedback-dismiss" bindtap="dismissTaskFeedback">收起</view>
      </view>

      <view class="task-priority-card" wx:for="{{dashboard.taskBoard.cards}}" wx:key="id">
        <view class="task-priority-main">
          <view class="task-priority-copy">
            <view class="task-priority-head" data-project-id="{{item.projectId}}" bindtap="openTaskProjectDetail">
              <view class="status-badge {{item.urgencyBadgeClass}} task-urgency-badge">{{item.urgencyText}}</view>
              <view class="task-priority-project">{{item.projectName}}</view>
            </view>
            <view class="project-name task-title">{{item.title}}</view>
            <view class="project-client task-project-link" data-project-id="{{item.projectId}}" bindtap="openTaskProjectDetail">
              {{item.clientName}} · {{item.stage}}
            </view>
            <view wx:if="{{item.focusText}}" class="task-focus-line">{{item.focusText}}</view>
          </view>
          <view class="task-priority-side">
            <view class="task-due-text">{{item.dueText}}</view>
            <view class="btn-primary task-complete-action" data-task-id="{{item.id}}" bindtap="openTaskCompleteSheet">去完成</view>
          </view>
        </view>
      </view>

      <empty-state
        wx:if="{{!dashboard.taskBoard.cards.length}}"
        appearance-page-class="{{appearancePageClass}}"
        title="暂无推进动作"
        desc="补充推进任务后，会自动显示在这里。"
        image="/assets/illustrations/empty-projects.svg"
        actionText="查看我的项目"
        bind:action="openProjectsPage"
      />
    </view>

    <view class="section rise-in stagger-2">
      <view class="section-header">
        <view class="section-title">动态时间线</view>
      </view>
      <view class="glass-card">
        <view class="timeline-group" wx:for="{{dashboard.timeline}}" wx:key="date">
          <view class="timeline-group-title">{{item.date}}</view>
          <view class="timeline-item" wx:for="{{item.items}}" wx:key="key" data-project-id="{{item.projectId}}" bindtap="openTimelineProject">
            <view class="timeline-axis">
              <view class="timeline-dot"></view>
              <view class="timeline-line"></view>
            </view>
            <view class="timeline-body">
              <view class="timeline-time">{{item.time}}</view>
              <view class="timeline-title">{{item.title}}</view>
              <view class="timeline-desc">{{item.desc}}</view>
              <view class="helper-text" wx:if="{{item.projectId}}">点击可查看该项目完整上下文</view>
            </view>
          </view>
        </view>
      </view>
      <empty-state
        wx:if="{{!dashboard.timeline.length}}"
        appearance-page-class="{{appearancePageClass}}"
        title="暂无最新动态"
        desc="新建项目、录入跟进或完成任务后，会自动显示在这里。"
        image="/assets/illustrations/empty-projects.svg"
        actionText="新建项目"
        bind:action="openProjectForm"
      />
    </view>
  </block>
</view>

<view wx:if="{{showQuickEntrySheet}}">
  <view class="sheet-mask quick-entry-mask" bindtap="onQuickEntryMaskTap"></view>
  <view class="sheet-panel quick-entry-sheet {{appearancePageClass}} {{isQuickEntryEditing ? 'is-editing' : ''}}" style="{{quickEntrySheetStyle}}">
    <view class="sheet-handle"></view>
    <view class="sheet-header">
      <view class="quick-entry-header-main">
        <view wx:if="{{!showQuickEntrySuccessPanel}}" class="quick-entry-header-back" bindtap="onQuickEntryHeaderBack">
          <image class="quick-entry-header-back-icon" src="/assets/icons/arrow-left-dark.svg" mode="aspectFit" />
        </view>
        <view class="quick-entry-title-wrap">
          <view class="sheet-title">快速录入</view>
          <view wx:if="{{quickEntryMode === 'follow_up' && !showQuickEntrySuccessPanel}}" class="quick-entry-ai-badge {{isQuickEntryAiLoading ? 'is-running' : ''}}">
            <image wx:if="{{!isQuickEntryAiLoading}}" class="quick-entry-ai-badge-icon" src="/assets/icons/ai-agent-dark.svg" mode="aspectFit" />
            <view wx:else class="ai-agent-loader quick-entry-ai-badge-loader">
              <view class="ai-agent-loader-antenna is-left"><view class="ai-agent-loader-dot"></view></view>
              <view class="ai-agent-loader-antenna is-right"><view class="ai-agent-loader-dot"></view></view>
              <view class="ai-agent-loader-cap"></view>
              <view class="ai-agent-loader-ear is-left"></view>
              <view class="ai-agent-loader-ear is-right"></view>
              <view class="ai-agent-loader-head">
                <view class="ai-agent-loader-eye is-left"></view>
                <view class="ai-agent-loader-eye is-right"></view>
                <view class="ai-agent-loader-mouth"></view>
              </view>
            </view>
            <view class="quick-entry-ai-badge-text">{{isQuickEntryAiLoading ? 'AI整理中' : 'AI辅助'}}</view>
          </view>
        </view>
      </view>
      <view class="sheet-close" bindtap="onQuickEntryHeaderClose">{{showQuickEntrySuccessPanel ? '完成' : '关闭'}}</view>
    </view>
    <view wx:if="{{!showQuickEntrySuccessPanel && quickEntryMode !== 'follow_up'}}" class="quick-entry-head">
      <view class="quick-entry-head-main">
        <view class="card-title">{{quickEntryModeTitle}}</view>
        <view class="card-subtitle">{{quickEntryModeDesc}}</view>
      </view>
    </view>
    <view wx:if="{{!showQuickEntrySuccessPanel && quickEntryMode !== 'follow_up'}}" class="chips quick-entry-mode-wall">
      <view
        wx:for="{{quickEntryModes}}"
        wx:key="key"
        class="chip quick-entry-mode-chip {{quickEntryMode === item.key ? 'is-active' : ''}}"
        data-mode="{{item.key}}"
        bindtap="setQuickEntryMode"
      >{{item.label}}</view>
    </view>
    <view class="quick-entry-body {{quickEntryMode === 'follow_up' && quickEntryFollowUpStage === 'review' ? 'is-review' : ''}}" style="{{quickEntryBodyStyle}}">
      <block wx:if="{{showQuickEntrySuccessPanel}}">
        <view class="quick-entry-success-card">
          <view class="quick-entry-success-badge">已保存</view>
          <view class="quick-entry-success-title">{{quickEntrySuccessState.title}}</view>
          <view class="quick-entry-success-detail">{{quickEntrySuccessState.detail}}</view>
          <view wx:if="{{quickEntrySuccessState.projectName}}" class="quick-entry-success-project">{{quickEntrySuccessState.projectName}}</view>
          <view wx:if="{{quickEntrySuccessState.continueHint}}" class="quick-entry-success-hint">{{quickEntrySuccessState.continueHint}}</view>
        </view>
      </block>
      <block wx:else>
      <block wx:if="{{quickEntryMode === 'project'}}">
        <view class="field-group quick-entry-field-group">
          <view class="field-label">项目名称</view>
          <input
            class="input-sim input-native"
            value="{{quickEntryForm.projectName}}"
            data-field="projectName"
            bindinput="onQuickEntryInput"
            bindfocus="onQuickEntryFieldFocus"
            cursor-spacing="{{quickEntryCursorSpacing}}"
            placeholder="例如：华大基因数据库改造"
            placeholder-class="input-placeholder"
          />
        </view>
        <view class="field-group quick-entry-field-group">
          <view class="field-label">客户名称</view>
          <input
            class="input-sim input-native"
            value="{{quickEntryForm.clientName}}"
            data-field="clientName"
            bindinput="onQuickEntryInput"
            bindfocus="onQuickEntryFieldFocus"
            cursor-spacing="{{quickEntryCursorSpacing}}"
            placeholder="例如：华大基因科技有限公司"
            placeholder-class="input-placeholder"
          />
        </view>
        <view class="field-group quick-entry-field-group">
          <view class="field-label">当前阶段</view>
          <view class="chips quick-entry-stage-wall">
            <view
              wx:for="{{quickEntryStages}}"
              wx:key="*this"
              class="chip quick-entry-stage-chip {{quickEntryForm.stage === item ? 'is-active' : ''}}"
              data-stage="{{item}}"
              bindtap="setQuickEntryStage"
            >{{item}}</view>
          </view>
        </view>
      </block>

      <block wx:if="{{quickEntryMode === 'follow_up'}}">
        <view wx:if="{{!quickEntryShowFollowUpDetails && !quickEntryManualInputEnabled}}" class="quick-entry-voice-card is-idle">
          <view class="quick-entry-voice-primary is-idle">
            <view class="quick-entry-voice-btn-shell {{isQuickEntryVoiceRecording ? 'is-recording' : ''}}">
              <view class="btn-secondary quick-entry-voice-btn {{isQuickEntryVoiceRecording ? 'is-recording' : ''}} {{(isQuickEntryVoiceRecognizing || isQuickEntryAiLoading) ? 'is-busy' : ''}}" bindtap="startQuickEntryVoiceInput">
                <view class="voice-button-content">
                  <view wx:if="{{isQuickEntryVoiceRecording}}" class="voice-receiver">
                    <view class="voice-receiver-bar is-one"></view>
                    <view class="voice-receiver-bar is-two"></view>
                    <view class="voice-receiver-bar is-three"></view>
                    <view class="voice-receiver-bar is-four"></view>
                  </view>
                  <text class="voice-button-label">{{isQuickEntryVoiceRecording ? '结束录音' : (isQuickEntryVoiceRecognizing ? '识别中...' : (isQuickEntryAiLoading ? 'AI整理中...' : '语音录入'))}}</text>
                  <text wx:if="{{isQuickEntryVoiceRecording && quickEntryVoiceElapsedText}}" class="voice-button-timer">{{quickEntryVoiceElapsedText}}</text>
                </view>
              </view>
            </view>
            <view wx:if="{{quickEntryVoiceStatusText && (quickEntryVoicePhase !== 'idle' || isQuickEntryVoiceRecording || isQuickEntryVoiceRecognizing || isQuickEntryAiLoading)}}" class="helper-text quick-entry-voice-status is-centered">{{quickEntryVoiceStatusText}}</view>
            <view wx:if="{{!quickEntryShowFollowUpDetails && quickEntrySelectedProjectMeta}}" class="quick-entry-continue-project">
              <view class="quick-entry-continue-project-label">将继续关联</view>
              <view class="quick-entry-continue-project-name">{{quickEntrySelectedProjectMeta.name}}</view>
              <view class="quick-entry-continue-project-meta">{{quickEntrySelectedProjectMeta.client}} · {{quickEntrySelectedProjectMeta.stage}}<text wx:if="{{quickEntryMode === 'follow_up' && quickEntryForm.followUpMethod && quickEntryForm.followUpMethod !== '其他'}}"> · 默认{{quickEntryForm.followUpMethod}}</text></view>
            </view>
            <view class="quick-entry-voice-idle-actions">
              <view class="section-link quick-entry-manual-link" bindtap="openQuickEntryManualInput">不方便说？改为手动录入</view>
              <view wx:if="{{quickEntrySelectedProjectMeta}}" class="section-link quick-entry-idle-discard-link" bindtap="onQuickEntryDiscardTap">不继续这次关联，清空本次闪录</view>
            </view>
          </view>
        </view>
        <block wx:if="{{quickEntryShowFollowUpDetails}}">
        <block wx:if="{{quickEntryFollowUpStage === 'review'}}">
          <view class="quick-entry-project-card quick-entry-review-overview-card">
            <view class="quick-entry-review-project-strip">
              <view class="line-between quick-entry-review-project-headline">
                <view class="quick-entry-review-card-title">关联项目</view>
                <view wx:if="{{quickEntrySelectedProjectMeta}}" class="status-badge quick-entry-review-project-badge">{{quickEntrySelectedProjectMeta.stage}}</view>
              </view>
              <view class="quick-entry-project-line-copy quick-entry-review-project-line {{quickEntrySelectedProjectMeta ? '' : 'is-placeholder'}}">
                <block wx:if="{{quickEntrySelectedProjectMeta}}">
                  <view class="quick-entry-project-line-name quick-entry-review-project-line-name">{{quickEntrySelectedProjectMeta.name}}</view>
                  <view wx:if="{{quickEntrySelectedProjectMeta.client}}" class="quick-entry-project-line-company quick-entry-review-project-line-company">· {{quickEntrySelectedProjectMeta.client}}</view>
                </block>
                <view wx:else class="quick-entry-project-line-placeholder">{{quickEntrySelectedProjectName}}</view>
              </view>
            </view>
            <view class="quick-entry-review-followup-summary">
              <view class="quick-entry-review-followup-summary-copy">
                <view class="quick-entry-review-followup-summary-label">跟进信息</view>
                <view class="quick-entry-review-followup-summary-text">{{quickEntryForm.followUpDate}} {{quickEntryForm.followUpClock}} · {{quickEntryForm.followUpMethod}}</view>
              </view>
              <view class="section-link quick-entry-review-followup-summary-link" bindtap="toggleQuickEntryReviewSettings">{{quickEntryShowReviewSettings ? '收起' : '修改'}}</view>
            </view>
            <view wx:if="{{quickEntryShowReviewSettings}}" class="quick-entry-review-settings">
              <view class="quick-entry-review-setting">
                <view class="quick-entry-review-setting-label">跟进时间</view>
                <view class="quick-entry-review-time-row">
                  <view class="quick-entry-review-time-pill">
                    <picker class="quick-entry-review-time-picker is-date" mode="date" value="{{quickEntryForm.followUpDate}}" data-field="followUpDate" bindchange="onQuickEntryPicker">
                      <view class="picker-sim">
                        <view class="picker-value">{{quickEntryForm.followUpDate}}</view>
                      </view>
                    </picker>
                  </view>
                  <view class="quick-entry-review-time-pill">
                    <picker class="quick-entry-review-time-picker is-clock" mode="time" value="{{quickEntryForm.followUpClock}}" data-field="followUpClock" bindchange="onQuickEntryPicker">
                      <view class="picker-sim">
                        <view class="picker-value">{{quickEntryForm.followUpClock}}</view>
                      </view>
                    </picker>
                  </view>
                </view>
              </view>
              <view class="quick-entry-review-setting">
                <view class="quick-entry-review-setting-label">跟进方式</view>
                <view class="chips quick-entry-method-wall quick-entry-review-method-wall">
                  <view
                    wx:for="{{quickEntryMethods}}"
                    wx:key="*this"
                    class="chip quick-entry-method-chip {{quickEntryForm.followUpMethod === item ? 'is-active' : ''}}"
                    data-method="{{item}}"
                    bindtap="setQuickEntryMethod"
                  >{{item}}</view>
                </view>
              </view>
            </view>
          </view>
            <view wx:if="{{quickEntryAiError}}" class="quick-entry-ai-state-card">
              <view class="quick-entry-ai-state-title">当前无法完成智能理解</view>
              <view class="helper-text quick-entry-ai-state-desc">{{quickEntryAiError}}</view>
            </view>
            <view wx:if="{{isQuickEntryAiLoading}}" class="quick-entry-ai-state-card">
              <view class="ai-agent-loader quick-entry-ai-state-loader">
                <view class="ai-agent-loader-antenna is-left"><view class="ai-agent-loader-dot"></view></view>
                <view class="ai-agent-loader-antenna is-right"><view class="ai-agent-loader-dot"></view></view>
                <view class="ai-agent-loader-cap"></view>
                <view class="ai-agent-loader-ear is-left"></view>
                <view class="ai-agent-loader-ear is-right"></view>
                <view class="ai-agent-loader-head">
                  <view class="ai-agent-loader-eye is-left"></view>
                  <view class="ai-agent-loader-eye is-right"></view>
                  <view class="ai-agent-loader-mouth"></view>
                </view>
              </view>
              <view class="quick-entry-ai-state-title">正在理解这条闪录</view>
              <view class="helper-text quick-entry-ai-state-desc">{{quickEntryAiLoadingHint}}</view>
            </view>
            <view wx:if="{{quickEntryAiSummary}}" class="quick-entry-ai-result-card">
              <view class="line-between quick-entry-ai-card-head">
                <view class="quick-entry-ai-card-title">AI摘要</view>
              </view>
              <view wx:if="{{!quickEntryEditingAiSummary}}" class="quick-entry-ai-block">
                <view class="quick-entry-ai-text">{{quickEntryAiSummary.summary}}</view>
              </view>
              <view wx:else class="quick-entry-ai-block">
                <textarea
                  class="textarea-sim textarea-native quick-entry-textarea is-small"
                  value="{{quickEntryAiSummaryDraft.summary}}"
                  bindinput="onQuickEntryAiSummaryDraftInput"
                  bindfocus="onQuickEntryFieldFocus"
                  cursor-spacing="{{quickEntryCursorSpacing}}"
                  placeholder="可按你的判断微调摘要"
                  placeholder-class="input-placeholder"
                  maxlength="-1"
                ></textarea>
              </view>
              <view wx:if="{{!quickEntryEditingAiSummary}}" class="quick-entry-inline-edit-actions">
                <view class="section-link quick-entry-ai-card-link" bindtap="startEditingQuickEntryAiSummary">调整</view>
              </view>
              <view wx:else class="quick-entry-inline-edit-actions">
                <view class="section-link quick-entry-ai-card-link" bindtap="cancelEditingQuickEntryAiSummary">取消</view>
                <view class="section-link quick-entry-ai-card-link" bindtap="applyQuickEntryAiSummaryDraft">应用修改</view>
              </view>
            </view>
            <view wx:if="{{!quickEntryAiNextSuggestion && quickEntryAiNextSuggestionError}}" class="quick-entry-ai-tip-card">
              <view class="line-between quick-entry-ai-card-head">
                <view class="quick-entry-ai-tip-title">AI建议的下一步</view>
                <view class="section-link quick-entry-ai-card-link {{isQuickEntryAiLoading ? 'is-disabled' : ''}}" bindtap="retryQuickEntryNextSuggestion">{{isQuickEntryAiLoading ? '生成中...' : '重试建议'}}</view>
              </view>
              <view class="helper-text quick-entry-ai-tip-text">{{quickEntryAiNextSuggestionError}}</view>
            </view>
            <view wx:if="{{quickEntryAiNextSuggestion}}" class="quick-entry-ai-result-card">
              <view class="line-between quick-entry-ai-card-head">
                <view class="quick-entry-ai-card-title">AI建议的下一步</view>
              </view>
              <view wx:if="{{!quickEntryEditingAiNextSuggestion}}" class="quick-entry-ai-block">
                <view class="quick-entry-ai-text quick-entry-ai-text-full">{{quickEntryAiNextSuggestion.nextAction}}</view>
              </view>
              <view wx:else class="quick-entry-ai-block">
                <textarea
                  class="textarea-sim textarea-native quick-entry-textarea is-small"
                  value="{{quickEntryAiNextSuggestionDraft.nextAction}}"
                  bindinput="onQuickEntryAiNextActionDraftInput"
                  bindfocus="onQuickEntryFieldFocus"
                  cursor-spacing="{{quickEntryCursorSpacing}}"
                  placeholder="可按你的判断调整下一步动作"
                  placeholder-class="input-placeholder"
                  maxlength="-1"
                ></textarea>
              </view>
              <view wx:if="{{!quickEntryEditingAiNextSuggestion}}" class="quick-entry-inline-edit-actions">
                <view class="section-link quick-entry-ai-card-link" bindtap="startEditingQuickEntryAiNextSuggestion">调整</view>
              </view>
