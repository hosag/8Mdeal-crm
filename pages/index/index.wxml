                  placeholder-class="input-placeholder"
                />
              </view>
              <view class="quick-entry-task-inline-row is-time">
                <view class="field-label quick-entry-task-inline-label">建议执行时间</view>
                <view class="quick-entry-task-inline-time">
                  <picker class="picker-block quick-entry-next-task-picker is-date" mode="date" value="{{quickEntryNextTaskDraft.dueDate}}" data-field="dueDate" bindchange="onQuickEntryNextTaskPicker">
                    <view class="picker-sim">
                      <view class="picker-value">{{quickEntryNextTaskDraft.dueDate}}</view>
                    </view>
                  </picker>
                  <picker class="picker-block quick-entry-next-task-picker is-time" mode="time" value="{{quickEntryNextTaskDraft.dueTime}}" data-field="dueTime" bindchange="onQuickEntryNextTaskPicker">
