<view class="page-shell home-page {{appearancePageClass}}">
  <view wx:if="{{isLoading}}" class="rise-in">
    <loading-panel rows="2" appearance-page-class="{{appearancePageClass}}" />
  </view>

  <block wx:else>
    <view class="hero rise-in">
      <view class="hero-top-actions">
        <view class="home-avatar-entry" bindtap="openMinePage">{{homeAvatarText}}</view>
        <view class="notify-entry" bindtap="openNotificationsPage">
          <view class="notify-entry-text">消息中心</view>
          <view wx:if="{{notificationUnreadCount}}" class="notify-entry-count">{{notificationUnreadCount > 99 ? '99+' : notificationUnreadCount}}</view>
        </view>
      </view>
      <view class="brand-lockup">
        <image class="brand-lockup-image" src="/assets/brand/logo-core-transparent.png" mode="aspectFit" />
        <view class="brand-lockup-copy">
          <view class="brand-lockup-title">八面成交</view>
          <view class="brand-lockup-subtitle">您的私人 CRM 引擎</view>
        </view>
      </view>
      <view class="eyebrow-row">
        <view class="eyebrow">私人成交推进系统</view>
      </view>
      <view class="hero-title">今天先处理 {{dashboard.taskBoard.summary.openCount || 0}} 条推进动作</view>
      <view class="hero-subtitle">把项目全局、推进动作和关键动态都收进八面成交，先看动作，再看项目，判断会更快。</view>
      <view class="hero-message-strip {{notificationHeadlineToneClass}}" bindtap="openHeadlineNotification">
        <view class="hero-message-copy">
          <view class="hero-message-topline">
            <view class="hero-message-badge">{{notificationHeadlineBadgeText}}</view>
            <view wx:if="{{notificationHeadlineProjectName}}" class="hero-message-project">{{notificationHeadlineProjectName}}</view>
          </view>
          <view class="hero-message-title">{{notificationHeadlineTitle}}</view>
          <view class="hero-message-desc">{{notificationHeadlineDesc}}</view>
        </view>
        <view class="hero-message-action">{{notificationHeadlineActionText}}</view>
      </view>
      <view class="hero-actions">
        <view class="btn-secondary hero-primary-btn" data-url="/pages/project-form/project-form" bindtap="openPage">新建项目</view>
        <view class="btn-ghost hero-secondary-btn" data-url="/pages/projects/projects" bindtap="openPage">我的项目</view>
      </view>
      <view class="pill-row hero-quick-pills">
        <view class="field-pill" data-filter="open" data-sort="priority" bindtap="openTasksCenter">查看推进任务</view>
        <view class="field-pill" data-filter="overdue" data-sort="priority" bindtap="openTasksCenter">查看逾期动作</view>
        <view class="field-pill" data-quick-filter="shared" data-sort-mode="updated" data-source="home-shared" bindtap="openProjectsWithFilter">查看我接手的</view>
      </view>
      <view class="hero-metrics section hero-metrics-compact">
        <view class="metric-card" wx:for="{{dashboard.metrics}}" wx:key="label">
          <view class="metric-label">{{item.label}}</view>
          <view class="metric-value">{{item.value}}</view>
          <view class="metric-note">{{item.note}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{homeAccessCard.visible}}" class="form-card section home-access-card rise-in stagger-1">
      <view class="home-access-head">
        <view class="home-access-title-wrap">
          <view class="section-title">{{homeAccessCard.title}}</view>
        </view>
        <view wx:if="{{homeAccessCard.actionText}}" class="home-access-action" bindtap="handleHomeAccessAction">{{homeAccessCard.actionText}}</view>
      </view>
      <view wx:if="{{homeAccessCard.desc}}" class="card-subtitle home-access-desc">{{homeAccessCard.desc}}</view>
      <view class="home-access-grid">
        <view class="home-access-item" wx:for="{{homeAccessCard.rows}}" wx:key="key">
          <view class="home-access-label">{{item.label}}</view>
          <view class="home-access-value">{{item.value}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{isLoadFailed}}" class="form-card section state-card rise-in stagger-1">
      <view class="form-card-title">当前无法同步云端数据</view>
      <view class="form-card-desc">{{loadError}}</view>
      <view class="hero-actions state-actions">
        <view class="btn-primary state-btn" bindtap="retryFetch">重新加载</view>
        <view class="btn-ghost state-btn" bindtap="openProjectsPage">查看我的项目</view>
      </view>
    </view>

    <view class="section rise-in stagger-1">
      <view class="section-header">
        <view class="section-title">推进动作优先</view>
        <view class="section-link" data-filter="open" data-sort="priority" bindtap="openTasksCenter">查看全部</view>
      </view>
      <view class="task-summary-strip">
        <view class="task-summary-item">
          <view class="task-summary-value">{{dashboard.taskBoard.summary.openCount || 0}}</view>
          <view class="task-summary-label">未完成</view>
        </view>
        <view class="task-summary-item">
          <view class="task-summary-value is-danger">{{dashboard.taskBoard.summary.overdueCount || 0}}</view>
          <view class="task-summary-label">逾期</view>
        </view>
        <view class="task-summary-item">
          <view class="task-summary-value is-brand">{{dashboard.taskBoard.summary.todayCount || 0}}</view>
          <view class="task-summary-label">今日</view>
        </view>
      </view>

      <view wx:if="{{taskFeedback.title}}" class="task-feedback-banner">
        <view class="task-feedback-main">
          <view class="task-feedback-title">{{taskFeedback.title}}</view>
          <view class="task-feedback-detail">{{taskFeedback.detail}}</view>
        </view>
        <view class="task-feedback-dismiss" bindtap="dismissTaskFeedback">收起</view>
      </view>

      <view class="task-priority-card" wx:for="{{dashboard.taskBoard.cards}}" wx:key="id">
        <view class="task-priority-main">
          <view class="task-priority-copy">
            <view class="task-priority-head" data-project-id="{{item.projectId}}" bindtap="openTaskProjectDetail">
              <view class="status-badge {{item.urgencyBadgeClass}} task-urgency-badge">{{item.urgencyText}}</view>
              <view class="task-priority-project">{{item.projectName}}</view>
            </view>
            <view class="project-name task-title">{{item.title}}</view>
            <view class="project-client task-project-link" data-project-id="{{item.projectId}}" bindtap="openTaskProjectDetail">
              {{item.clientName}} · {{item.stage}}
            </view>
            <view wx:if="{{item.focusText}}" class="task-focus-line">{{item.focusText}}</view>
          </view>
          <view class="task-priority-side">
            <view class="task-due-text">{{item.dueText}}</view>
            <view class="btn-primary task-complete-action" data-task-id="{{item.id}}" bindtap="openTaskCompleteSheet">去完成</view>
          </view>
        </view>
      </view>

      <empty-state
        wx:if="{{!dashboard.taskBoard.cards.length}}"
        appearance-page-class="{{appearancePageClass}}"
        title="暂无推进动作"
        desc="补充推进任务后，会自动显示在这里。"
        image="/assets/illustrations/empty-projects.svg"
        actionText="查看我的项目"
        bind:action="openProjectsPage"
      />
    </view>

    <view class="section rise-in stagger-2">
      <view class="section-header">
        <view class="section-title">动态时间线</view>
      </view>
      <view class="glass-card">
        <view class="timeline-group" wx:for="{{dashboard.timeline}}" wx:key="date">
          <view class="timeline-group-title">{{item.date}}</view>
          <view class="timeline-item" wx:for="{{item.items}}" wx:key="key" data-project-id="{{item.projectId}}" bindtap="openTimelineProject">
            <view class="timeline-axis">
              <view class="timeline-dot"></view>
              <view class="timeline-line"></view>
            </view>
            <view class="timeline-body">
              <view class="timeline-time">{{item.time}}</view>
              <view class="timeline-title">{{item.title}}</view>
              <view class="timeline-desc">{{item.desc}}</view>
              <view class="helper-text" wx:if="{{item.projectId}}">点击可查看该项目完整上下文</view>
            </view>
          </view>
        </view>
      </view>
      <empty-state
        wx:if="{{!dashboard.timeline.length}}"
        appearance-page-class="{{appearancePageClass}}"
        title="暂无最新动态"
        desc="新建项目、录入跟进或完成任务后，会自动显示在这里。"
        image="/assets/illustrations/empty-projects.svg"
        actionText="新建项目"
        bind:action="openProjectForm"
      />
    </view>
  </block>
</view>

<view wx:if="{{showQuickEntrySheet}}">
  <view class="sheet-mask quick-entry-mask" bindtap="onQuickEntryMaskTap"></view>
  <view class="sheet-panel quick-entry-sheet {{appearancePageClass}} {{isQuickEntryEditing ? 'is-editing' : ''}}" style="{{quickEntrySheetStyle}}">
    <view class="sheet-handle"></view>
    <view class="sheet-header">
      <view class="quick-entry-title-wrap">
        <view class="sheet-title">快速录入</view>
        <view wx:if="{{quickEntryMode === 'follow_up' && !showQuickEntrySuccessPanel}}" class="quick-entry-ai-badge {{isQuickEntryAiLoading ? 'is-running' : ''}}">
          <image wx:if="{{!isQuickEntryAiLoading}}" class="quick-entry-ai-badge-icon" src="/assets/icons/ai-agent-dark.svg" mode="aspectFit" />
          <view wx:else class="ai-agent-loader quick-entry-ai-badge-loader">
            <view class="ai-agent-loader-antenna is-left"><view class="ai-agent-loader-dot"></view></view>
            <view class="ai-agent-loader-antenna is-right"><view class="ai-agent-loader-dot"></view></view>
            <view class="ai-agent-loader-cap"></view>
            <view class="ai-agent-loader-ear is-left"></view>
            <view class="ai-agent-loader-ear is-right"></view>
            <view class="ai-agent-loader-head">
              <view class="ai-agent-loader-eye is-left"></view>
              <view class="ai-agent-loader-eye is-right"></view>
              <view class="ai-agent-loader-mouth"></view>
            </view>
          </view>
          <view class="quick-entry-ai-badge-text">{{isQuickEntryAiLoading ? 'AI整理中' : 'AI辅助'}}</view>
        </view>
      </view>
      <view class="sheet-close" bindtap="onQuickEntryHeaderClose">{{showQuickEntrySuccessPanel ? '完成' : '关闭'}}</view>
    </view>
    <view wx:if="{{!showQuickEntrySuccessPanel && quickEntryMode !== 'follow_up'}}" class="quick-entry-head">
      <view class="quick-entry-head-main">
        <view class="card-title">{{quickEntryModeTitle}}</view>
        <view class="card-subtitle">{{quickEntryModeDesc}}</view>
      </view>
    </view>
    <view wx:if="{{!showQuickEntrySuccessPanel && quickEntryMode !== 'follow_up'}}" class="chips quick-entry-mode-wall">
      <view
        wx:for="{{quickEntryModes}}"
        wx:key="key"
        class="chip quick-entry-mode-chip {{quickEntryMode === item.key ? 'is-active' : ''}}"
        data-mode="{{item.key}}"
        bindtap="setQuickEntryMode"
      >{{item.label}}</view>
    </view>
    <view class="quick-entry-body" style="{{quickEntryBodyStyle}}">
      <block wx:if="{{showQuickEntrySuccessPanel}}">
        <view class="quick-entry-success-card">
          <view class="quick-entry-success-badge">已保存</view>
          <view class="quick-entry-success-title">{{quickEntrySuccessState.title}}</view>
          <view class="quick-entry-success-detail">{{quickEntrySuccessState.detail}}</view>
          <view wx:if="{{quickEntrySuccessState.projectName}}" class="quick-entry-success-project">{{quickEntrySuccessState.projectName}}</view>
          <view wx:if="{{quickEntrySuccessState.continueHint}}" class="quick-entry-success-hint">{{quickEntrySuccessState.continueHint}}</view>
        </view>
      </block>
      <block wx:else>
      <block wx:if="{{quickEntryMode === 'project'}}">
        <view class="field-group quick-entry-field-group">
          <view class="field-label">项目名称</view>
          <input
            class="input-sim input-native"
            value="{{quickEntryForm.projectName}}"
            data-field="projectName"
            bindinput="onQuickEntryInput"
            bindfocus="onQuickEntryFieldFocus"
            cursor-spacing="{{quickEntryCursorSpacing}}"
            placeholder="例如：华大基因数据库改造"
            placeholder-class="input-placeholder"
          />
        </view>
        <view class="field-group quick-entry-field-group">
          <view class="field-label">客户名称</view>
          <input
            class="input-sim input-native"
            value="{{quickEntryForm.clientName}}"
            data-field="clientName"
            bindinput="onQuickEntryInput"
            bindfocus="onQuickEntryFieldFocus"
            cursor-spacing="{{quickEntryCursorSpacing}}"
            placeholder="例如：华大基因科技有限公司"
            placeholder-class="input-placeholder"
          />
        </view>
        <view class="field-group quick-entry-field-group">
          <view class="field-label">当前阶段</view>
          <view class="chips quick-entry-stage-wall">
            <view
              wx:for="{{quickEntryStages}}"
              wx:key="*this"
              class="chip quick-entry-stage-chip {{quickEntryForm.stage === item ? 'is-active' : ''}}"
              data-stage="{{item}}"
              bindtap="setQuickEntryStage"
            >{{item}}</view>
          </view>
        </view>
      </block>

      <block wx:if="{{quickEntryMode === 'follow_up'}}">
        <view wx:if="{{!quickEntryShowFollowUpDetails && !quickEntryManualInputEnabled}}" class="quick-entry-voice-card is-idle">
          <view class="quick-entry-voice-primary is-idle">
            <view class="quick-entry-voice-btn-shell {{isQuickEntryVoiceRecording ? 'is-recording' : ''}}">
              <view class="btn-secondary quick-entry-voice-btn {{isQuickEntryVoiceRecording ? 'is-recording' : ''}} {{(isQuickEntryVoiceRecognizing || isQuickEntryAiLoading) ? 'is-busy' : ''}}" bindtap="startQuickEntryVoiceInput">
                <view class="voice-button-content">
                  <view wx:if="{{isQuickEntryVoiceRecording}}" class="voice-receiver">
                    <view class="voice-receiver-bar is-one"></view>
                    <view class="voice-receiver-bar is-two"></view>
                    <view class="voice-receiver-bar is-three"></view>
                    <view class="voice-receiver-bar is-four"></view>
                  </view>
                  <text class="voice-button-label">{{isQuickEntryVoiceRecording ? '结束录音' : (isQuickEntryVoiceRecognizing ? '识别中...' : (isQuickEntryAiLoading ? 'AI整理中...' : '语音录入'))}}</text>
                  <text wx:if="{{isQuickEntryVoiceRecording && quickEntryVoiceElapsedText}}" class="voice-button-timer">{{quickEntryVoiceElapsedText}}</text>
                </view>
              </view>
            </view>
            <view wx:if="{{quickEntryVoiceStatusText && (quickEntryVoicePhase !== 'idle' || isQuickEntryVoiceRecording || isQuickEntryVoiceRecognizing || isQuickEntryAiLoading)}}" class="helper-text quick-entry-voice-status is-centered">{{quickEntryVoiceStatusText}}</view>
            <view wx:if="{{!quickEntryShowFollowUpDetails && quickEntrySelectedProjectMeta}}" class="quick-entry-continue-project">
              <view class="quick-entry-continue-project-label">将继续关联</view>
              <view class="quick-entry-continue-project-name">{{quickEntrySelectedProjectMeta.name}}</view>
              <view class="quick-entry-continue-project-meta">{{quickEntrySelectedProjectMeta.client}} · {{quickEntrySelectedProjectMeta.stage}}<text wx:if="{{quickEntryMode === 'follow_up' && quickEntryForm.followUpMethod}}"> · 默认{{quickEntryForm.followUpMethod}}</text></view>
            </view>
            <view class="quick-entry-voice-idle-actions">
              <view class="section-link quick-entry-manual-link" bindtap="openQuickEntryManualInput">不方便说？改为手动录入</view>
              <view wx:if="{{quickEntrySelectedProjectMeta}}" class="section-link quick-entry-idle-discard-link" bindtap="onQuickEntryDiscardTap">不继续这次关联，清空本次闪录</view>
            </view>
          </view>
        </view>
        <block wx:if="{{quickEntryShowFollowUpDetails}}">
        <view wx:if="{{quickEntryFollowUpStage !== 'capture'}}" class="quick-entry-stage-banner quick-entry-stage-banner-{{quickEntryFollowUpStage}}">
          <view class="quick-entry-stage-title">{{quickEntryFollowUpStageTitle}}</view>
          <view wx:if="{{quickEntryFollowUpStageHint}}" class="quick-entry-stage-hint">{{quickEntryFollowUpStageHint}}</view>
        </view>
        <view class="field-group quick-entry-field-group">
          <view class="line-between quick-entry-field-head">
            <view class="field-label">{{quickEntryManualInputEnabled ? '这次发生了什么？' : '跟进内容'}}</view>
            <view wx:if="{{quickEntryManualInputEnabled && !isQuickEntryVoiceRecording && !isQuickEntryVoiceRecognizing && !isQuickEntryAiLoading}}" class="section-link quick-entry-ai-link" bindtap="returnQuickEntryToVoiceInput">切回语音录入</view>
            <view wx:elif="{{quickEntryFollowUpStage !== 'content' && quickEntryForm.followUpContent}}" class="section-link quick-entry-ai-link {{isQuickEntryAiLoading ? 'is-disabled' : ''}}" bindtap="retryQuickEntryAiPipeline">{{isQuickEntryAiLoading ? 'AI整理中...' : '重新AI整理'}}</view>
          </view>
          <view wx:if="{{!quickEntryManualInputEnabled}}" class="quick-entry-inline-voice-actions">
            <view class="quick-entry-voice-btn-shell quick-entry-inline-voice-shell {{isQuickEntryVoiceRecording ? 'is-recording' : ''}}">
              <view class="btn-secondary quick-entry-voice-btn quick-entry-inline-voice-btn {{isQuickEntryVoiceRecording ? 'is-recording' : ''}} {{(isQuickEntryVoiceRecognizing || isQuickEntryAiLoading) ? 'is-busy' : ''}}" bindtap="startQuickEntryVoiceInput">
                <view class="voice-button-content">
                  <view wx:if="{{isQuickEntryVoiceRecording}}" class="voice-receiver">
                    <view class="voice-receiver-bar is-one"></view>
                    <view class="voice-receiver-bar is-two"></view>
                    <view class="voice-receiver-bar is-three"></view>
                    <view class="voice-receiver-bar is-four"></view>
                  </view>
                  <text class="voice-button-label">{{isQuickEntryVoiceRecording ? '结束录音' : (isQuickEntryVoiceRecognizing ? '识别中...' : '语音录入')}}</text>
                  <text wx:if="{{isQuickEntryVoiceRecording && quickEntryVoiceElapsedText}}" class="voice-button-timer">{{quickEntryVoiceElapsedText}}</text>
                </view>
              </view>
            </view>
          </view>
          <textarea
            class="textarea-sim textarea-native quick-entry-textarea"
            value="{{quickEntryForm.followUpContent}}"
            data-field="followUpContent"
            bindinput="onQuickEntryInput"
            bindfocus="onQuickEntryFieldFocus"
            cursor-spacing="{{quickEntryCursorSpacing}}"
            placeholder="{{quickEntryManualInputEnabled ? '例如：客户说周五看方案，下周二再确认预算' : '把刚刚说的话整理一下，确认后再交给 AI'}}"
            placeholder-class="input-placeholder"
            maxlength="-1"
          ></textarea>
          <view wx:if="{{quickEntryVoicePreviewText && quickEntryFollowUpStage !== 'capture' && quickEntryVoicePreviewText !== quickEntryForm.followUpContent}}" class="quick-entry-inline-preview">
            <view class="quick-entry-inline-preview-label">识别原文</view>
            <view class="quick-entry-inline-preview-text">{{quickEntryVoicePreviewText}}</view>
          </view>
          <view wx:if="{{quickEntryVoiceStatusText && (quickEntryVoicePhase !== 'idle' || isQuickEntryVoiceRecording || isQuickEntryVoiceRecognizing || isQuickEntryAiLoading || quickEntryAiError)}}" class="helper-text quick-entry-inline-note">{{quickEntryVoiceStatusText}}</view>
          <view wx:if="{{quickEntryForm.followUpContent && quickEntryFollowUpStage === 'content'}}" class="helper-text quick-entry-inline-note">确认无误后，再点下方 AI整理。</view>
        </view>
        <view wx:if="{{quickEntryAiError}}" class="quick-entry-ai-state-card">
          <view class="quick-entry-ai-state-title">当前无法完成智能理解</view>
          <view class="helper-text quick-entry-ai-state-desc">{{quickEntryAiError}}</view>
        </view>
        <view wx:if="{{isQuickEntryAiLoading}}" class="quick-entry-ai-state-card">
          <view class="ai-agent-loader quick-entry-ai-state-loader">
            <view class="ai-agent-loader-antenna is-left"><view class="ai-agent-loader-dot"></view></view>
            <view class="ai-agent-loader-antenna is-right"><view class="ai-agent-loader-dot"></view></view>
            <view class="ai-agent-loader-cap"></view>
            <view class="ai-agent-loader-ear is-left"></view>
            <view class="ai-agent-loader-ear is-right"></view>
            <view class="ai-agent-loader-head">
              <view class="ai-agent-loader-eye is-left"></view>
              <view class="ai-agent-loader-eye is-right"></view>
              <view class="ai-agent-loader-mouth"></view>
            </view>
          </view>
          <view class="quick-entry-ai-state-title">正在理解这条闪录</view>
          <view class="helper-text quick-entry-ai-state-desc">{{quickEntryAiLoadingHint}}</view>
        </view>
        <view wx:if="{{quickEntryFollowUpStage === 'project' || quickEntryFollowUpStage === 'review'}}" class="quick-entry-project-card">
          <view class="line-between quick-entry-project-head">
            <view class="quick-entry-project-summary">
              <view class="field-label quick-entry-inline-label">{{quickEntrySelectedProjectMeta ? '关联项目' : '确认项目'}}</view>
              <view class="quick-entry-selected-project {{quickEntrySelectedProjectMeta ? '' : 'is-placeholder'}}">{{quickEntrySelectedProjectName}}</view>
            </view>
            <view class="quick-entry-project-head-actions">
              <view wx:if="{{quickEntrySelectedProjectMeta}}" class="status-badge quick-entry-project-stage">{{quickEntrySelectedProjectMeta.stage}}</view>
              <view class="section-link quick-entry-project-link" bindtap="toggleQuickEntryProjectSearch">
                {{quickEntryShowProjectSearch ? '收起' : '从项目库选择'}}
              </view>
            </view>
          </view>
          <view wx:if="{{quickEntrySelectedProjectMeta}}" class="helper-text quick-entry-project-meta">{{quickEntrySelectedProjectMeta.client}}<text wx:if="{{quickEntryProjectSelectionMode === 'ai_auto'}}"> · 已自动匹配，如不对可更换</text><text wx:if="{{quickEntryProjectSelectionMode === 'manual'}}"> · 已手动确认</text></view>
          <view wx:else class="helper-text quick-entry-project-meta">{{quickEntryAiProjectMatch && quickEntryAiProjectMatch.status === 'candidates' ? '未自动确认项目，请从项目库选择。' : '未匹配到项目，请从项目库选择。'}}</view>
          <view wx:if="{{quickEntrySuggestedProjects.length}}" class="chips quick-entry-project-suggest-wall">
            <view
              wx:for="{{quickEntrySuggestedProjects}}"
              wx:key="id"
              class="chip quick-entry-project-suggest-chip {{quickEntrySelectedProjectId === item.id ? 'is-active' : ''}} {{(isQuickEntryAiLoading || isQuickEntryVoiceRecognizing) ? 'is-disabled' : ''}}"
              data-project-id="{{item.id}}"
              bindtap="selectQuickEntryProject"
            >{{item.name}}</view>
          </view>
          <view wx:if="{{quickEntryAiProjectMatch && quickEntryAiProjectMatch.status === 'candidates' && quickEntryAiProjectCandidateIds.length > quickEntrySuggestedProjects.length && !quickEntryShowProjectSearch}}" class="helper-text quick-entry-project-candidate-more">也可从项目库自行更换</view>
          <block wx:if="{{quickEntryShowProjectSearch}}">
            <view class="search-panel quick-entry-project-search">
              <input
                class="input-sim input-native projects-search-input"
                value="{{quickEntryProjectKeyword}}"
                bindinput="onQuickEntryProjectSearch"
                bindfocus="onQuickEntryFieldFocus"
                placeholder="搜索项目 / 客户 / 联系人"
                placeholder-class="input-placeholder"
                confirm-type="search"
                cursor-spacing="{{quickEntryCursorSpacing}}"
              />
              <view wx:if="{{quickEntryProjectKeyword}}" class="search-clear" bindtap="clearQuickEntryProjectSearch">清空</view>
            </view>
            <view wx:if="{{quickEntryVisibleProjects.length}}" class="quick-entry-project-list">
              <view
                wx:for="{{quickEntryVisibleProjects}}"
                wx:key="id"
                class="quick-entry-project-option {{quickEntrySelectedProjectId === item.id ? 'is-active' : ''}} {{(isQuickEntryAiLoading || isQuickEntryVoiceRecognizing) ? 'is-disabled' : ''}}"
                data-project-id="{{item.id}}"
                bindtap="selectQuickEntryProject"
              >
                <view class="quick-entry-project-option-top">
                  <view class="quick-entry-project-option-name">{{item.name}}</view>
                  <view class="quick-entry-project-option-badges">
                    <view class="field-pill quick-entry-project-option-pill">{{item.stage}}</view>
                  </view>
                </view>
                <view class="helper-text quick-entry-project-option-meta">{{item.client}}<text wx:if="{{item.contactText}}"> · {{item.contactText}}</text></view>
                <view wx:if="{{item.nextText || item.focusText || item.latestSummary}}" class="quick-entry-project-option-brief">{{item.nextText || item.focusText || item.latestSummary}}</view>
              </view>
            </view>
            <view wx:else class="helper-text quick-entry-empty">没有找到匹配项目，可以先切到“新建项目”。</view>
          </block>
        </view>
        <view wx:if="{{quickEntryFollowUpStage === 'review' && quickEntryAiSummary}}" class="quick-entry-ai-result-card">
          <view class="line-between quick-entry-ai-card-head">
            <view class="quick-entry-ai-card-title">摘要</view>
            <view class="quick-entry-ai-card-actions">
              <view wx:if="{{!quickEntryEditingAiSummary}}" class="section-link quick-entry-ai-card-link" bindtap="startEditingQuickEntryAiSummary">调整</view>
              <view wx:else class="section-link quick-entry-ai-card-link" bindtap="applyQuickEntryAiSummaryDraft">应用修改</view>
              <view wx:if="{{quickEntryAiSummaryOriginal && !quickEntryEditingAiSummary}}" class="section-link quick-entry-ai-card-link" bindtap="restoreQuickEntryAiSummary">恢复AI建议</view>
            </view>
          </view>
          <view wx:if="{{!quickEntryEditingAiSummary}}" class="quick-entry-ai-block">
            <view class="quick-entry-ai-text">{{quickEntryAiSummary.summary}}</view>
          </view>
          <view wx:else class="quick-entry-ai-block">
            <textarea
              class="textarea-sim textarea-native quick-entry-textarea is-small"
              value="{{quickEntryAiSummaryDraft.summary}}"
              bindinput="onQuickEntryAiSummaryDraftInput"
              bindfocus="onQuickEntryFieldFocus"
              cursor-spacing="{{quickEntryCursorSpacing}}"
              placeholder="可按你的判断微调摘要"
              placeholder-class="input-placeholder"
              maxlength="-1"
            ></textarea>
            <view class="quick-entry-inline-edit-actions">
              <view class="section-link quick-entry-ai-card-link" bindtap="cancelEditingQuickEntryAiSummary">取消</view>
            </view>
          </view>
          <view class="quick-entry-inline-followup-settings">
            <view class="split-row quick-entry-time-row">
              <picker class="picker-block" mode="date" value="{{quickEntryForm.followUpDate}}" data-field="followUpDate" bindchange="onQuickEntryPicker">
                <view class="picker-sim">
                  <view class="picker-value">{{quickEntryForm.followUpDate}}</view>
                </view>
              </picker>
              <picker class="picker-block" mode="time" value="{{quickEntryForm.followUpClock}}" data-field="followUpClock" bindchange="onQuickEntryPicker">
                <view class="picker-sim">
                  <view class="picker-value">{{quickEntryForm.followUpClock}}</view>
                </view>
              </picker>
            </view>
            <view class="chips quick-entry-method-wall quick-entry-inline-method-wall">
              <view
                wx:for="{{quickEntryMethods}}"
                wx:key="*this"
                class="chip quick-entry-method-chip {{quickEntryForm.followUpMethod === item ? 'is-active' : ''}}"
                data-method="{{item}}"
                bindtap="setQuickEntryMethod"
              >{{item}}</view>
            </view>
          </view>
        </view>
        <view wx:if="{{quickEntryFollowUpStage === 'review' && quickEntryAiNextSuggestion}}" class="quick-entry-ai-result-card">
          <view class="line-between quick-entry-ai-card-head">
            <view class="quick-entry-ai-card-title">下一步</view>
            <view class="quick-entry-ai-card-actions">
              <view wx:if="{{!quickEntryEditingAiNextSuggestion}}" class="section-link quick-entry-ai-card-link" bindtap="startEditingQuickEntryAiNextSuggestion">调整</view>
              <view wx:else class="section-link quick-entry-ai-card-link" bindtap="applyQuickEntryAiNextSuggestionDraft">应用修改</view>
              <view wx:if="{{quickEntryAiNextSuggestionOriginal && !quickEntryEditingAiNextSuggestion}}" class="section-link quick-entry-ai-card-link" bindtap="restoreQuickEntryAiNextSuggestion">恢复AI建议</view>
            </view>
          </view>
          <view wx:if="{{!quickEntryEditingAiNextSuggestion}}" class="quick-entry-ai-block">
            <view class="quick-entry-ai-text">{{quickEntryAiNextSuggestion.nextAction}}</view>
          </view>
          <view wx:else class="quick-entry-ai-block">
            <textarea
              class="textarea-sim textarea-native quick-entry-textarea is-small"
              value="{{quickEntryAiNextSuggestionDraft.nextAction}}"
              bindinput="onQuickEntryAiNextActionDraftInput"
              bindfocus="onQuickEntryFieldFocus"
              cursor-spacing="{{quickEntryCursorSpacing}}"
              placeholder="可按你的判断调整下一步动作"
              placeholder-class="input-placeholder"
              maxlength="-1"
            ></textarea>
          </view>
          <view class="quick-entry-ai-grid">
            <view class="quick-entry-ai-grid-item">
              <view class="quick-entry-ai-grid-label">对象</view>
              <view wx:if="{{!quickEntryEditingAiNextSuggestion}}" class="quick-entry-ai-grid-value">{{quickEntryAiNextSuggestion.recommendedTarget}}</view>
              <input
                wx:else
                class="input-sim input-native quick-entry-ai-grid-input"
                value="{{quickEntryAiNextSuggestionDraft.recommendedTarget}}"
                data-field="recommendedTarget"
                bindinput="onQuickEntryAiNextSuggestionDraftInput"
                bindfocus="onQuickEntryFieldFocus"
                cursor-spacing="{{quickEntryCursorSpacing}}"
                placeholder="例如：客户决策人"
                placeholder-class="input-placeholder"
              />
            </view>
            <view class="quick-entry-ai-grid-item">
              <view class="quick-entry-ai-grid-label">时间</view>
              <view wx:if="{{!quickEntryEditingAiNextSuggestion}}" class="quick-entry-ai-grid-value">{{quickEntryAiNextSuggestion.recommendedDate}} {{quickEntryAiNextSuggestion.recommendedTime}}</view>
              <view wx:else class="quick-entry-ai-grid-edit-row">
                <input
                  class="input-sim input-native quick-entry-ai-grid-input"
                  value="{{quickEntryAiNextSuggestionDraft.recommendedDate}}"
                  data-field="recommendedDate"
                  bindinput="onQuickEntryAiNextSuggestionDraftInput"
                  bindfocus="onQuickEntryFieldFocus"
                  cursor-spacing="{{quickEntryCursorSpacing}}"
                  placeholder="YYYY-MM-DD"
                  placeholder-class="input-placeholder"
                />
                <input
                  class="input-sim input-native quick-entry-ai-grid-input"
                  value="{{quickEntryAiNextSuggestionDraft.recommendedTime}}"
                  data-field="recommendedTime"
                  bindinput="onQuickEntryAiNextSuggestionDraftInput"
                  bindfocus="onQuickEntryFieldFocus"
                  cursor-spacing="{{quickEntryCursorSpacing}}"
                  placeholder="10:00"
                  placeholder-class="input-placeholder"
                />
              </view>
            </view>
          </view>
          <view wx:if="{{quickEntryEditingAiNextSuggestion}}" class="quick-entry-inline-edit-actions">
            <view class="section-link quick-entry-ai-card-link" bindtap="cancelEditingQuickEntryAiNextSuggestion">取消</view>
          </view>
        </view>
        </block>
      </block>

      <block wx:if="{{quickEntryMode === 'task'}}">
        <view class="field-group quick-entry-field-group">
          <view class="field-label">任务标题</view>
          <input
            class="input-sim input-native primary-title-input quick-entry-task-title-input"
            value="{{quickEntryForm.taskTitle}}"
            data-field="taskTitle"
            bindinput="onQuickEntryInput"
            bindfocus="onQuickEntryFieldFocus"
            cursor-spacing="{{quickEntryCursorSpacing}}"
            placeholder="填写任务标题，例如：本周五前发报价"
            placeholder-class="input-placeholder"
          />
        </view>
        <view class="field-group quick-entry-field-group">
          <view class="field-label">截止时间</view>
          <view class="split-row quick-entry-time-row">
            <picker class="picker-block" mode="date" value="{{quickEntryForm.taskDueDate}}" data-field="taskDueDate" bindchange="onQuickEntryPicker">
              <view class="picker-sim">
                <view class="picker-value">{{quickEntryForm.taskDueDate}}</view>
              </view>
            </picker>
            <picker class="picker-block" mode="time" value="{{quickEntryForm.taskDueTime}}" data-field="taskDueTime" bindchange="onQuickEntryPicker">
              <view class="picker-sim">
                <view class="picker-value">{{quickEntryForm.taskDueTime}}</view>
              </view>
            </picker>
          </view>
        </view>
        <view class="quick-entry-project-card">
          <view class="line-between quick-entry-project-head">
            <view class="quick-entry-project-summary">
              <view class="field-label quick-entry-inline-label">关联项目</view>
              <view class="quick-entry-selected-project {{quickEntrySelectedProjectMeta ? '' : 'is-placeholder'}}">{{quickEntrySelectedProjectName}}</view>
            </view>
            <view class="quick-entry-project-head-actions">
              <view wx:if="{{quickEntrySelectedProjectMeta}}" class="status-badge quick-entry-project-stage">{{quickEntrySelectedProjectMeta.stage}}</view>
              <view class="section-link quick-entry-project-link" bindtap="toggleQuickEntryProjectSearch">{{quickEntryShowProjectSearch ? '收起' : '更多项目'}}</view>
            </view>
          </view>
          <view wx:if="{{quickEntrySelectedProjectMeta}}" class="helper-text quick-entry-project-meta">{{quickEntrySelectedProjectMeta.client}}<text wx:if="{{quickEntrySelectedProjectMeta.nextText}}"> · {{quickEntrySelectedProjectMeta.nextText}}</text><text wx:if="{{quickEntryProjectSelectionMode === 'auto'}}"> · 已按内容匹配</text></view>
          <view wx:else class="helper-text quick-entry-project-meta">先把动作定下来，再从最近项目里选一个关联即可。</view>
          <view wx:if="{{quickEntrySuggestedProjects.length}}" class="chips quick-entry-project-suggest-wall">
            <view
              wx:for="{{quickEntrySuggestedProjects}}"
              wx:key="id"
              class="chip quick-entry-project-suggest-chip {{quickEntrySelectedProjectId === item.id ? 'is-active' : ''}}"
              data-project-id="{{item.id}}"
              bindtap="selectQuickEntryProject"
            >{{item.name}}</view>
          </view>
          <block wx:if="{{quickEntryShowProjectSearch}}">
            <view class="search-panel quick-entry-project-search">
              <input
                class="input-sim input-native projects-search-input"
                value="{{quickEntryProjectKeyword}}"
                bindinput="onQuickEntryProjectSearch"
                bindfocus="onQuickEntryFieldFocus"
                placeholder="搜索项目 / 客户 / 联系人"
                placeholder-class="input-placeholder"
                confirm-type="search"
                cursor-spacing="{{quickEntryCursorSpacing}}"
              />
              <view wx:if="{{quickEntryProjectKeyword}}" class="search-clear" bindtap="clearQuickEntryProjectSearch">清空</view>
            </view>
            <view wx:if="{{quickEntryVisibleProjects.length}}" class="quick-entry-project-list">
              <view
                wx:for="{{quickEntryVisibleProjects}}"
                wx:key="id"
                class="quick-entry-project-option {{quickEntrySelectedProjectId === item.id ? 'is-active' : ''}}"
                data-project-id="{{item.id}}"
                bindtap="selectQuickEntryProject"
              >
                <view class="quick-entry-project-option-top">
                  <view class="quick-entry-project-option-name">{{item.name}}</view>
                  <view class="field-pill quick-entry-project-option-pill">{{item.stage}}</view>
                </view>
                <view class="helper-text quick-entry-project-option-meta">{{item.client}}<text wx:if="{{item.contactText}}"> · {{item.contactText}}</text></view>
                <view wx:if="{{item.nextText || item.focusText || item.latestSummary}}" class="quick-entry-project-option-brief">{{item.nextText || item.focusText || item.latestSummary}}</view>
              </view>
            </view>
            <view wx:else class="helper-text quick-entry-empty">没有找到匹配项目，可以先切到“新建项目”。</view>
          </block>
        </view>
        <view class="field-group quick-entry-field-group">
          <view class="field-label">任务类型</view>
          <view class="chips quick-entry-task-wall">
            <view
              wx:for="{{nextTaskTemplates}}"
              wx:key="type"
              class="chip quick-entry-task-chip {{quickEntryForm.taskType === item.type ? 'is-active' : ''}}"
              data-type="{{item.type}}"
              bindtap="setQuickEntryTaskType"
            >{{item.label}}</view>
          </view>
        </view>
        <view class="field-group quick-entry-field-group">
          <view class="field-label">动作背景</view>
          <textarea
            class="textarea-sim textarea-native quick-entry-textarea is-compact"
            value="{{quickEntryForm.taskContext}}"
            data-field="taskContext"
            bindinput="onQuickEntryInput"
            bindfocus="onQuickEntryFieldFocus"
            cursor-spacing="{{quickEntryCursorSpacing}}"
            placeholder="可选：补一句当前为什么要做这件事。"
            placeholder-class="input-placeholder"
            maxlength="-1"
          ></textarea>
        </view>
        <view class="field-group quick-entry-field-group">
          <view class="field-label">任务说明</view>
          <textarea
            class="textarea-sim textarea-native quick-entry-textarea is-small"
            value="{{quickEntryForm.taskDescription}}"
            data-field="taskDescription"
            bindinput="onQuickEntryInput"
            bindfocus="onQuickEntryFieldFocus"
            cursor-spacing="{{quickEntryCursorSpacing}}"
            placeholder="可选：补一句执行时需要注意的事项。"
            placeholder-class="input-placeholder"
            maxlength="-1"
          ></textarea>
        </view>
      </block>
      </block>
    </view>
    <view wx:if="{{!showQuickEntrySuccessPanel && !(quickEntryMode === 'follow_up' && !quickEntryShowFollowUpDetails)}}" class="inline-actions quick-entry-actions is-fixed {{isQuickEntryEditing ? 'is-editing' : ''}}" style="{{quickEntryActionsStyle}}">
      <view wx:if="{{quickEntryMode === 'follow_up'}}" class="helper-text quick-entry-actions-hint {{quickEntryFollowUpCanSubmit ? 'is-ready' : ''}}">{{quickEntryFollowUpSubmitHint}}</view>
      <view class="btn-ghost quick-entry-cancel-btn" bindtap="onQuickEntryCancelTap">{{quickEntryMode === 'follow_up' && quickEntryFollowUpStage === 'content' ? '返回修改' : '取消'}}</view>
      <view class="btn-primary quick-entry-submit-btn {{quickEntryMode === 'follow_up' && !quickEntryFollowUpCanSubmit ? 'is-disabled' : ''}}" bindtap="submitQuickEntry">
        <block wx:if="{{quickEntryMode === 'project'}}">{{quickEntryActionId === 'project' ? '创建中...' : '立即创建'}}</block>
        <block wx:elif="{{quickEntryMode === 'task'}}">{{quickEntryActionId === 'task' ? '保存中...' : '补进清单'}}</block>
        <block wx:else>{{quickEntryFollowUpSubmitText}}</block>
      </view>
    </view>
    <view wx:else class="quick-entry-success-actions">
      <view class="btn-primary quick-entry-success-primary" bindtap="continueQuickEntryAfterSuccess">{{quickEntrySuccessState.primaryActionText}}</view>
      <view class="inline-actions quick-entry-success-secondary-row">
        <view wx:if="{{quickEntrySuccessState.projectId}}" class="btn-ghost quick-entry-success-secondary" bindtap="openQuickEntrySavedProject">{{quickEntrySuccessState.projectActionText}}</view>
        <view class="btn-ghost quick-entry-success-secondary" bindtap="closeQuickEntryAfterSuccess">关闭</view>
      </view>
    </view>
  </view>
</view>

<view wx:if="{{showTaskCompleteSheet}}">
  <view class="sheet-mask task-complete-mask" bindtap="closeTaskCompleteSheet"></view>
  <view class="sheet-panel task-complete-sheet {{appearancePageClass}} {{isTaskCompletionEditing ? 'is-editing' : ''}}" style="{{taskCompleteSheetStyle}}">
    <view class="sheet-handle"></view>
    <view class="sheet-header">
      <view class="sheet-title">完成：{{taskCompletionTaskTitle}}</view>
      <view class="sheet-close" bindtap="closeTaskCompleteSheet">关闭</view>
    </view>
    <view class="task-complete-body" style="{{taskCompleteBodyStyle}}">
      <view class="field-group task-complete-field">
        <view class="field-label">完成情况 · 提交后自动写入时间线</view>
        <textarea
          class="textarea-sim textarea-native task-complete-textarea"
          value="{{taskCompletionText}}"
          bindinput="onTaskCompletionInput"
          bindfocus="onTaskCompletionFieldFocus"
          cursor-spacing="{{taskCompletionCursorSpacing}}"
          placeholder="例如：报价已发送，客户确认本周三内部评审，若通过则进入合同沟通。"
          placeholder-class="input-placeholder"
          maxlength="-1"
        ></textarea>
        <view wx:if="{{isTaskCompletionVoiceSupported}}" class="task-complete-voice-row">
          <view class="btn-ghost task-complete-voice-btn {{isTaskCompletionVoiceRecording ? 'is-recording' : ''}} {{isTaskCompletionVoiceRecognizing ? 'is-busy' : ''}}" bindtap="handleTaskCompletionVoiceInput">
            <view class="voice-button-content">
              <view wx:if="{{isTaskCompletionVoiceRecording}}" class="voice-receiver">
                <view class="voice-receiver-bar is-one"></view>
                <view class="voice-receiver-bar is-two"></view>
                <view class="voice-receiver-bar is-three"></view>
                <view class="voice-receiver-bar is-four"></view>
              </view>
              <text class="voice-button-label">{{isTaskCompletionVoiceRecording ? '结束录音' : (isTaskCompletionVoiceRecognizing ? '识别中...' : '语音录入')}}</text>
              <text wx:if="{{isTaskCompletionVoiceRecording && taskCompletionVoiceElapsedText}}" class="voice-button-timer">{{taskCompletionVoiceElapsedText}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="task-complete-inline-entry">
        <view wx:if="{{!taskCompletionCreateNextTask}}" class="btn-ghost task-complete-inline-btn" bindtap="toggleTaskCompletionCreateNextTask">补下一步动作</view>
      </view>
      <view wx:if="{{taskCompletionCreateNextTask}}" class="task-complete-next-card">
        <view class="line-between task-complete-next-head">
          <view>
            <view class="task-complete-toggle-title">下一步任务</view>
          </view>
          <view class="section-link" bindtap="toggleTaskCompletionCreateNextTask">收起</view>
        </view>
        <view class="field-group task-complete-field is-inline-first">
          <input
            class="input-sim input-native primary-title-input task-complete-title-input"
            value="{{taskCompletionNextTaskTitle}}"
            data-field="taskCompletionNextTaskTitle"
            bindinput="onTaskCompletionNextTaskInput"
            bindfocus="onTaskCompletionFieldFocus"
            cursor-spacing="{{taskCompletionCursorSpacing}}"
            placeholder="填写下一步任务，例如：3天后回访报价反馈"
            placeholder-class="input-placeholder"
          />
        </view>
        <view class="field-group task-complete-field">
          <view class="field-label">任务类型</view>
          <view class="chips task-complete-type-wall">
            <view
              class="chip {{taskCompletionNextTaskType === item.type ? 'is-active' : ''}}"
              wx:for="{{nextTaskTemplates}}"
              wx:key="type"
              data-type="{{item.type}}"
              bindtap="setTaskCompletionNextTaskType"
            >{{item.label}}</view>
          </view>
        </view>
        <view class="field-group task-complete-field">
          <view class="field-label">下一步时间</view>
          <view class="split-row task-complete-time-row">
            <picker class="picker-block" mode="date" value="{{taskCompletionNextTaskDate}}" data-field="taskCompletionNextTaskDate" bindchange="onTaskCompletionNextTaskPicker">
              <view class="picker-sim">
                <view class="picker-value {{!taskCompletionNextTaskDate ? 'is-placeholder' : ''}}">{{taskCompletionNextTaskDate || '选择日期'}}</view>
              </view>
            </picker>
            <picker class="picker-block" mode="time" value="{{taskCompletionNextTaskTime}}" data-field="taskCompletionNextTaskTime" bindchange="onTaskCompletionNextTaskPicker">
              <view class="picker-sim">
                <view class="picker-value {{!taskCompletionNextTaskTime ? 'is-placeholder' : ''}}">{{taskCompletionNextTaskTime || '选择时间'}}</view>
              </view>
            </picker>
          </view>
        </view>
        <view class="field-group task-complete-field">
          <view class="field-label">任务说明</view>
          <textarea
            class="textarea-sim textarea-native task-complete-next-textarea"
            value="{{taskCompletionNextTaskDescription}}"
            data-field="taskCompletionNextTaskDescription"
            bindinput="onTaskCompletionNextTaskInput"
            bindfocus="onTaskCompletionFieldFocus"
            cursor-spacing="{{taskCompletionCursorSpacing}}"
            placeholder="可选：补一句下一步要重点确认什么。"
            placeholder-class="input-placeholder"
            maxlength="-1"
          ></textarea>
        </view>
      </view>
    </view>
    <view class="inline-actions task-complete-actions is-fixed {{isTaskCompletionEditing ? 'is-editing' : ''}}" style="{{taskCompleteActionsStyle}}">
      <view class="btn-ghost" bindtap="closeTaskCompleteSheet">取消</view>
      <view class="btn-primary" bindtap="submitTaskCompletion">{{taskActionId === taskCompletionTaskId ? '提交中...' : '确认完成'}}</view>
    </view>
  </view>
</view>

<bottom-nav current="home" appearance-page-class="{{appearancePageClass}}" bind:quickentry="handleQuickEntryTap" />
