              </view>
              <view class="quick-entry-source-preview">{{quickEntryForm.followUpContent}}</view>
            </view>
          </block>
          <block wx:else>
            <view class="field-group quick-entry-field-group">
              <view wx:if="{{(quickEntryManualInputEnabled && !isQuickEntryVoiceRecording && !isQuickEntryVoiceRecognizing && !isQuickEntryAiLoading) || quickEntryFollowUpStage === 'project'}}" class="quick-entry-field-head-actions quick-entry-field-head-actions-standalone">
                <view wx:if="{{quickEntryManualInputEnabled && !isQuickEntryVoiceRecording && !isQuickEntryVoiceRecognizing && !isQuickEntryAiLoading}}" class="section-link quick-entry-ai-link" bindtap="returnQuickEntryToVoiceInput">切回语音录入</view>
                <view wx:if="{{quickEntryFollowUpStage === 'project'}}" class="section-link quick-entry-ai-link" bindtap="returnQuickEntryFollowUpToContent">返回修改</view>
              </view>
              <view wx:if="{{!quickEntryManualInputEnabled}}" class="quick-entry-inline-voice-actions">
                <view class="quick-entry-voice-btn-shell quick-entry-inline-voice-shell {{isQuickEntryVoiceRecording ? 'is-recording' : ''}}">
                  <view class="btn-secondary quick-entry-voice-btn quick-entry-inline-voice-btn {{isQuickEntryVoiceRecording ? 'is-recording' : ''}} {{(isQuickEntryVoiceRecognizing || isQuickEntryAiLoading) ? 'is-busy' : ''}}" bindtap="startQuickEntryVoiceInput">
                    <view class="voice-button-content">
                      <view wx:if="{{isQuickEntryVoiceRecording}}" class="voice-receiver">
                        <view class="voice-receiver-bar is-one"></view>
                        <view class="voice-receiver-bar is-two"></view>
                        <view class="voice-receiver-bar is-three"></view>
                        <view class="voice-receiver-bar is-four"></view>
                      </view>
                      <text class="voice-button-label">{{isQuickEntryVoiceRecording ? '结束录音' : (isQuickEntryVoiceRecognizing ? '识别中...' : '语音录入')}}</text>
                      <text wx:if="{{isQuickEntryVoiceRecording && quickEntryVoiceElapsedText}}" class="voice-button-timer">{{quickEntryVoiceElapsedText}}</text>
                    </view>
                  </view>
                </view>
              </view>
              <textarea
                class="textarea-sim textarea-native quick-entry-textarea"
                value="{{quickEntryForm.followUpContent}}"
                data-field="followUpContent"
                bindinput="onQuickEntryInput"
                bindfocus="onQuickEntryFieldFocus"
                cursor-spacing="{{quickEntryCursorSpacing}}"
                placeholder="{{quickEntryManualInputEnabled ? '例如：客户说周五看方案，下周二再确认预算' : '把刚刚说的话整理一下，确认后再交给 AI'}}"
                placeholder-class="input-placeholder"
                maxlength="-1"
              ></textarea>
              <view wx:if="{{quickEntryVoicePreviewText && quickEntryFollowUpStage !== 'capture' && quickEntryVoicePreviewText !== quickEntryForm.followUpContent}}" class="quick-entry-inline-preview">
                <view class="quick-entry-inline-preview-label">识别原文</view>
                <view class="quick-entry-inline-preview-text">{{quickEntryVoicePreviewText}}</view>
              </view>
              <view wx:if="{{quickEntryVoiceStatusText && (quickEntryVoicePhase !== 'idle' || isQuickEntryVoiceRecording || isQuickEntryVoiceRecognizing || isQuickEntryAiLoading || quickEntryAiError)}}" class="helper-text quick-entry-inline-note">{{quickEntryVoiceStatusText}}</view>
              <view wx:if="{{quickEntryForm.followUpContent && quickEntryFollowUpStage === 'content' && quickEntrySelectedProjectMeta}}" class="quick-entry-project-inline-hint is-hit">
                <view class="quick-entry-project-inline-text">
                  可能命中：{{quickEntrySelectedProjectMeta.name}}<text wx:if="{{quickEntrySelectedProjectMeta.client}}"> / {{quickEntrySelectedProjectMeta.client}}</text>
                </view>
              </view>
            </view>
            <view wx:if="{{quickEntryAiError}}" class="quick-entry-ai-state-card">
              <view class="quick-entry-ai-state-title">当前无法完成智能理解</view>
              <view class="helper-text quick-entry-ai-state-desc">{{quickEntryAiError}}</view>
            </view>
            <view wx:if="{{isQuickEntryAiLoading}}" class="quick-entry-ai-state-card">
              <view class="ai-agent-loader quick-entry-ai-state-loader">
                <view class="ai-agent-loader-antenna is-left"><view class="ai-agent-loader-dot"></view></view>
                <view class="ai-agent-loader-antenna is-right"><view class="ai-agent-loader-dot"></view></view>
                <view class="ai-agent-loader-cap"></view>
                <view class="ai-agent-loader-ear is-left"></view>
                <view class="ai-agent-loader-ear is-right"></view>
                <view class="ai-agent-loader-head">
                  <view class="ai-agent-loader-eye is-left"></view>
                  <view class="ai-agent-loader-eye is-right"></view>
                  <view class="ai-agent-loader-mouth"></view>
                </view>
              </view>
              <view class="quick-entry-ai-state-title">正在理解这条闪录</view>
              <view class="helper-text quick-entry-ai-state-desc">{{quickEntryAiLoadingHint}}</view>
            </view>
            <view wx:if="{{quickEntryFollowUpStage === 'project'}}" class="quick-entry-project-card is-confirm">
              <view class="quick-entry-project-head is-confirm">
                <view class="quick-entry-project-summary">
                  <view class="quick-entry-project-main-line">
                    <view class="quick-entry-project-line-copy {{quickEntrySelectedProjectMeta ? '' : 'is-placeholder'}}">
                      <block wx:if="{{quickEntrySelectedProjectMeta}}">
                        <view class="quick-entry-project-line-name">{{quickEntrySelectedProjectMeta.name}}</view>
                        <view wx:if="{{quickEntrySelectedProjectMeta.client}}" class="quick-entry-project-line-company">· {{quickEntrySelectedProjectMeta.client}}</view>
                      </block>
                      <view wx:else class="quick-entry-project-line-placeholder">{{quickEntrySelectedProjectName}}</view>
                    </view>
                    <view class="status-badge quick-entry-project-state-badge {{quickEntryProjectSelectionMode === 'manual' ? 'is-manual' : (quickEntrySelectedProjectMeta ? 'is-hit' : 'is-pending')}}">
                      <block wx:if="{{quickEntryProjectSelectionMode === 'manual'}}">已调整</block>
                      <block wx:elif="{{quickEntryProjectSelectionMode === 'ai_auto'}}">已匹配</block>
                      <block wx:elif="{{quickEntrySelectedProjectMeta}}">已命中</block>
                      <block wx:else>待选择</block>
                    </view>
                  </view>
                </view>
              </view>
              <view wx:if="{{!quickEntrySelectedProjectMeta}}" class="helper-text quick-entry-project-meta">{{quickEntryAiProjectMatch && quickEntryAiProjectMatch.status === 'candidates' ? '未自动确认项目，请从项目库选择。' : '未匹配到项目，请从项目库选择。'}}</view>
              <view wx:if="{{quickEntrySuggestedProjects.length > 1 && !quickEntryShowProjectSearch && quickEntryProjectSelectionMode !== 'manual' && ((quickEntryAiProjectMatch && quickEntryAiProjectMatch.status === 'candidates') || quickEntryProjectSelectionMode === 'auto')}}" class="quick-entry-project-choice-list">
                <view
                  wx:for="{{quickEntrySuggestedProjects}}"
                  wx:key="id"
                  class="quick-entry-project-choice-item {{quickEntrySelectedProjectId === item.id ? 'is-active' : ''}} {{(isQuickEntryAiLoading || isQuickEntryVoiceRecognizing) ? 'is-disabled' : ''}}"
                  data-project-id="{{item.id}}"
                  bindtap="selectQuickEntryProject"
                >
                  <view class="quick-entry-project-choice-line">
                    <view class="quick-entry-project-choice-name">{{item.name}}</view>
                    <view wx:if="{{item.client}}" class="quick-entry-project-choice-company">· {{item.client}}</view>
                  </view>
                </view>
              </view>
              <block wx:if="{{quickEntryShowProjectSearch}}">
                <view class="search-panel quick-entry-project-search">
                  <view class="input-sim quick-entry-search-shell">
                    <image class="quick-entry-search-icon" src="/assets/icons/search-light.svg" mode="aspectFit" />
                    <input
                      class="input-native projects-search-input"
                      value="{{quickEntryProjectKeyword}}"
                      bindinput="onQuickEntryProjectSearch"
                      bindfocus="onQuickEntryFieldFocus"
                      placeholder="搜索项目、公司、联系人"
                      placeholder-class="quick-entry-search-placeholder"
                      confirm-type="search"
                      cursor-spacing="{{quickEntryCursorSpacing}}"
                    />
                    <view wx:if="{{quickEntryProjectKeyword}}" class="search-clear" bindtap="clearQuickEntryProjectSearch">清空</view>
                  </view>
                </view>
                <view wx:if="{{quickEntryVisibleProjects.length}}" class="quick-entry-project-list">
                  <view
                    wx:for="{{quickEntryVisibleProjects}}"
                    wx:key="id"
                    class="quick-entry-project-option {{quickEntrySelectedProjectId === item.id ? 'is-active' : ''}} {{(isQuickEntryAiLoading || isQuickEntryVoiceRecognizing) ? 'is-disabled' : ''}}"
                    data-project-id="{{item.id}}"
                    bindtap="selectQuickEntryProject"
                  >
                    <view class="quick-entry-project-option-top">
                      <view class="quick-entry-project-option-name">{{item.name}}</view>
                      <view class="quick-entry-project-option-badges">
                        <view class="field-pill quick-entry-project-option-pill">{{item.stage}}</view>
                      </view>
                    </view>
                    <view class="helper-text quick-entry-project-option-meta">{{item.client}}<text wx:if="{{item.contactText}}"> · {{item.contactText}}</text></view>
                    <view wx:if="{{item.nextText || item.focusText || item.latestSummary}}" class="quick-entry-project-option-brief">{{item.nextText || item.focusText || item.latestSummary}}</view>
                  </view>
                </view>
                <view wx:else class="helper-text quick-entry-empty">没有找到匹配项目，可以先切到“新建项目”。</view>
              </block>
              <view class="quick-entry-project-footer">
                <view class="section-link quick-entry-project-footer-link" bindtap="toggleQuickEntryProjectSearch">
                  {{quickEntryShowProjectSearch ? '收起项目库' : (quickEntrySelectedProjectMeta ? '项目不对，换一个' : '从项目库选择')}}
                </view>
              </view>
            </view>
          </block>
        </block>
      </block>

      <block wx:if="{{quickEntryMode === 'task'}}">
        <view class="field-group quick-entry-field-group">
          <view class="field-label">任务标题</view>
          <input
            class="input-sim input-native primary-title-input quick-entry-task-title-input"
            value="{{quickEntryForm.taskTitle}}"
            data-field="taskTitle"
            bindinput="onQuickEntryInput"
            bindfocus="onQuickEntryFieldFocus"
            cursor-spacing="{{quickEntryCursorSpacing}}"
            placeholder="填写任务标题，例如：本周五前发报价"
            placeholder-class="input-placeholder"
          />
        </view>
        <view class="field-group quick-entry-field-group">
          <view class="field-label">截止时间</view>
          <view class="split-row quick-entry-time-row">
            <picker class="picker-block" mode="date" value="{{quickEntryForm.taskDueDate}}" data-field="taskDueDate" bindchange="onQuickEntryPicker">
              <view class="picker-sim">
                <view class="picker-value">{{quickEntryForm.taskDueDate}}</view>
              </view>
            </picker>
            <picker class="picker-block" mode="time" value="{{quickEntryForm.taskDueTime}}" data-field="taskDueTime" bindchange="onQuickEntryPicker">
              <view class="picker-sim">
                <view class="picker-value">{{quickEntryForm.taskDueTime}}</view>
              </view>
            </picker>
          </view>
        </view>
        <view class="quick-entry-project-card">
          <view class="line-between quick-entry-project-head">
            <view class="quick-entry-project-summary">
              <view class="field-label quick-entry-inline-label">关联项目</view>
              <view class="quick-entry-selected-project {{quickEntrySelectedProjectMeta ? '' : 'is-placeholder'}}">{{quickEntrySelectedProjectName}}</view>
            </view>
            <view class="quick-entry-project-head-actions">
              <view wx:if="{{quickEntrySelectedProjectMeta}}" class="status-badge quick-entry-project-stage">{{quickEntrySelectedProjectMeta.stage}}</view>
              <view class="section-link quick-entry-project-link" bindtap="toggleQuickEntryProjectSearch">{{quickEntryShowProjectSearch ? '收起' : '更多项目'}}</view>
            </view>
          </view>
          <view wx:if="{{quickEntrySelectedProjectMeta}}" class="helper-text quick-entry-project-meta">{{quickEntrySelectedProjectMeta.client}}<text wx:if="{{quickEntrySelectedProjectMeta.nextText}}"> · {{quickEntrySelectedProjectMeta.nextText}}</text><text wx:if="{{quickEntryProjectSelectionMode === 'auto'}}"> · 已按内容匹配</text></view>
          <view wx:else class="helper-text quick-entry-project-meta">先把动作定下来，再从最近项目里选一个关联即可。</view>
          <view wx:if="{{quickEntrySuggestedProjects.length}}" class="chips quick-entry-project-suggest-wall">
            <view
              wx:for="{{quickEntrySuggestedProjects}}"
              wx:key="id"
              class="chip quick-entry-project-suggest-chip {{quickEntrySelectedProjectId === item.id ? 'is-active' : ''}}"
              data-project-id="{{item.id}}"
              bindtap="selectQuickEntryProject"
            >{{item.name}}</view>
          </view>
          <block wx:if="{{quickEntryShowProjectSearch}}">
            <view class="search-panel quick-entry-project-search">
              <view class="input-sim quick-entry-search-shell">
                <image class="quick-entry-search-icon" src="/assets/icons/search-light.svg" mode="aspectFit" />
                <input
                  class="input-native projects-search-input"
                  value="{{quickEntryProjectKeyword}}"
                  bindinput="onQuickEntryProjectSearch"
                  bindfocus="onQuickEntryFieldFocus"
                  placeholder="搜索项目、公司、联系人"
                  placeholder-class="quick-entry-search-placeholder"
                  confirm-type="search"
                  cursor-spacing="{{quickEntryCursorSpacing}}"
                />
                <view wx:if="{{quickEntryProjectKeyword}}" class="search-clear" bindtap="clearQuickEntryProjectSearch">清空</view>
              </view>
            </view>
            <view wx:if="{{quickEntryVisibleProjects.length}}" class="quick-entry-project-list">
              <view
                wx:for="{{quickEntryVisibleProjects}}"
                wx:key="id"
                class="quick-entry-project-option {{quickEntrySelectedProjectId === item.id ? 'is-active' : ''}}"
                data-project-id="{{item.id}}"
                bindtap="selectQuickEntryProject"
              >
                <view class="quick-entry-project-option-top">
                  <view class="quick-entry-project-option-name">{{item.name}}</view>
                  <view class="field-pill quick-entry-project-option-pill">{{item.stage}}</view>
                </view>
                <view class="helper-text quick-entry-project-option-meta">{{item.client}}<text wx:if="{{item.contactText}}"> · {{item.contactText}}</text></view>
                <view wx:if="{{item.nextText || item.focusText || item.latestSummary}}" class="quick-entry-project-option-brief">{{item.nextText || item.focusText || item.latestSummary}}</view>
              </view>
            </view>
            <view wx:else class="helper-text quick-entry-empty">没有找到匹配项目，可以先切到“新建项目”。</view>
          </block>
        </view>
        <view class="field-group quick-entry-field-group">
          <view class="field-label">任务类型</view>
          <view class="chips quick-entry-task-wall">
            <view
              wx:for="{{nextTaskTemplates}}"
              wx:key="type"
              class="chip quick-entry-task-chip {{quickEntryForm.taskType === item.type ? 'is-active' : ''}}"
              data-type="{{item.type}}"
              bindtap="setQuickEntryTaskType"
            >{{item.label}}</view>
          </view>
        </view>
        <view class="field-group quick-entry-field-group">
          <view class="field-label">动作背景</view>
          <textarea
            class="textarea-sim textarea-native quick-entry-textarea is-compact"
            value="{{quickEntryForm.taskContext}}"
            data-field="taskContext"
            bindinput="onQuickEntryInput"
            bindfocus="onQuickEntryFieldFocus"
            cursor-spacing="{{quickEntryCursorSpacing}}"
            placeholder="可选：补一句当前为什么要做这件事。"
            placeholder-class="input-placeholder"
            maxlength="-1"
          ></textarea>
        </view>
        <view class="field-group quick-entry-field-group">
          <view class="field-label">任务说明</view>
          <textarea
            class="textarea-sim textarea-native quick-entry-textarea is-small"
            value="{{quickEntryForm.taskDescription}}"
            data-field="taskDescription"
            bindinput="onQuickEntryInput"
            bindfocus="onQuickEntryFieldFocus"
            cursor-spacing="{{quickEntryCursorSpacing}}"
            placeholder="可选：补一句执行时需要注意的事项。"
            placeholder-class="input-placeholder"
            maxlength="-1"
          ></textarea>
        </view>
      </block>
      </block>
    </view>
    <view wx:if="{{!showQuickEntrySuccessPanel && !(quickEntryMode === 'follow_up' && !quickEntryShowFollowUpDetails)}}" class="inline-actions quick-entry-actions is-fixed {{isQuickEntryEditing ? 'is-editing' : ''}}" style="{{quickEntryActionsStyle}}">
      <block wx:if="{{quickEntryMode === 'follow_up'}}">
        <block wx:if="{{quickEntryFollowUpStage === 'project' && quickEntrySelectedProjectId}}">
          <view class="quick-entry-dual-submit-row">
            <view class="btn-ghost quick-entry-dual-submit-btn {{quickEntryActionId === 'follow_up' || isQuickEntryVoiceRecognizing || isQuickEntryAiLoading ? 'is-disabled' : ''}}" bindtap="submitQuickFollowUpOnly">{{quickEntryActionId === 'follow_up' && quickEntryFollowUpPendingAction === 'save_only' ? '保存中...' : '直接保存'}}</view>
            <view class="btn-primary quick-entry-submit-btn is-single ai-entry ai-entry-button {{!quickEntryFollowUpCanSubmit ? 'is-disabled' : ''}}" bindtap="submitQuickEntry">
              <image wx:if="{{!isQuickEntryAiLoading}}" class="ai-entry-icon" src="/assets/icons/ai-agent-light.svg" mode="aspectFit" />
              <view wx:else class="ai-agent-loader is-light">
                <view class="ai-agent-loader-antenna is-left"><view class="ai-agent-loader-dot"></view></view>
                <view class="ai-agent-loader-antenna is-right"><view class="ai-agent-loader-dot"></view></view>
                <view class="ai-agent-loader-cap"></view>
                <view class="ai-agent-loader-ear is-left"></view>
                <view class="ai-agent-loader-ear is-right"></view>
                <view class="ai-agent-loader-head">
                  <view class="ai-agent-loader-eye is-left"></view>
                  <view class="ai-agent-loader-eye is-right"></view>
                  <view class="ai-agent-loader-mouth"></view>
                </view>
              </view>
              <view class="ai-entry-text">{{quickEntryFollowUpSubmitText}}</view>
            </view>
          </view>
        </block>
        <block wx:elif="{{quickEntryAiNextSuggestion && quickEntryFollowUpStage === 'review'}}">
          <view class="quick-entry-dual-submit-row">
            <view class="btn-ghost quick-entry-dual-submit-btn {{quickEntryActionId === 'follow_up' ? 'is-disabled' : ''}}" bindtap="submitQuickFollowUpOnly">{{quickEntryActionId === 'follow_up' && quickEntryFollowUpPendingAction === 'save_only' ? '保存中...' : '仅保存跟进'}}</view>
            <view class="btn-primary quick-entry-submit-btn quick-entry-dual-submit-main {{(quickEntryActionId === 'follow_up' || !quickEntryTaskDraftCanCreate) ? 'is-disabled' : ''}}" bindtap="submitQuickFollowUpWithTask">
              <view class="quick-entry-dual-submit-copy">
                <view class="quick-entry-dual-submit-title">{{quickEntryActionId === 'follow_up' && quickEntryFollowUpPendingAction === 'save_with_task' ? '创建中...' : '保存并创建任务'}}</view>
                <view class="quick-entry-dual-submit-meta">{{quickEntryActionId === 'follow_up' && quickEntryFollowUpPendingAction === 'save_with_task' ? '正在写入跟进与任务' : (quickEntryNextTaskSelectedTimeLabel ? quickEntryNextTaskSelectedTimeLabel : '请先确认任务时间')}}</view>
              </view>
            </view>
          </view>
        </block>
        <block wx:else>
          <view class="btn-primary quick-entry-submit-btn is-single {{quickEntryFollowUpSubmitIsAiAction ? 'ai-entry ai-entry-button' : ''}} {{!quickEntryFollowUpCanSubmit ? 'is-disabled' : ''}}" bindtap="submitQuickEntry">
            <block wx:if="{{quickEntryFollowUpSubmitIsAiAction}}">
              <image wx:if="{{!isQuickEntryAiLoading}}" class="ai-entry-icon" src="/assets/icons/ai-agent-light.svg" mode="aspectFit" />
              <view wx:else class="ai-agent-loader is-light">
                <view class="ai-agent-loader-antenna is-left"><view class="ai-agent-loader-dot"></view></view>
                <view class="ai-agent-loader-antenna is-right"><view class="ai-agent-loader-dot"></view></view>
                <view class="ai-agent-loader-cap"></view>
                <view class="ai-agent-loader-ear is-left"></view>
                <view class="ai-agent-loader-ear is-right"></view>
                <view class="ai-agent-loader-head">
                  <view class="ai-agent-loader-eye is-left"></view>
                  <view class="ai-agent-loader-eye is-right"></view>
                  <view class="ai-agent-loader-mouth"></view>
                </view>
              </view>
              <view class="ai-entry-text">{{quickEntryFollowUpSubmitText}}</view>
            </block>
            <block wx:else>{{quickEntryFollowUpSubmitText}}</block>
          </view>
        </block>
      </block>
      <block wx:else>
        <view class="btn-ghost quick-entry-cancel-btn" bindtap="onQuickEntryCancelTap">取消</view>
        <view class="btn-primary quick-entry-submit-btn" bindtap="submitQuickEntry">
          <block wx:if="{{quickEntryMode === 'project'}}">{{quickEntryActionId === 'project' ? '创建中...' : '立即创建'}}</block>
          <block wx:else>{{quickEntryActionId === 'task' ? '保存中...' : '补进清单'}}</block>
        </view>
      </block>
    </view>
    <view wx:if="{{showQuickEntrySuccessPanel}}" class="quick-entry-success-actions">
      <view class="btn-primary quick-entry-success-primary" bindtap="continueQuickEntryAfterSuccess">{{quickEntrySuccessState.primaryActionText}}</view>
      <view class="inline-actions quick-entry-success-secondary-row">
        <view wx:if="{{quickEntrySuccessState.projectId}}" class="btn-ghost quick-entry-success-secondary" bindtap="openQuickEntrySavedProject">{{quickEntrySuccessState.projectActionText}}</view>
        <view class="btn-ghost quick-entry-success-secondary" bindtap="closeQuickEntryAfterSuccess">关闭</view>
      </view>
    </view>
  </view>
</view>

<view wx:if="{{showTaskCompleteSheet}}">
  <view class="sheet-mask task-complete-mask" bindtap="closeTaskCompleteSheet"></view>
  <view class="sheet-panel task-complete-sheet {{appearancePageClass}} {{isTaskCompletionEditing ? 'is-editing' : ''}}" style="{{taskCompleteSheetStyle}}">
    <view class="sheet-handle"></view>
    <view class="sheet-header">
      <view class="sheet-title">完成：{{taskCompletionTaskTitle}}</view>
      <view class="sheet-close" bindtap="closeTaskCompleteSheet">关闭</view>
    </view>
    <view class="task-complete-body" style="{{taskCompleteBodyStyle}}">
      <view class="field-group task-complete-field">
        <view class="field-label">完成情况 · 提交后自动写入时间线</view>
        <textarea
          class="textarea-sim textarea-native task-complete-textarea"
          value="{{taskCompletionText}}"
          bindinput="onTaskCompletionInput"
          bindfocus="onTaskCompletionFieldFocus"
          cursor-spacing="{{taskCompletionCursorSpacing}}"
          placeholder="例如：报价已发送，客户确认本周三内部评审，若通过则进入合同沟通。"
          placeholder-class="input-placeholder"
          maxlength="-1"
        ></textarea>
        <view wx:if="{{isTaskCompletionVoiceSupported}}" class="task-complete-voice-row">
          <view class="btn-ghost task-complete-voice-btn {{isTaskCompletionVoiceRecording ? 'is-recording' : ''}} {{isTaskCompletionVoiceRecognizing ? 'is-busy' : ''}}" bindtap="handleTaskCompletionVoiceInput">
            <view class="voice-button-content">
              <view wx:if="{{isTaskCompletionVoiceRecording}}" class="voice-receiver">
                <view class="voice-receiver-bar is-one"></view>
                <view class="voice-receiver-bar is-two"></view>
                <view class="voice-receiver-bar is-three"></view>
                <view class="voice-receiver-bar is-four"></view>
              </view>
              <text class="voice-button-label">{{isTaskCompletionVoiceRecording ? '结束录音' : (isTaskCompletionVoiceRecognizing ? '识别中...' : '语音录入')}}</text>
              <text wx:if="{{isTaskCompletionVoiceRecording && taskCompletionVoiceElapsedText}}" class="voice-button-timer">{{taskCompletionVoiceElapsedText}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="task-complete-inline-entry">
        <view wx:if="{{!taskCompletionCreateNextTask}}" class="btn-ghost task-complete-inline-btn" bindtap="toggleTaskCompletionCreateNextTask">补下一步动作</view>
      </view>
      <view wx:if="{{taskCompletionCreateNextTask}}" class="task-complete-next-card">
        <view class="line-between task-complete-next-head">
          <view>
            <view class="task-complete-toggle-title">下一步任务</view>
          </view>
          <view class="section-link" bindtap="toggleTaskCompletionCreateNextTask">收起</view>
        </view>
        <view class="field-group task-complete-field is-inline-first">
          <input
            class="input-sim input-native primary-title-input task-complete-title-input"
            value="{{taskCompletionNextTaskTitle}}"
            data-field="taskCompletionNextTaskTitle"
            bindinput="onTaskCompletionNextTaskInput"
            bindfocus="onTaskCompletionFieldFocus"
            cursor-spacing="{{taskCompletionCursorSpacing}}"
            placeholder="填写下一步任务，例如：3天后回访报价反馈"
            placeholder-class="input-placeholder"
          />
        </view>
        <view class="field-group task-complete-field">
          <view class="field-label">任务类型</view>
          <view class="chips task-complete-type-wall">
            <view
              class="chip {{taskCompletionNextTaskType === item.type ? 'is-active' : ''}}"
              wx:for="{{nextTaskTemplates}}"
              wx:key="type"
              data-type="{{item.type}}"
              bindtap="setTaskCompletionNextTaskType"
            >{{item.label}}</view>
          </view>
        </view>
        <view class="field-group task-complete-field">
          <view class="field-label">下一步时间</view>
          <view class="split-row task-complete-time-row">
            <picker class="picker-block" mode="date" value="{{taskCompletionNextTaskDate}}" data-field="taskCompletionNextTaskDate" bindchange="onTaskCompletionNextTaskPicker">
              <view class="picker-sim">
                <view class="picker-value {{!taskCompletionNextTaskDate ? 'is-placeholder' : ''}}">{{taskCompletionNextTaskDate || '选择日期'}}</view>
              </view>
            </picker>
            <picker class="picker-block" mode="time" value="{{taskCompletionNextTaskTime}}" data-field="taskCompletionNextTaskTime" bindchange="onTaskCompletionNextTaskPicker">
              <view class="picker-sim">
                <view class="picker-value {{!taskCompletionNextTaskTime ? 'is-placeholder' : ''}}">{{taskCompletionNextTaskTime || '选择时间'}}</view>
              </view>
            </picker>
          </view>
        </view>
        <view class="field-group task-complete-field">
          <view class="field-label">任务说明</view>
          <textarea
            class="textarea-sim textarea-native task-complete-next-textarea"
            value="{{taskCompletionNextTaskDescription}}"
            data-field="taskCompletionNextTaskDescription"
            bindinput="onTaskCompletionNextTaskInput"
            bindfocus="onTaskCompletionFieldFocus"
            cursor-spacing="{{taskCompletionCursorSpacing}}"
            placeholder="可选：补一句下一步要重点确认什么。"
            placeholder-class="input-placeholder"
            maxlength="-1"
          ></textarea>
        </view>
      </view>
    </view>
    <view class="inline-actions task-complete-actions is-fixed {{isTaskCompletionEditing ? 'is-editing' : ''}}" style="{{taskCompleteActionsStyle}}">
      <view class="btn-ghost" bindtap="closeTaskCompleteSheet">取消</view>
      <view class="btn-primary" bindtap="submitTaskCompletion">{{taskActionId === taskCompletionTaskId ? '提交中...' : '确认完成'}}</view>
    </view>
  </view>
</view>

<bottom-nav current="home" appearance-page-class="{{appearancePageClass}}" bind:quickentry="handleQuickEntryTap" />
