.legal-document-detail-page {
  padding-bottom: 80rpx;
}

.legal-detail-loading {
  padding: 28rpx 24rpx;
}

.legal-version-card,
.legal-content-card {
  padding: 26rpx 24rpx;
}

.legal-version-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.legal-version-item {
  min-width: 0;
}

.legal-rich-text {
  margin-top: 18rpx;
  color: var(--theme-ink);
  line-height: 1.8;
  font-size: 28rpx;
}
