.rise-in {
  animation: riseIn 520ms ease both;
}

.stagger-1 {
  animation-delay: 40ms;
}

.stagger-2 {
  animation-delay: 90ms;
}

.stagger-3 {
  animation-delay: 140ms;
}

.stagger-4 {
  animation-delay: 190ms;
}

.shimmer {
  background-image: linear-gradient(90deg, rgba(255, 255, 255, 0.56) 25%, rgba(255, 255, 255, 0.9) 38%, rgba(255, 255, 255, 0.56) 50%);
  background-size: 200% 100%;
  animation: shimmerMove 1.4s linear infinite;
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 34rpx;
  border-radius: 36rpx;
  background: var(--theme-hero-bg);
  color: var(--theme-hero-text);
  box-shadow: var(--theme-hero-shadow);
}

.hero::after {
  content: "";
  position: absolute;
  right: -80rpx;
  top: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: var(--theme-hero-glow);
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: var(--theme-badge-bg);
  color: var(--theme-badge-text);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.eyebrow-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.source-badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: var(--theme-source-badge-bg);
  color: var(--theme-source-badge-text);
  font-size: 21rpx;
}

.hero-title {
  margin-top: 22rpx;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.2;
}

.hero-subtitle {
  margin-top: 14rpx;
  color: var(--theme-hero-muted);
  font-size: 26rpx;
  line-height: 1.6;
}

.hero-actions,
.inline-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 28rpx;
}

.hero-metrics,
.grid-two,
.grid-three {
  display: grid;
  gap: 18rpx;
}

.hero-metrics,
.grid-three {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.grid-two {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.metric-card {
  padding: 22rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(12rpx);
}

.metric-label {
  font-size: 22rpx;
  color: rgba(246, 240, 229, 0.72);
}

.metric-value {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--theme-hero-text);
}

.metric-note {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: rgba(255, 241, 224, 0.64);
}

.section {
  margin-top: 28rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--theme-section-title);
}

.section-link {
  font-size: 24rpx;
  color: var(--theme-link);
}

.ai-entry {
  --ai-entry-control-height: 56rpx;
  --ai-entry-icon-size: 40rpx;
  --ai-entry-font-size: 24rpx;
  --ai-entry-font-weight: 700;
  --ai-entry-gap: 10rpx;
  --ai-entry-padding-x: 18rpx;
  --ai-entry-radius: 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--ai-entry-gap);
  min-height: var(--ai-entry-control-height);
  font-size: var(--ai-entry-font-size);
  font-weight: var(--ai-entry-font-weight);
  line-height: 1.2;
  vertical-align: middle;
}

.ai-entry-icon {
  flex: 0 0 auto;
  width: var(--ai-entry-icon-size);
  height: var(--ai-entry-icon-size);
  display: block;
  align-self: center;
}

.ai-agent-loader {
  --ai-loader-size: var(--ai-entry-icon-size, 40rpx);
  --ai-loader-stroke: 2.4rpx;
  --ai-loader-body: #25364a;
  --ai-loader-orbit: rgba(232, 240, 254, 0.68);
  --ai-loader-eye: #f5a623;
  --ai-loader-eye-inner: #ffd166;
  --ai-loader-core: #fff;
  --ai-loader-smile: rgba(255, 255, 255, 0.82);
  width: var(--ai-loader-size);
  height: var(--ai-loader-size);
  position: relative;
  flex: 0 0 auto;
  align-self: center;
  overflow: visible;
}

.ai-agent-loader.is-light {
  --ai-loader-body: #fff8ef;
  --ai-loader-orbit: rgba(255, 253, 248, 0.78);
  --ai-loader-eye: #f5a623;
  --ai-loader-eye-inner: #ffd166;
  --ai-loader-core: #25364a;
  --ai-loader-smile: rgba(37, 54, 74, 0.72);
}

.ai-agent-loader.is-large {
  --ai-loader-size: 84rpx;
  --ai-loader-stroke: 3.4rpx;
}

.ai-agent-loader-antenna {
  position: absolute;
  left: -4%;
  top: 31%;
  width: 108%;
  height: 38%;
  border: var(--ai-loader-stroke) solid var(--ai-loader-orbit);
  border-radius: 999rpx;
  background: transparent;
  box-sizing: border-box;
  opacity: 0.72;
  transform-origin: 50% 50%;
  animation: aiPlanetOrbitSpin 3200ms linear infinite;
}

.ai-agent-loader-antenna.is-left {
  transform: rotate(-30deg);
}

.ai-agent-loader-antenna.is-right {
  opacity: 0.24;
  transform: rotate(150deg);
  animation-name: aiPlanetOrbitSpinBack;
  animation-duration: 4200ms;
}

.ai-agent-loader-dot {
  position: absolute;
  top: -14%;
  left: 50%;
  width: 11%;
  height: 28%;
  border-radius: 999rpx;
  background: var(--ai-loader-eye);
  box-shadow: 0 0 8rpx rgba(245, 166, 35, 0.28);
  opacity: 0.92;
  transform: translateX(-50%);
}

.ai-agent-loader-cap {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 7.5%;
  height: 7.5%;
  border-radius: 999rpx;
  background: var(--ai-loader-core);
  box-shadow: 0 0 7rpx rgba(255, 255, 255, 0.36);
  opacity: 0.9;
  transform: translate(-50%, -50%);
  z-index: 4;
  animation: aiPlanetCorePulse 1200ms ease-in-out infinite;
}

.ai-agent-loader-ear {
  display: none;
}

.ai-agent-loader-head {
  position: absolute;
  left: 16%;
  right: 16%;
  top: 16%;
  bottom: 16%;
  border-radius: 50%;
  background: var(--ai-loader-body);
  border: 1.2rpx solid rgba(111, 168, 255, 0.2);
  box-sizing: border-box;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.05), 0 6rpx 12rpx rgba(37, 54, 74, 0.08);
  opacity: 1;
  z-index: 2;
  animation: aiPlanetFocusFloat 2800ms ease-in-out infinite;
}

.ai-agent-loader-eye {
  position: absolute;
  top: 49%;
  border-radius: 999rpx;
  opacity: 1;
  transform-origin: 50% 50%;
}

.ai-agent-loader-eye.is-left {
  left: 27%;
  width: 46%;
  height: 32%;
  background: var(--ai-loader-eye);
  transform: translateY(-50%) scale(1);
  animation: aiPlanetEyeFocus 1600ms ease-in-out infinite;
}

.ai-agent-loader-eye.is-right {
  left: 43%;
  width: 14%;
  height: 14%;
  border-radius: 2rpx;
  background: var(--ai-loader-eye-inner);
  transform: translateY(-50%) rotate(45deg) scale(1);
  animation: aiPlanetEyeCrystal 1600ms ease-in-out infinite;
}

.ai-agent-loader-mouth {
  position: absolute;
  left: 36%;
  bottom: 17%;
  width: 28%;
  height: 12%;
  border-bottom: 1.6rpx solid var(--ai-loader-smile);
  border-radius: 0 0 999rpx 999rpx;
  box-sizing: border-box;
  opacity: 0.72;
}

.ai-entry-text {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 1.2em;
  font-size: var(--ai-entry-font-size);
  font-weight: var(--ai-entry-font-weight);
  line-height: 1.2;
  text-align: center;
  vertical-align: middle;
  white-space: nowrap;
}

.ai-entry-link,
.ai-entry-chip {
  min-height: var(--ai-entry-control-height);
  padding: 0 var(--ai-entry-padding-x);
  border-radius: var(--ai-entry-radius);
  background: var(--theme-brand-bg);
  color: var(--theme-brand-text);
  box-shadow: inset 0 0 0 1rpx rgba(24, 39, 51, 0.06);
}

.ai-entry-chip {
  padding: 0 var(--ai-entry-padding-x);
}

.ai-entry-button {
  min-height: var(--ai-entry-control-height);
  padding-left: var(--ai-entry-padding-x);
  padding-right: var(--ai-entry-padding-x);
  border-radius: var(--ai-entry-radius);
  gap: var(--ai-entry-gap);
}

.ai-entry-button .ai-entry-text,
.ai-entry-link .ai-entry-text,
.ai-entry-chip .ai-entry-text {
  min-height: 1.3em;
}

.ai-entry-button.btn-secondary,
.ai-entry-button.btn-ghost {
  background: var(--theme-brand-bg);
  color: var(--theme-brand-text);
  box-shadow: inset 0 0 0 1rpx rgba(24, 39, 51, 0.06);
}

@keyframes aiPlanetOrbitSpin {
  from {
    transform: rotate(-30deg);
  }

  to {
    transform: rotate(330deg);
  }
}

@keyframes aiPlanetOrbitSpinBack {
  from {
    transform: rotate(150deg);
  }

  to {
    transform: rotate(510deg);
  }
}

@keyframes aiPlanetFocusFloat {
  0%,
  100% {
    transform: scale(1);
  }

  50% {
    transform: scale(1.025);
  }
}

@keyframes aiPlanetEyeFocus {
  0%,
  100% {
    transform: translateY(-50%) scale(1);
    opacity: 0.92;
  }

  50% {
    transform: translateY(-50%) scale(1.08);
    opacity: 1;
  }
}

@keyframes aiPlanetEyeCrystal {
  0%,
  100% {
    transform: translateY(-50%) rotate(45deg) scale(1);
  }

  50% {
    transform: translateY(-50%) rotate(45deg) scale(1.14);
  }
}

@keyframes aiPlanetCorePulse {
  0%,
  100% {
    opacity: 0.72;
    transform: translate(-50%, -50%) scale(0.86);
  }

  50% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.22);
  }
}

