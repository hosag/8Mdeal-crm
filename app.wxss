  gap: 16rpx;
  margin-top: 24rpx;
}

.detail-box {
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(248, 245, 239, 0.88);
}

.detail-box-label {
  font-size: 22rpx;
  color: #7a8692;
}

.detail-box-value {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1e3240;
}

.detail-box-note {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #73818d;
  line-height: 1.5;
}

.detail-grid-compact {
  margin-top: 18rpx;
}

.detail-grid-compact .detail-box {
