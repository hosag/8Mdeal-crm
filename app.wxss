  box-shadow: 0 12rpx 30rpx rgba(24, 39, 51, 0.06);
}

.task-feedback-main {
  min-width: 0;
  flex: 1 1 auto;
}

.task-feedback-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a2f3f;
}

.task-feedback-detail {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #5f6d79;
}

.task-feedback-dismiss {
