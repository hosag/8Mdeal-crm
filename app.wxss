  font-size: 22rpx;
  color: #7a6546;
}

.info-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #17242e;
}

.card-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #657382;
  line-height: 1.6;
}

.pill-row,
.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.chip,
.status-badge,
.soft-badge,
.field-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.chip {
  background: #edf1f3;
  color: #40505d;
}

.chip.is-active {
  background: #173347;
  color: #fff5e8;
}

.status-badge {
  background: rgba(177, 139, 86, 0.14);
  color: #8d6631;
}

.status-badge.is-success {
  background: rgba(74, 132, 98, 0.14);
  color: #2b6a49;
}

.status-badge.is-danger {
  background: rgba(165, 69, 69, 0.14);
  color: #9a4040;
}

.status-badge.is-brand {
  background: rgba(38, 74, 96, 0.12);
  color: #244b61;
}

.soft-badge {
  background: #f5ede0;
  color: #8b6a37;
}

.field-pill {
  background: #eff4f6;
  color: #36515f;
  cursor: pointer;
}

.project-card + .project-card,
.todo-card + .todo-card,
.timeline-group + .timeline-group,
.deal-card + .deal-card,
.tag-card + .tag-card,
.form-card + .form-card,
.nav-card + .nav-card {
