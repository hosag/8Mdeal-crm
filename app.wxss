page {
  min-height: 100%;
  background:
    radial-gradient(circle at top left, rgba(40, 72, 95, 0.14), transparent 28%),
    radial-gradient(circle at top right, rgba(177, 139, 86, 0.12), transparent 24%),
    linear-gradient(180deg, #f7f5f0 0%, #f2efe8 42%, #eeebe3 100%);
  color: #17222d;
  font-family: "Avenir Next", "PingFang SC", "Helvetica Neue", sans-serif;
}

@keyframes riseIn {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes shimmerMove {
  0% {
    background-position: 100% 0;
  }
  100% {
    background-position: -100% 0;
  }
}

.page-shell {
  padding: 32rpx 28rpx 180rpx;
}

.rise-in {
  animation: riseIn 520ms ease both;
}

.stagger-1 {
  animation-delay: 40ms;
}

.stagger-2 {
  animation-delay: 90ms;
}

.stagger-3 {
  animation-delay: 140ms;
}

.stagger-4 {
  animation-delay: 190ms;
}

.shimmer {
  background-image: linear-gradient(90deg, rgba(255, 255, 255, 0.56) 25%, rgba(255, 255, 255, 0.9) 38%, rgba(255, 255, 255, 0.56) 50%);
  background-size: 200% 100%;
  animation: shimmerMove 1.4s linear infinite;
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 34rpx;
  border-radius: 36rpx;
  background: linear-gradient(145deg, #183247 0%, #23465f 54%, #2b596f 100%);
  color: #f6f2ea;
  box-shadow: 0 26rpx 60rpx rgba(22, 38, 50, 0.18);
}

.hero::after {
  content: "";
  position: absolute;
  right: -80rpx;
  top: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.2), transparent 72%);
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 248, 240, 0.92);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.eyebrow-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.source-badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 246, 235, 0.86);
  font-size: 21rpx;
}

.hero-title {
  margin-top: 22rpx;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.2;
}

.hero-subtitle {
  margin-top: 14rpx;
  color: rgba(245, 238, 228, 0.8);
  font-size: 26rpx;
  line-height: 1.6;
}

.hero-actions,
.inline-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 28rpx;
}

.hero-metrics,
.grid-two,
.grid-three {
  display: grid;
  gap: 18rpx;
}

.hero-metrics,
.grid-three {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.grid-two {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.metric-card {
  padding: 22rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(12rpx);
}

.metric-label {
  font-size: 22rpx;
  color: rgba(246, 240, 229, 0.72);
}

.metric-value {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #fff5e7;
}

.metric-note {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: rgba(255, 241, 224, 0.64);
}

.section {
  margin-top: 28rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #16242f;
}

.section-link {
  font-size: 24rpx;
  color: #365d76;
}

.surface-card,
.glass-card,
.list-card,
.sheet-card,
.form-card,
.mode-card,
.tag-card,
.stats-card,
.deal-card,
.nav-card {
  border-radius: 30rpx;
  background: rgba(255, 252, 247, 0.88);
  box-shadow: 0 18rpx 38rpx rgba(30, 39, 45, 0.08);
}

.surface-card,
.glass-card,
.list-card,
.sheet-card,
.form-card,
.mode-card,
.tag-card,
.stats-card,
.deal-card,
