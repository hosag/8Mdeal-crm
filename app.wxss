}

.shared-detail-value {
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-word;
}

.contact-summary {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: #f3f1eb;
}

.state-card {
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(255, 251, 246, 0.96) 0%, rgba(247, 242, 235, 0.96) 100%);
  box-shadow:
    inset 0 0 0 2rpx rgba(177, 139, 86, 0.08),
    0 18rpx 36rpx rgba(25, 40, 52, 0.08);
}

.state-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: linear-gradient(180deg, #d0aa73 0%, #c39050 100%);
}

.state-actions {
  margin-top: 18rpx;
}

.state-btn {
  min-width: 220rpx;
}

.contact-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a2b35;
}

.contact-role {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6a7784;
}

.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(16, 28, 36, 0.38);
}

.sheet-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background: rgba(247, 243, 236, 0.98);
  box-shadow: 0 -16rpx 46rpx rgba(20, 34, 45, 0.12);
}

.sheet-handle {
  width: 88rpx;
  height: 8rpx;
  margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: rgba(61, 82, 95, 0.18);
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.sheet-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #17252f;
}

.sheet-close {
  font-size: 24rpx;
  color: #667381;
}

.sheet-list .sheet-card + .sheet-card {
  margin-top: 16rpx;
}

.form-card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a2b35;
}

.form-card-desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #70808c;
  line-height: 1.6;
}

.field-group {
  margin-top: 20rpx;
}

.field-label {
  font-size: 24rpx;
  color: #41515f;
  margin-bottom: 10rpx;
}

.input-sim,
.textarea-sim,
.picker-sim {
  padding: 22rpx 24rpx;
  min-height: 88rpx;
  border-radius: 22rpx;
  background: #f3f1ec;
  font-size: 26rpx;
  line-height: 44rpx;
  color: #1f2e38;
  box-sizing: border-box;
}

.picker-sim {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.picker-block {
  display: block;
  width: 100%;
}

.input-placeholder {
  color: #95a1ab;
}

.input-native,
.textarea-native {
  width: 100%;
  box-sizing: border-box;
  border: 0;
  outline: none;
  padding: 0;
  margin: 0;
  background: transparent;
  vertical-align: middle;
}

.input-native {
  display: block;
  height: 44rpx;
  min-height: 44rpx;
  line-height: 44rpx;
}

.textarea-sim {
  min-height: 140rpx;
  line-height: 1.7;
}

.textarea-native {
  min-height: 140rpx;
  line-height: 1.7;
}

.picker-sim::after {
  content: ">";
  flex: 0 0 auto;
  color: #95a1ab;
}

.picker-value {
  flex: 1 1 auto;
  min-width: 0;
  font-size: 26rpx;
  color: #1f2e38;
}

.picker-value.is-placeholder {
  color: #95a1ab;
}

.split-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.split-row .picker-block {
  min-width: 0;
}

.attachment-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.attachment {
  height: 150rpx;
  border-radius: 24rpx;
  background: linear-gradient(140deg, rgba(31, 58, 76, 0.9) 0%, rgba(73, 108, 126, 0.78) 100%);
  color: #f6efe3;
  font-size: 24rpx;
  display: flex;
  align-items: flex-end;
  padding: 18rpx;
  box-sizing: border-box;
}

.attachment-image {
  position: relative;
  overflow: hidden;
  padding: 0;
}

.attachment-thumb {
  width: 100%;
  height: 100%;
}

.attachment-caption {
  position: absolute;
  left: 14rpx;
  right: 14rpx;
  bottom: 12rpx;
  font-size: 20rpx;
  color: #fff8ef;
  line-height: 1.4;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.28);
}

.attachment-remove {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(19, 31, 40, 0.58);
  color: #fff6ea;
  font-size: 20rpx;
}

.attachment.is-add {
  justify-content: center;
  align-items: center;
  background: rgba(244, 241, 235, 0.95);
  color: #7a8791;
  border: 2rpx dashed rgba(60, 83, 96, 0.18);
}

.attachment-trigger {
  margin-top: 14rpx;
}

.contact-editor {
  padding: 22rpx;
  border-radius: 26rpx;
  background: #f6f3ee;
}

.contact-editor + .contact-editor {
  margin-top: 16rpx;
}

.link-danger {
  color: #9a4040;
}

.section-link.is-muted {
  color: #80909c;
}

.step-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.step-pill {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #eef2f4;
  color: #516270;
  font-size: 22rpx;
}

.step-pill.is-current {
  background: #1d3f57;
  color: #fff4e2;
}

.mode-card.is-active,
.tag-card.is-active,
.field-pill.is-active {
  box-shadow: 0 0 0 2rpx rgba(32, 67, 88, 0.12);
  background: linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(244, 240, 233, 1) 100%);
}

.mode-title,
.tag-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #172631;
}

.mode-desc,
.tag-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #667584;
}

.preview-card {
  margin-top: 20rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  background: linear-gradient(145deg, #24445d 0%, #345d71 100%);
  color: #f9f2e8;
}

.preview-title {
  font-size: 34rpx;
  font-weight: 700;
}

.preview-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(247, 240, 230, 0.82);
}

.preview-footer {
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.12);
  font-size: 22rpx;
  color: rgba(248, 241, 230, 0.68);
}

.source-banner {
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, rgba(177, 139, 86, 0.14), rgba(177, 139, 86, 0.06));
  color: #7f6033;
  font-size: 24rpx;
  line-height: 1.7;
}

.stats-card {
  background: linear-gradient(145deg, rgba(255, 254, 252, 0.98) 0%, rgba(244, 241, 234, 0.98) 100%);
}

.stats-big {
  font-size: 38rpx;
  font-weight: 700;
  color: #213744;
}

.stats-label {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #6d7b88;
}

.menu-list {
  margin-top: 8rpx;
}

.menu-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 2rpx solid rgba(36, 61, 79, 0.06);
  font-size: 27rpx;
  color: #21323f;
}

.menu-row:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.menu-caption {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7c8894;
}

.result-card {
  padding: 26rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 254, 252, 0.98) 0%, rgba(242, 238, 231, 0.98) 100%);
  box-shadow: 0 16rpx 34rpx rgba(25, 40, 52, 0.08);
}

.result-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #183041;
}

.result-text {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.75;
  color: #556572;
}

.result-block + .result-block {
  margin-top: 20rpx;
}

.result-label {
  font-size: 23rpx;
  color: #7a8792;
}

.result-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.footer-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  padding: 14rpx;
  border-radius: 30rpx;
  background: rgba(255, 253, 248, 0.92);
  backdrop-filter: blur(18rpx);
  box-shadow: 0 18rpx 34rpx rgba(24, 39, 51, 0.12);
}

.footer-bar.is-three {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.btn-primary,
.btn-secondary,
.btn-ghost {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 28rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.btn-primary {
  background: linear-gradient(145deg, #183548 0%, #30566b 100%);
  color: #fff5e5;
}

.btn-secondary {
  background: linear-gradient(145deg, #b89159 0%, #d1ac71 100%);
  color: #fff8ee;
}

.btn-ghost {
  background: #f1ede5;
  color: #304858;
}

.fab {
  position: fixed;
  right: 28rpx;
  bottom: 164rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #173447 0%, #2c566a 100%);
  color: #fff1df;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 18rpx 34rpx rgba(24, 43, 57, 0.18);
}

.bottom-space {
  height: 140rpx;
}

.center-note {
  text-align: center;
  font-size: 23rpx;
  color: #80909c;
  line-height: 1.7;
}
