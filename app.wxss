}

.timeline-card {
  margin-top: 10rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 252, 247, 0.9);
  box-shadow: 0 10rpx 24rpx rgba(24, 39, 51, 0.06);
}

.timeline-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #182730;
}

.timeline-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #5d6b78;
  line-height: 1.7;
}

.timeline-section + .timeline-section {
  margin-top: 16rpx;
}

.timeline-section-label {
  font-size: 22rpx;
  color: #7b8792;
}

.timeline-section-text {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #4f6070;
  line-height: 1.75;
}

.timeline-list {
  margin-top: 10rpx;
}

.timeline-list-item {
  position: relative;
  padding-left: 24rpx;
  font-size: 24rpx;
  color: #546472;
  line-height: 1.8;
}

.timeline-list-item::before {
  content: "";
  position: absolute;
  left: 0;
  top: 14rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #b18b56;
}

.timeline-list-item.is-risk::before {
