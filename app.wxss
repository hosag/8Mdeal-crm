}

.todo-priority {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #8d6430;
}

.checklist {
  margin-top: 18rpx;
}

.check-item {
  position: relative;
  padding-left: 28rpx;
  font-size: 24rpx;
  color: #52606f;
  line-height: 1.8;
}

.check-item::before {
