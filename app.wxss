}

.toolbar {
  display: flex;
  gap: 14rpx;
  overflow-x: auto;
  padding-bottom: 6rpx;
}

.projects-filter-card {
  padding: 20rpx 20rpx 18rpx;
}

.compact-search-panel {
  margin-top: 0;
}

.projects-quick-filter-row {
  margin-top: 10rpx;
  gap: 8rpx;
  padding-bottom: 2rpx;
  flex-wrap: wrap;
  overflow-x: visible;
}

.projects-picker-row {
  margin-top: 8rpx;
  gap: 10rpx;
}

.projects-picker-group {
  margin-top: 0;
}

.projects-picker-group .field-label {
  margin-bottom: 6rpx;
  font-size: 22rpx;
}

.projects-picker-sim {
  min-height: 76rpx;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
}

.search-box {
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.82);
