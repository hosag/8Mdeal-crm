.privacy-auth-mask {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
  background: rgba(16, 28, 36, 0.46);
}

.privacy-auth-panel {
  width: 100%;
  max-width: 640rpx;
  padding: 36rpx 32rpx 28rpx;
  border-radius: 32rpx;
  box-sizing: border-box;
  background: #fffdf8;
  box-shadow: 0 24rpx 70rpx rgba(14, 26, 36, 0.2);
}

.privacy-auth-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #17242e;
}

.privacy-auth-desc {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #40515f;
}

.privacy-auth-link {
  margin-top: 18rpx;
  font-size: 25rpx;
  color: #1f566f;
}

.privacy-auth-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 30rpx;
}

.privacy-auth-cancel,
.privacy-auth-confirm {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 26rpx;
  box-sizing: border-box;
}

.privacy-auth-cancel {
  color: #5d6a75;
  background: #f1eee8;
}

.privacy-auth-confirm {
  padding: 0;
  border: 0;
  color: #fff7e8;
  background: linear-gradient(145deg, #183447 0%, #2b5369 100%);
}

.privacy-auth-confirm::after {
  border: 0;
}
