.bottom-nav {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  padding: 14rpx;
  border-radius: 32rpx;
  background: rgba(255, 252, 247, 0.92);
  backdrop-filter: blur(18rpx);
  box-shadow: 0 16rpx 34rpx rgba(23, 40, 52, 0.16);
}

.bottom-nav__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 8rpx;
  color: #7b8793;
}

.bottom-nav__item.is-active {
  color: #1c3f57;
}

.bottom-nav__icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: #f0ede6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.bottom-nav__icon-image {
  width: 34rpx;
  height: 34rpx;
}

.bottom-nav__item.is-active .bottom-nav__icon {
  background: linear-gradient(145deg, #193547 0%, #31586d 100%);
  color: #fff3de;
}

.bottom-nav__label {
  font-size: 20rpx;
}
