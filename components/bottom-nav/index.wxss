.bottom-nav {
  --nav-bg: rgba(255, 252, 247, 0.92);
  --nav-shadow: 0 16rpx 34rpx rgba(23, 40, 52, 0.16);
  --nav-icon-bg: #f0ede6;
  --nav-text: #7b8793;
  --nav-active-bg: linear-gradient(145deg, #193547 0%, #31586d 100%);
  --nav-active-text: #1c3f57;
  --nav-active-icon-text: #fff3de;
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 8rpx;
  padding: 14rpx 12rpx 12rpx;
  border-radius: 32rpx;
  background: var(--nav-bg);
  backdrop-filter: blur(18rpx);
  box-shadow: var(--nav-shadow);
}

.bottom-nav__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 8rpx;
  color: var(--nav-text);
}

.bottom-nav__item.is-active {
  color: var(--nav-active-text);
}

.bottom-nav__icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: var(--nav-icon-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.bottom-nav__icon-image {
  width: 34rpx;
  height: 34rpx;
}

.bottom-nav__item.is-active .bottom-nav__icon {
  background: var(--nav-active-bg);
  color: var(--nav-active-icon-text);
}

.bottom-nav__label {
  font-size: 20rpx;
}

.bottom-nav__action-wrap {
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.bottom-nav__action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transform: translateY(-34rpx);
}

.bottom-nav__action-icon {
  position: relative;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: var(--nav-active-bg);
  box-shadow:
    0 18rpx 32rpx rgba(23, 40, 52, 0.2),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.bottom-nav__action-image {
  width: 38rpx;
  height: 38rpx;
}

.bottom-nav__action-label {
  margin-top: -2rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: var(--nav-active-text);
}

.bottom-nav.appearance-theme-warm_almond {
  --nav-bg: rgba(255, 249, 242, 0.94);
  --nav-shadow: 0 16rpx 34rpx rgba(96, 60, 44, 0.14);
  --nav-icon-bg: #f4e6d9;
  --nav-text: #907767;
  --nav-active-bg: linear-gradient(145deg, #824b36 0%, #b47049 100%);
  --nav-active-text: #844a30;
}

.bottom-nav.appearance-theme-misty_blossom {
  --nav-bg: rgba(255, 249, 252, 0.94);
  --nav-shadow: 0 16rpx 34rpx rgba(119, 89, 103, 0.12);
  --nav-icon-bg: #f6edf1;
  --nav-text: #8d7b86;
  --nav-active-bg: linear-gradient(145deg, #8d6178 0%, #bb879e 100%);
  --nav-active-text: #8d6178;
}

.bottom-nav.appearance-theme-festive_crimson {
  --nav-bg: rgba(255, 248, 244, 0.94);
  --nav-shadow: 0 16rpx 34rpx rgba(109, 47, 47, 0.14);
  --nav-icon-bg: #f6ebe7;
  --nav-text: #93797a;
  --nav-active-bg: linear-gradient(145deg, #9f3c3f 0%, #c16c4a 100%);
  --nav-active-text: #9f3c3f;
}

.bottom-nav.appearance-theme-cloud_mist {
  --nav-bg: rgba(252, 249, 243, 0.94);
  --nav-shadow: 0 16rpx 34rpx rgba(106, 109, 79, 0.12);
  --nav-icon-bg: #f2ede4;
  --nav-text: #858474;
  --nav-active-bg: linear-gradient(145deg, #75816c 0%, #9aa38c 100%);
  --nav-active-text: #6b775f;
}

.bottom-nav.appearance-theme-ink_readable {
  --nav-bg: rgba(250, 252, 249, 0.96);
  --nav-shadow: 0 16rpx 34rpx rgba(51, 70, 58, 0.12);
  --nav-icon-bg: #eef3ef;
  --nav-text: #71827a;
  --nav-active-bg: linear-gradient(145deg, #385348 0%, #5f766a 100%);
  --nav-active-text: #355045;
  --nav-active-icon-text: #f6faf8;
