.bottom-nav.appearance-font-large {
  padding: 16rpx;
}

.bottom-nav.appearance-font-large .bottom-nav__item {
  gap: 10rpx;
  padding: 12rpx 8rpx;
}

.bottom-nav.appearance-font-large .bottom-nav__icon {
  width: 60rpx;
  height: 60rpx;
}

.bottom-nav.appearance-font-large .bottom-nav__icon-image {
  width: 36rpx;
  height: 36rpx;
}

.bottom-nav.appearance-font-large .bottom-nav__label {
  font-size: 24rpx;
}

.bottom-nav.appearance-font-large .bottom-nav__action {
  transform: translateY(-36rpx);
}

.bottom-nav.appearance-font-large .bottom-nav__action-icon {
  width: 100rpx;
  height: 100rpx;
}

.bottom-nav.appearance-font-large .bottom-nav__action-image {
  width: 42rpx;
  height: 42rpx;
}

.bottom-nav.appearance-font-large .bottom-nav__action-label {
  font-size: 24rpx;
}

.bottom-nav.appearance-font-readable {
  padding: 18rpx;
}

.bottom-nav.appearance-font-readable .bottom-nav__item {
  gap: 12rpx;
  padding: 14rpx 8rpx;
}

.bottom-nav.appearance-font-readable .bottom-nav__icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
}

.bottom-nav.appearance-font-readable .bottom-nav__icon-image {
  width: 40rpx;
  height: 40rpx;
}

.bottom-nav.appearance-font-readable .bottom-nav__label {
  font-size: 30rpx;
}

.bottom-nav.appearance-font-readable .bottom-nav__action {
  transform: translateY(-42rpx);
}

.bottom-nav.appearance-font-readable .bottom-nav__action-icon {
  width: 112rpx;
  height: 112rpx;
}

.bottom-nav.appearance-font-readable .bottom-nav__action-image {
  width: 48rpx;
  height: 48rpx;
}

.bottom-nav.appearance-font-readable .bottom-nav__action-label {
  font-size: 30rpx;
}
