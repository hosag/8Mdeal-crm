.loading-panel {
  --loading-card-bg: rgba(255, 252, 247, 0.86);
  --loading-card-shadow: 0 18rpx 36rpx rgba(24, 39, 51, 0.06);
  --loading-hero-bg: rgba(255, 255, 255, 0.72);
  --loading-badge-bg: rgba(38, 74, 96, 0.08);
  --loading-badge-text: #456275;
  --loading-title: #1d2f3b;
  --loading-desc: #71808c;
  --loading-line-bg: rgba(31, 56, 72, 0.08);
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.loading-shell,
.loading-card {
  border-radius: 30rpx;
  background: var(--loading-card-bg);
  box-shadow: var(--loading-card-shadow);
}

.loading-shell {
  overflow: hidden;
}

.loading-hero {
  height: 220rpx;
  border-radius: 30rpx 30rpx 0 0;
  background: var(--loading-hero-bg);
}

.loading-summary {
  padding: 22rpx 24rpx 24rpx;
}

.loading-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: var(--loading-badge-bg);
  color: var(--loading-badge-text);
  font-size: 21rpx;
  font-weight: 700;
}

.loading-title {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--loading-title);
}

.loading-desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: var(--loading-desc);
}

.loading-card {
  padding: 28rpx;
}

.loading-line {
  height: 22rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  background: var(--loading-line-bg);
}

.loading-line.is-long {
  width: 68%;
}

.loading-line:not(.is-long) {
  width: 44%;
}

.loading-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.loading-pill {
  height: 68rpx;
  border-radius: 22rpx;
  background: var(--loading-line-bg);
}

.loading-panel.appearance-theme-warm_almond {
  --loading-card-bg: rgba(255, 249, 242, 0.88);
  --loading-card-shadow: 0 18rpx 36rpx rgba(96, 60, 44, 0.07);
