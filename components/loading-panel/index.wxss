.loading-panel.appearance-font-large .loading-badge {
  min-height: 56rpx;
  font-size: 27rpx;
}

.loading-panel.appearance-font-large .loading-title {
  font-size: 38rpx;
}

.loading-panel.appearance-font-large .loading-desc {
  font-size: 28rpx;
  line-height: 1.78;
}

.loading-panel.appearance-font-large .loading-pill {
  height: 76rpx;
}

.loading-panel.appearance-font-readable .loading-badge {
  min-height: 68rpx;
  padding-left: 26rpx;
  padding-right: 26rpx;
  font-size: 34rpx;
}

.loading-panel.appearance-font-readable .loading-title {
  font-size: 48rpx;
}

.loading-panel.appearance-font-readable .loading-desc {
  font-size: 38rpx;
  line-height: 2;
}

.loading-panel.appearance-font-readable .loading-pill {
  height: 92rpx;
}
